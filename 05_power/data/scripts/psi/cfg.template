#}
#PT_RPT_FILE             user_data/STA/pt.rpt
#PATH_IDX_LIST           { 1 3 5 }
#PATH_START_IDX          1
#PATH_END_IDX            10
#ACTION                  clockjitter
#CLK_INST_FILE           psi_input.dir/chip_clk_inst.out
#REDHAWK_DIR             ./
