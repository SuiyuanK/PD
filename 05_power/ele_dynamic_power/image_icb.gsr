### required parameters
VDD_NETS {
    VDD 1.21
}

GND_NETS {
    VSS 0
}

FREQ 1e6


### optional parameters
DELTA_T_RMS_EM 15

LIB2AVM 1

# CHARACTERIZATION_MODE ACCURATE

TOGGLE_RATE 0.1 1.2

INPUT_TRANSITION 0.3ns

# SWITCH_MODEL_FILES ../../data/switch.model

IGNORE_LEF_DEF_MISMATCH 1
IGNORE_LIB_CHECK 1
IGNORE_DEF_ERROR 1
ADD_LEF_CELL_FOR_POWER 1
STEINER_TREE_CAP 2.02e-4

BLOCK_POWER_FOR_SCALING {
    FULLCHIP FULLCHIP 0.600
}

