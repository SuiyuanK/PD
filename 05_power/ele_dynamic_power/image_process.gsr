}


## timinig file 回到pt打开session 运行write_timing_file.tcl
STA_FILE {
    FREQ_OF_MISSING_INSTANCES 1e6
    image_process ../data/image_process.timing
}


USE_DEF_VIARULE 1

## APL
APL_FILES {
    hvt_ff1p21v125c.cdev cap
    hvt_ff1p21v125c.pwcdev pwcap
    hvt_ff1p21v125c.spiprof current
    lvt_ff1p21v125c.cdev cap
    lvt_ff1p21v125c.pwcdev pwcap
    lvt_ff1p21v125c.spiprof current
    rvt_ff1p21v125c.cdev cap
    rvt_ff1p21v125c.pwcdev pwcap
    rvt_ff1p21v125c.spiprof current
}

## spef
CELL_RC_FILE {
    image_process ../data/image_process.cmax_125c.spef.gz
}

### required parameters
VDD_NETS {
    VDD 1.1
}

GND_NETS {
    VSS 0
}

FREQ 1e6


### optional parameters
LIB2AVM 1

CHARACTERIZATION_MODE ACCURATE

TOGGLE_RATE 0.1 1.2

INPUT_TRANSITION 0.3ns

# SWITCH_MODEL_FILES ../data/switch.model

IGNORE_LEF_DEF_MISMATCH 1
IGNORE_LIB_CHECK 1
IGNORE_DEF_ERROR 1
ADD_LEF_CELL_FOR_POWER 1
STEINER_TREE_CAP 2.02-4

BLOCK_POWER_FOR_SCALING {
    FULLCHIP FULLCHIP 0.600
}

