set TOPDIR	            [sh pwd]
/mnt/hgfs/Em/PD/00_dc
# Define RTL source files directory
set rtlDir 		        [getenv rtlDir]
../../RTL
set TOP_MODULE          [getenv TOP_MODULE]                                       
conv
# Output&Reports files directory
set reportsDir          "$TOPDIR/rpts"
/mnt/hgfs/Em/PD/00_dc/rpts
