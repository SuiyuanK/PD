/mnt/hgfs/Em/PD/00_dc/outputs
set dataDir             "$TOPDIR/data"
/mnt/hgfs/Em/PD/00_dc/data
# Design Compile system setting
set_app_var search_path                ". $rtlDir"
. ../../RTL
lappend search_path             "$dataDir/lib"
. ../../RTL /mnt/hgfs/Em/PD/00_dc/data/lib
#****************************************************
# stdcell
