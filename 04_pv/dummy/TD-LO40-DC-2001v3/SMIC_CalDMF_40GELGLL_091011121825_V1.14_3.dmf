//*************************************
//     DIRECTIVE SECTION
//*************************************


LAYOUT PRIMARY "*"
LAYOUT PATH "xxx.gds"
LAYOUT SYSTEM GDSII
 
DRC RESULTS DATABASE "Dummy.gds" GDSII _dummy
//DRC RESULTS DATABASE "DUM.OUT" ASCII
DRC MAXIMUM RESULTS ALL
DRC MAXIMUM VERTEX 199
DRC KEEP EMPTY NO

DRC SUMMARY REPORT "ADD_DUMAAGTMnVn.sum" REPLACE HIER 
PRECISION 1000


LAYER   MAP      10 DATATYPE 0 1099 
LAYER   AAi      1099

LAYER   MAP      30 DATATYPE 0 3099
LAYER   GTi      3099

LAYER   MAP      14 DATATYPE 0 1499
LAYER   NW       1499

LAYER   MAP      19 DATATYPE 0 1999
LAYER   DNW      1999

LAYER   MAP     26 DATATYPE 0 2699
LAYER   LOGO    2699

LAYER   MAP      61 DATATYPE 0 610
LAYER   M1i      610      //      Metal-1

LAYER   MAP      62 DATATYPE 0 620
LAYER   M2i      620      //      Metal-2

LAYER   MAP      63 DATATYPE 0 630
LAYER   M3i      630      //      Metal-3

LAYER   MAP      64 DATATYPE 0 640
LAYER   M4i      640      //      Metal-4

LAYER   MAP      65 DATATYPE 0 650
LAYER   M5i      650      //      Metal-5

LAYER   MAP      66 DATATYPE 0 660
LAYER   M6i      660      //      Metal-6

LAYER   MAP      67 DATATYPE 0 670
LAYER   M7i      670      //      Metal-7

LAYER   MAP      68 DATATYPE 0 680
LAYER   M8i      680      //      Metal-8

LAYER   MAP      120 DATATYPE 0 1200
LAYER   TM1i     1200     //      Top Metal 1

LAYER   MAP      122 DATATYPE 0 1220
LAYER   TM2i     1220     //      Top Metal 2

LAYER   MAP     70 DATATYPE 0 700
LAYER   V1i     700

LAYER   MAP     70 DATATYPE 1 701
LAYER   V1DUM   701

LAYER   MAP     70 DATATYPE 6 706
LAYER   V1DUB   706

LAYER   MAP     71 DATATYPE 0 710
LAYER   V2i     710

LAYER   MAP     71 DATATYPE 1 711
LAYER   V2DUM   711

LAYER   MAP     71 DATATYPE 6 716
LAYER   V2DUB   716

LAYER   MAP     72 DATATYPE 0 720
LAYER   V3i     720

LAYER   MAP     72 DATATYPE 1 721
LAYER   V3DUM   721

LAYER   MAP     72 DATATYPE 6 726
LAYER   V3DUB   726

LAYER   MAP     73 DATATYPE 0 730
LAYER   V4i     730

LAYER   MAP     73 DATATYPE 1 731
LAYER   V4DUM   731

LAYER   MAP     73 DATATYPE 6 736
LAYER   V4DUB   736

LAYER   MAP     74 DATATYPE 0 740
LAYER   V5i     740

LAYER   MAP     74 DATATYPE 1 741
LAYER   V5DUM   741

LAYER   MAP     74 DATATYPE 6 746
LAYER   V5DUB   746

LAYER   MAP     75 DATATYPE 0 750
LAYER   V6i     750

LAYER   MAP     75 DATATYPE 1 751
LAYER   V6DUM   751

LAYER   MAP     75 DATATYPE 6 756
LAYER   V6DUB   756

LAYER   MAP     76 DATATYPE 0 760
LAYER   V7i     760

LAYER   MAP     76 DATATYPE 1 761
LAYER   V7DUM   761

LAYER   MAP     76 DATATYPE 6 766
LAYER   V7DUB   766

LAYER   MAP     80 DATATYPE 0 800
LAYER   PA      800      //      Passivation / Pad

LAYER   MAP     81 DATATYPE 0 810
LAYER   FUSE    810      //      Fuse Window

LAYER   MAP     81 DATATYPE 1 811
LAYER   GTFUSE  811

LAYER   MAP     83 DATATYPE 0  8300
LAYER   ALPAi   8300

LAYER   MAP     83 DATATYPE 3  8303
LAYER   ALRDL   8303

LAYER   MAP     83 DATATYPE 6  8306
LAYER   ALDUB   8306

LAYER   MAP     83 DATATYPE 11 8311
LAYER   ALDUM   8311

LAYER   MAP     90 DATATYPE 0 900
LAYER   DUMBM   900      //      Define area to prevent METAL Dummy operation

LAYER   MAP     91 DATATYPE 0 910
LAYER   DUMBA   910      //      Define area to prevent AA Dummy operation

LAYER   MAP     92 DATATYPE 0 920
LAYER   DUMBP   920      //      Define area to prevent Poly Dummy operation

LAYER   MAP     93 DATATYPE 0 930
LAYER   VARMOS  930     //      Block Layer to cover all MOS-type varactor

LAYER   MAP     95 DATATYPE 0 950
LAYER   RESNW   950      //      Dummy Pattern for NWELL Resistor

LAYER   MAP     96 DATATYPE 0 960
LAYER   RESP1   960      //      Dummy Pattern for Poly-1 Resistor

LAYER   MAP     97 DATATYPE 0 970
LAYER   RESAA   970      //      Dummy Pattern for AA Resistor

LAYER   MAP     127 DATATYPE 0 1270
LAYER   BORDERi 1270

LAYER   MAP     151     DATATYPE == 1   1511
LAYER   M1DUB   1511     // Block layer for M1 dummy operations

LAYER   MAP     152     DATATYPE == 1   1521
LAYER   M2DUB   1521     // Block layer for M2 dummy operations

LAYER   MAP     153     DATATYPE == 1   1531
LAYER   M3DUB   1531     // Block layer for M3 dummy operations

LAYER   MAP     154     DATATYPE == 1   1541
LAYER   M4DUB   1541     // Block layer for M4 dummy operations

LAYER   MAP     155     DATATYPE == 1   1551
LAYER   M5DUB   1551     // Block layer for M5 dummy operations

LAYER   MAP     156     DATATYPE == 1   1561
LAYER   M6DUB   1561     // Block layer for M6 dummy operations

LAYER   MAP     157     DATATYPE == 1   1571
LAYER   M7DUB   1571     // Block layer for M7 dummy operations

LAYER   MAP     158     DATATYPE == 1   1581
LAYER   M8DUB   1581     // Block layer for M8 dummy operations

LAYER   MAP     159 DATATYPE 7 1597
LAYER   PTCT 1597

LAYER   MAP     193     DATATYPE == 1   1939
LAYER   TM1DUB  1939     // Block layer for TM1 dummy operations

LAYER   MAP     194     DATATYPE == 1   1940
LAYER   TM2DUB  1940     // Block layer for TM2 dummy operations

//--------------------------------------------------------------------------------
LAYER   MAP 189 DATATYPE 0 1890
LAYER	MARKGi	1890	//	Guard ring or seal ring area mark layer for DRC
MARKG = MARKGi OR MARKS

LAYER MAP 189  DATATYPE  151  1895
LAYER MARKS 1895
//------------------------------------------------------------------------------------

LAYER   MAP     211 DATATYPE 1 2111
LAYER   MOMDMY  2111    //      MOM Dummy layer

LAYER   MAP     212 DATATYPE 0 2120
LAYER   INDMY   2120

LAYER   MAP     231 DATATYPE 0 2310
LAYER   MTT2i   2310

LAYER   MAP     10  DATATYPE 1 1019
LAYER   AADUM   1019

LAYER   MAP     30  DATATYPE 1 3010
LAYER   GTDUM   3010

LAYER   MAP     61  DATATYPE 1 6110
LAYER   M1DUM   6110

LAYER   MAP     62  DATATYPE 1 6210
LAYER   M2DUM   6210

LAYER   MAP     63  DATATYPE 1 6310
LAYER   M3DUM   6310

LAYER   MAP     64  DATATYPE 1 6410
LAYER   M4DUM   6410

LAYER   MAP     65  DATATYPE 1 6510
LAYER   M5DUM   6510

LAYER   MAP     66  DATATYPE 1 6610
LAYER   M6DUM   6610

LAYER   MAP     67  DATATYPE 1 6710
LAYER   M7DUM   6710

LAYER   MAP     68  DATATYPE 1 6810
LAYER   M8DUM   6810

LAYER   MAP     120  DATATYPE 1 1201
LAYER   TM1DUM  1201

LAYER   MAP     122  DATATYPE 1 1221
LAYER   TM2DUM  1221

LAYER   MAP     61   DATATYPE 7 6170
LAYER   M1DOP   6170

LAYER   MAP     62   DATATYPE 7 6270
LAYER   M2DOP   6270

LAYER   MAP     63   DATATYPE 7 6370
LAYER   M3DOP   6370

LAYER   MAP     64   DATATYPE 7 6470
LAYER   M4DOP   6470

LAYER   MAP     65   DATATYPE 7 6570
LAYER   M5DOP   6570

LAYER   MAP     66   DATATYPE 7 6670
LAYER   M6DOP   6670

LAYER   MAP     67   DATATYPE 7 6770
LAYER   M7DOP   6770

LAYER   MAP     68   DATATYPE 7 6870
LAYER   M8DOP   6870

LAYER   MAP     70   DATATYPE 7 7070
LAYER   V1DOP   7070

LAYER   MAP     71   DATATYPE 7 7170
LAYER   V2DOP   7170

LAYER   MAP     72   DATATYPE 7 7270
LAYER   V3DOP   7270

LAYER   MAP     73   DATATYPE 7 7370
LAYER   V4DOP   7370

LAYER   MAP     74   DATATYPE 7 7470
LAYER   V5DOP   7470

LAYER   MAP     75   DATATYPE 7 7570
LAYER   V6DOP   7570

LAYER   MAP     76   DATATYPE 7 7670
LAYER   V7DOP   7670

LAYER   MAP     231  DATATYPE 1 2311
LAYER   MTT2DM  2311

LAYER   MAP     194  DATATYPE 2 1942
LAYER   MTT2DB  1942

LAYER   MAP     97 DATATYPE 3 973
LAYER   DIFRES  973

LAYER   MAP     96 DATATYPE 3 963
LAYER   PLRES   963

LAYER   MAP     210 DATATYPE 0 2199
LAYER   HRPDMY  2199

BORDER = BORDERi OR (HOLES BORDERi)

AA = AAi OR AADUM
GT = GTi OR GTDUM
M1 = (M1i OR M1DUM) OR M1DOP
M2 = (M2i OR M2DUM) OR M2DOP
M3 = (M3i OR M3DUM) OR M3DOP
M4 = (M4i OR M4DUM) OR M4DOP
M5 = (M5i OR M5DUM) OR M5DOP
M6 = (M6i OR M6DUM) OR M6DOP
M7 = (M7i OR M7DUM) OR M7DOP
M8 = (M8i OR M8DUM) OR M8DOP
TM1 = TM1i OR TM1DUM
TM2 = TM2i OR TM2DUM
MTT2 = MTT2i OR MTT2DM

// Metal constrains for distinguishing datetype
M1_UP = SIZE M1 BY 1.111
M2_UP = SIZE M2 BY 1.111
M3_UP = SIZE M3 BY 1.111
M4_UP = SIZE M4 BY 1.111
M5_UP = SIZE M5 BY 1.111
M6_UP = SIZE M6 BY 1.111
M7_UP = SIZE M7 BY 1.111
M8_UP = SIZE M8 BY 1.111


V1     = (V1i OR V1DUM) OR V1DOP
V2     = (V2i OR V2DUM) OR V2DOP
V3     = (V3i OR V3DUM) OR V3DOP
V4     = (V4i OR V4DUM) OR V4DOP
V5     = (V5i OR V5DUM) OR V5DOP
V6     = (V6i OR V6DUM) OR V6DOP
V7     = (V7i OR V7DUM) OR V7DOP
ALPA   = (ALPAi OR ALRDL) OR ALDUM

V1D_BK        = (V1 OR V1DUB) OR INDMY
V2D_BK        = (V2 OR V2DUB) OR INDMY
V3D_BK        = (V3 OR V3DUB) OR INDMY
V4D_BK        = (V4 OR V4DUB) OR INDMY
V5D_BK        = (V5 OR V5DUB) OR INDMY
V6D_BK        = (V6 OR V6DUB) OR INDMY
V7D_BK        = (V7 OR V7DUB) OR INDMY

GTFUSE_EXPAND = SIZE GTFUSE BY 3.332
DUM_INSERT_AREA_M1 = DENSITY M1 <= 0.6 WINDOW 110 STEP 55 BACKUP
DUM_INSERT_AREA_M2 = DENSITY M2 <= 0.6 WINDOW 110 STEP 55 BACKUP
DUM_INSERT_AREA_M3 = DENSITY M3 <= 0.6 WINDOW 110 STEP 55 BACKUP
DUM_INSERT_AREA_M4 = DENSITY M4 <= 0.6 WINDOW 110 STEP 55 BACKUP
DUM_INSERT_AREA_M5 = DENSITY M5 <= 0.6 WINDOW 110 STEP 55 BACKUP
DUM_INSERT_AREA_M6 = DENSITY M6 <= 0.6 WINDOW 110 STEP 55 BACKUP
DUM_INSERT_AREA_M7 = DENSITY M7 <= 0.6 WINDOW 110 STEP 55 BACKUP
DUM_INSERT_AREA_M8 = DENSITY M8 <= 0.6 WINDOW 110 STEP 55 BACKUP
DUM_INSERT_AREA_TM1 = DENSITY TM1 <= 0.6 WINDOW 110 STEP 55 BACKUP
DUM_INSERT_AREA_TM2 = DENSITY TM2 <= 0.6 WINDOW 110 STEP 55 BACKUP
DUM_INSERT_AREA_MTT2 = DENSITY MTT2 <= 0.6 WINDOW 110 STEP 55 BACKUP
DUM_INSERT_AREA_ALPA = DENSITY ALPA <= 0.6 WINDOW 110 STEP 55 BACKUP

//=====================
//AA Dummy insertion 
//=====================

//Dummy AA rectangles constrains
AAD_GTD = LOGO OR (PTCT OR (MARKG OR RESNW))
AAD = (AAD_GTD OR (PLRES OR HRPDMY)) OR ((GT OR DUMBA) OR RESP1)
AAD_a = SIZE (AAD OR AA) BY 2.221
AA_OUT_DUM = DUMBA OUTSIDE AAi
AAD_b = OR (SIZE AAD BY 0.221)  (SIZE AA BY 0.710) (SIZE AA_OUT_DUM BY 0.71)

NW_ENC_SPA_AA = (SIZE NW BY 0.266) NOT (SIZE NW BY -0.266)
DNW_ENC_SPA_AA = (SIZE DNW BY 0.266) NOT (SIZE DNW BY -0.266)
NW_DNW_ENC_SPA_AA = NW_ENC_SPA_AA OR DNW_ENC_SPA_AA

DUMAA_CONSTRAIN_0 = NW_DNW_ENC_SPA_AA OR (GTFUSE_EXPAND NOT GTFUSE)
DUMAA_CONSTRAIN_a = AAD_a OR DUMAA_CONSTRAIN_0
DUMAA_CONSTRAIN_b = AAD_b OR DUMAA_CONSTRAIN_0


//Dummy AA_a rectangles produce regulation
EXTENT_AA_0   = SIZE BORDER BY -0.1
EXTENT_AA_a_1   = SHRINK (SIZE EXTENT_AA_0 BY 6.666) RIGHT BY 6.666 TOP BY 6.666 LEFT BY 8.888
EXTENT_AA_a_2   = SHRINK (SIZE EXTENT_AA_a_1 BY 6.666) RIGHT BY 6.666 TOP BY 6.666 LEFT BY 8.888

DUMAA_OFF_a_0 =  RECTANGLES 4.444 4.444 2.222 17.776 OFFSET 0 2.222 INSIDE OF LAYER EXTENT_AA_0
DUMAA_OFF_a_1 = (RECTANGLES 4.444 4.444 2.222 17.776 OFFSET 0 2.222 INSIDE OF LAYER EXTENT_AA_a_1) INSIDE EXTENT_AA_0
DUMAA_OFF_a_2 = (RECTANGLES 4.444 4.444 2.222 17.776 OFFSET 0 2.222 INSIDE OF LAYER EXTENT_AA_a_2) INSIDE EXTENT_AA_0

DUMAA_OFF_a_all = DUMAA_OFF_a_0 OR (DUMAA_OFF_a_1 OR DUMAA_OFF_a_2)


//AADUM_a rectangles
DUMAA_a_all = DUMAA_OFF_a_all NOT INTERACT DUMAA_CONSTRAIN_a


//Dummy AA_b rectangles produce regulation
EXTENT_AA_b_1   = SHRINK (SIZE EXTENT_AA_0 BY 0.666) RIGHT BY 0.666 TOP BY 0.666 LEFT BY 0.888
EXTENT_AA_b_2   = SHRINK (SIZE EXTENT_AA_b_1 BY 0.666) RIGHT BY 0.666 TOP BY 0.666 LEFT BY 0.888


DUMAA_OFF_b_0 =  RECTANGLES 0.444 0.444 0.222 1.776 OFFSET 0 0.222 INSIDE OF LAYER EXTENT_AA_0
DUMAA_OFF_b_1 = (RECTANGLES 0.444 0.444 0.222 1.776 OFFSET 0 0.222 INSIDE OF LAYER EXTENT_AA_b_1) INSIDE EXTENT_AA_0
DUMAA_OFF_b_2 = (RECTANGLES 0.444 0.444 0.222 1.776 OFFSET 0 0.222 INSIDE OF LAYER EXTENT_AA_b_2) INSIDE EXTENT_AA_0

DUMAA_OFF_b_all = DUMAA_OFF_b_0 OR (DUMAA_OFF_b_1 OR DUMAA_OFF_b_2)

//AADUM_b rectangles
DUMAA_CONSTRAIN_b_all = (SIZE DUMAA_a_all BY 2.222 OVERUNDER) OR ((SIZE DUMAA_a_all BY 0.221) OR DUMAA_CONSTRAIN_b)
DUMAA_b_all = DUMAA_OFF_b_all NOT INTERACT DUMAA_CONSTRAIN_b_all



//Output results of AADUM insertion

#IFDEF AA_insert YES
DUMAA_a_all_out { COPY DUMAA_a_all }
DRC CHECK MAP DUMAA_a_all_out GDSII 10 1 AUTOREF

DUMAA_b_all_out { COPY DUMAA_b_all }
DRC CHECK MAP DUMAA_b_all_out GDSII 10 1 AUTOREF
#ENDIF



 
//=====================
//GT Dummy insertion 
//=====================

//GTDUM rectangles constrains AND output results

GTD = (AAD_GTD OR DIFRES) OR ((AA OR DUMBP) OR RESAA)
GTD_a = SIZE ((GTD OR GT) OR DUMAA_b_all) BY 2.665
GTD_b = (SIZE (GTD OR DUMAA_a_all) BY 0.221) OR (SIZE GT BY 0.710) 
NW_DNW_ENC_GT = SIZE (NW OR DNW) BY -0.710 
NW_DNW_SPA_GT = SIZE (NW OR DNW) BY 0.710
NW_DNW_ENC_SPA_GT = NW_DNW_SPA_GT NOT NW_DNW_ENC_GT
DUMGT_CONSTRAIN_0 = NW_DNW_ENC_SPA_GT OR (GTFUSE_EXPAND NOT GTFUSE)
DUMGT_CONSTRAIN_a = GTD_a OR DUMGT_CONSTRAIN_0
DUMGT_CONSTRAIN_b = GTD_b OR DUMGT_CONSTRAIN_0

EXTENT_GT_0   = SIZE BORDER BY -0.177

#IFDEF GT_insert YES
DUMGT_a_all = (SIZE DUMAA_OFF_a_all BY -0.444) NOT INTERACT DUMGT_CONSTRAIN_a
DUMGT_a_all_out { COPY DUMGT_a_all }
DRC CHECK MAP DUMGT_a_all_out GDSII 30 1 AUTOREF

DUMGT_CONSTRAIN_b_all = ((SIZE DUMGT_a_all BY 3.11 OVERUNDER) OR (SIZE DUMGT_a_all BY 0.709)) OR DUMGT_CONSTRAIN_b
DUMGT_b_all = ((SIZE DUMAA_OFF_b_all BY -0.044) NOT INTERACT DUMGT_CONSTRAIN_b_all) INSIDE EXTENT_GT_0
DUMGT_b_all_out { COPY DUMGT_b_all }
DRC CHECK MAP DUMGT_b_all_out GDSII 30 1 AUTOREF
#ENDIF





//=================================================
//Mx Dummy insertion when Mx Dummy NOT touching INDMY
//=================================================


EXTENT_MT_0   = SIZE BORDER BY -0.4
EXTENT_MT_1   = SHRINK (SIZE EXTENT_MT_0 BY 0.666) RIGHT BY 0.666 TOP BY 0.666 LEFT BY 0.888
EXTENT_MT_2   = SHRINK (SIZE EXTENT_MT_1 BY 0.666) RIGHT BY 0.666 TOP BY 0.666 LEFT BY 0.888


MD_BK         = ((LOGO OR PTCT) OR DUMBM) OR MARKG
INDMY_UP       = SIZE INDMY BY 0.6

M1D_BK_0      = SIZE (M1DUB OR MD_BK) BY 0.6
M1D_BK_A      = (SIZE M1 BY 1.111) OR (M1D_BK_0 OR GTFUSE_EXPAND)
M1D_BK_C      = (SIZE M1 BY 0.533) OR (M1D_BK_0 OR GTFUSE_EXPAND)

M2D_BK_0      = SIZE (M2DUB OR MD_BK) BY 0.6
M2D_BK_A      = (SIZE M2 BY 1.111) OR (M2D_BK_0 OR GTFUSE_EXPAND)
M2D_BK_C      = (SIZE M2 BY 0.533) OR (M2D_BK_0 OR GTFUSE_EXPAND)

M3D_BK_0      = SIZE (M3DUB OR MD_BK) BY 0.6
M3D_BK_A      = (SIZE M3 BY 1.111) OR M3D_BK_0
M3D_BK_C      = (SIZE M3 BY 0.533) OR M3D_BK_0

M4D_BK_0      = SIZE (M4DUB OR MD_BK) BY 0.6
M4D_BK_A      = (SIZE M4 BY 1.111) OR M4D_BK_0
M4D_BK_C      = (SIZE M4 BY 0.533) OR M4D_BK_0

M5D_BK_0      = SIZE (M5DUB OR MD_BK) BY 0.6
M5D_BK_A      = (SIZE M5 BY 1.111) OR M5D_BK_0
M5D_BK_C      = (SIZE M5 BY 0.533) OR M5D_BK_0

