DUMMB_OFF_2 = ((RECTANGLES 0.222 0.222 0.222 1.665 OFFSET 0 0.111 INSIDE OF LAYER EXTENT_MT_B_2) INSIDE EXTENT_MT_0) NOT INTERACT INDMY_UP
DUMMB_OFF_3 = ((RECTANGLES 0.222 0.222 0.222 1.665 OFFSET 0 0.111 INSIDE OF LAYER EXTENT_MT_B_3) INSIDE EXTENT_MT_0) NOT INTERACT INDMY_UP

//MxDUM_B rectangles constrains when Mx Dummy B NOT touching INDMY
M1D_BK_B = ((SIZE M1 BY 0.6) OR (SIZE DUMM1A_ALL BY 0.222)) OR (M1D_BK_0 OR GTFUSE_EXPAND)
