EXTENT_MT_INDMY_1   = SHRINK (SIZE EXTENT_MT_0 BY 0.889) RIGHT BY 0.889 TOP BY 0.889 LEFT BY 1.333


//MxDUM rectangles produce regulation when Mx Dummy touching INDMY
//Notice:Some dummy patterns will ignore 1 grid X-Shift in order to guarantee the speed of filling dummy patterns
INDMY_DOWN_M = SIZE INDMY BY -0.6
DUMM_OFF_INDMY_0 =  (RECTANGLES 0.3 0.3 0.589 1.922 OFFSET 0 0.444 INSIDE OF LAYER EXTENT_MT_0) INSIDE INDMY_DOWN_M
DUMM_OFF_INDMY_1 = ((RECTANGLES 0.3 0.3 0.589 1.922 OFFSET 0 0.444 INSIDE OF LAYER EXTENT_MT_INDMY_1) INSIDE EXTENT_MT_0) INSIDE INDMY_DOWN_M


//M1DUM rectangles when M1 Dummy touching INDMY
DUMM1_INDMY_0 = DUMM_OFF_INDMY_0 NOT INTERACT M1D_BK_C
DUMM1_INDMY_1 = DUMM_OFF_INDMY_1 NOT INTERACT M1D_BK_C
DUMM1_INDMY_ALL = (DUMM1_INDMY_0 OR DUMM1_INDMY_1) INSIDE DUM_INSERT_AREA_M1
DUMM1_INDMY_ALL_datetype_1 = DUMM1_INDMY_ALL NOT INTERACT M1_UP
DUMM1_INDMY_ALL_datetype_7 = DUMM1_INDMY_ALL NOT DUMM1_INDMY_ALL_datetype_1 

//M2DUM rectangles when M2 Dummy touching INDMY
DUMM2_INDMY_0 = DUMM_OFF_INDMY_0 NOT INTERACT M2D_BK_C
DUMM2_INDMY_1 = DUMM_OFF_INDMY_1 NOT INTERACT M2D_BK_C
DUMM2_INDMY_ALL = (DUMM2_INDMY_0 OR DUMM2_INDMY_1) INSIDE DUM_INSERT_AREA_M2
DUMM2_INDMY_ALL_datetype_1 = DUMM2_INDMY_ALL NOT INTERACT M2_UP
DUMM2_INDMY_ALL_datetype_7 = DUMM2_INDMY_ALL NOT DUMM2_INDMY_ALL_datetype_1

//M3DUM rectangles when M3 Dummy touching INDMY
DUMM3_INDMY_0 = DUMM_OFF_INDMY_0 NOT INTERACT M3D_BK_C
DUMM3_INDMY_1 = DUMM_OFF_INDMY_1 NOT INTERACT M3D_BK_C
DUMM3_INDMY_ALL = (DUMM3_INDMY_0 OR DUMM3_INDMY_1) INSIDE DUM_INSERT_AREA_M3
DUMM3_INDMY_ALL_datetype_1 = DUMM3_INDMY_ALL NOT INTERACT M3_UP
DUMM3_INDMY_ALL_datetype_7 = DUMM3_INDMY_ALL NOT DUMM3_INDMY_ALL_datetype_1

//M4DUM rectangles when M4 Dummy touching INDMY
DUMM4_INDMY_0 = DUMM_OFF_INDMY_0 NOT INTERACT M4D_BK_C
DUMM4_INDMY_1 = DUMM_OFF_INDMY_1 NOT INTERACT M4D_BK_C
DUMM4_INDMY_ALL = (DUMM4_INDMY_0 OR DUMM4_INDMY_1) INSIDE DUM_INSERT_AREA_M4
DUMM4_INDMY_ALL_datetype_1 = DUMM4_INDMY_ALL NOT INTERACT M4_UP
DUMM4_INDMY_ALL_datetype_7 = DUMM4_INDMY_ALL NOT DUMM4_INDMY_ALL_datetype_1

//M5DUM rectangles when M5 Dummy touching INDMY
DUMM5_INDMY_0 = DUMM_OFF_INDMY_0 NOT INTERACT M5D_BK_C
DUMM5_INDMY_1 = DUMM_OFF_INDMY_1 NOT INTERACT M5D_BK_C
DUMM5_INDMY_ALL = (DUMM5_INDMY_0 OR DUMM5_INDMY_1) INSIDE DUM_INSERT_AREA_M5
DUMM5_INDMY_ALL_datetype_1 = DUMM5_INDMY_ALL NOT INTERACT M5_UP
DUMM5_INDMY_ALL_datetype_7 = DUMM5_INDMY_ALL NOT DUMM5_INDMY_ALL_datetype_1

//M6DUM rectangles when M6 Dummy touching INDMY
DUMM6_INDMY_0 = DUMM_OFF_INDMY_0 NOT INTERACT M6D_BK_C
DUMM6_INDMY_1 = DUMM_OFF_INDMY_1 NOT INTERACT M6D_BK_C
DUMM6_INDMY_ALL = (DUMM6_INDMY_0 OR DUMM6_INDMY_1) INSIDE DUM_INSERT_AREA_M6
DUMM6_INDMY_ALL_datetype_1 = DUMM6_INDMY_ALL NOT INTERACT M6_UP
DUMM6_INDMY_ALL_datetype_7 = DUMM6_INDMY_ALL NOT DUMM6_INDMY_ALL_datetype_1

//M7DUM rectangles when M7 Dummy touching INDMY
DUMM7_INDMY_0 = DUMM_OFF_INDMY_0 NOT INTERACT M7D_BK_C
DUMM7_INDMY_1 = DUMM_OFF_INDMY_1 NOT INTERACT M7D_BK_C
DUMM7_INDMY_ALL = (DUMM7_INDMY_0 OR DUMM7_INDMY_1) INSIDE DUM_INSERT_AREA_M7
DUMM7_INDMY_ALL_datetype_1 = DUMM7_INDMY_ALL NOT INTERACT M7_UP
DUMM7_INDMY_ALL_datetype_7 = DUMM7_INDMY_ALL NOT DUMM7_INDMY_ALL_datetype_1

//M8DUM rectangles when M8 Dummy touching INDMY 
DUMM8_INDMY_0 = DUMM_OFF_INDMY_0 NOT INTERACT M8D_BK_C
DUMM8_INDMY_1 = DUMM_OFF_INDMY_1 NOT INTERACT M8D_BK_C
DUMM8_INDMY_ALL = (DUMM8_INDMY_0 OR DUMM8_INDMY_1) INSIDE DUM_INSERT_AREA_M8
DUMM8_INDMY_ALL_datetype_1 = DUMM8_INDMY_ALL NOT INTERACT M8_UP
DUMM8_INDMY_ALL_datetype_7 = DUMM8_INDMY_ALL NOT DUMM8_INDMY_ALL_datetype_1


//Output results of MxDUM insertion when Mx Dummy touching INDMY

#IFDEF M1_insert YES
DUMM1_INDMY_ALL_OUT_datetype_1 { COPY DUMM1_INDMY_ALL_datetype_1 }
DRC CHECK MAP DUMM1_INDMY_ALL_OUT_datetype_1 GDSII 61 1 AUTOREF
DUMM1_INDMY_ALL_OUT_datetype_7 { COPY DUMM1_INDMY_ALL_datetype_7 }
DRC CHECK MAP DUMM1_INDMY_ALL_OUT_datetype_7 GDSII 61 7 AUTOREF
#ENDIF

#IFDEF M2_insert YES
DUMM2_INDMY_ALL_OUT_datetype_1 { COPY DUMM2_INDMY_ALL_datetype_1 }
DRC CHECK MAP DUMM2_INDMY_ALL_OUT_datetype_1 GDSII 62 1 AUTOREF
DUMM2_INDMY_ALL_OUT_datetype_7 { COPY DUMM2_INDMY_ALL_datetype_7 }
DRC CHECK MAP DUMM2_INDMY_ALL_OUT_datetype_7 GDSII 62 7 AUTOREF
#ENDIF

#IFDEF M3_insert YES
DUMM3_INDMY_ALL_OUT_datetype_1 { COPY DUMM3_INDMY_ALL_datetype_1 }
DRC CHECK MAP DUMM3_INDMY_ALL_OUT_datetype_1 GDSII 63 1 AUTOREF
DUMM3_INDMY_ALL_OUT_datetype_7 { COPY DUMM3_INDMY_ALL_datetype_7 }
DRC CHECK MAP DUMM3_INDMY_ALL_OUT_datetype_7 GDSII 63 7 AUTOREF
#ENDIF

#IFDEF M4_insert YES
DUMM4_INDMY_ALL_OUT_datetype_1 { COPY DUMM4_INDMY_ALL_datetype_1 }
DRC CHECK MAP DUMM4_INDMY_ALL_OUT_datetype_1 GDSII 64 1 AUTOREF
DUMM4_INDMY_ALL_OUT_datetype_7 { COPY DUMM4_INDMY_ALL_datetype_7 }
DRC CHECK MAP DUMM4_INDMY_ALL_OUT_datetype_7 GDSII 64 7 AUTOREF
#ENDIF

#IFDEF M5_insert YES
DUMM5_INDMY_ALL_OUT_datetype_1 { COPY DUMM5_INDMY_ALL_datetype_1 }
DRC CHECK MAP DUMM5_INDMY_ALL_OUT_datetype_1 GDSII 65 1 AUTOREF
DUMM5_INDMY_ALL_OUT_datetype_7 { COPY DUMM5_INDMY_ALL_datetype_7 }
DRC CHECK MAP DUMM5_INDMY_ALL_OUT_datetype_7 GDSII 65 7 AUTOREF
#ENDIF

#IFDEF M6_insert YES
DUMM6_INDMY_ALL_OUT_datetype_1 { COPY DUMM6_INDMY_ALL_datetype_1 }
DRC CHECK MAP DUMM6_INDMY_ALL_OUT_datetype_1 GDSII 66 1 AUTOREF
DUMM6_INDMY_ALL_OUT_datetype_7 { COPY DUMM6_INDMY_ALL_datetype_7 }
DRC CHECK MAP DUMM6_INDMY_ALL_OUT_datetype_7 GDSII 66 7 AUTOREF
#ENDIF

#IFDEF M7_insert YES
DUMM7_INDMY_ALL_OUT_datetype_1 { COPY DUMM7_INDMY_ALL_datetype_1 }
DRC CHECK MAP DUMM7_INDMY_ALL_OUT_datetype_1 GDSII 67 1 AUTOREF
DUMM7_INDMY_ALL_OUT_datetype_7 { COPY DUMM7_INDMY_ALL_datetype_7 }
DRC CHECK MAP DUMM7_INDMY_ALL_OUT_datetype_7 GDSII 67 7 AUTOREF
#ENDIF

#IFDEF M8_insert YES
DUMM8_INDMY_ALL_OUT_datetype_1 { COPY DUMM8_INDMY_ALL_datetype_1 }
DRC CHECK MAP DUMM8_INDMY_ALL_OUT_datetype_1 GDSII 68 1 AUTOREF
DUMM8_INDMY_ALL_OUT_datetype_7 { COPY DUMM8_INDMY_ALL_datetype_7 }
DRC CHECK MAP DUMM8_INDMY_ALL_OUT_datetype_7 GDSII 68 7 AUTOREF
#ENDIF




//=================================================
//TM Dummy insertion when TM Dummy NOT touching INDMY
//=================================================


EXTENT_TM_1   = SHRINK (SIZE EXTENT_MT_0 BY 5.333) RIGHT BY 5.333 TOP BY 5.333 LEFT BY 7.111
EXTENT_TM_2   = SHRINK (SIZE EXTENT_TM_1 BY 5.333) RIGHT BY 5.333 TOP BY 5.333 LEFT BY 7.111

//TMxDUM rectangles constrains
INDMY_TM_UP = SIZE INDMY BY 0.6
INDMY_MTT2_UP = SIZE INDMY BY 1.778
TM1D_BK    = (SIZE (TM1DUB OR MD_BK) BY 1.778) OR (SIZE TM1 BY 0.6)
TM2D_BK    = (SIZE (TM2DUB OR MD_BK) BY 1.778) OR (SIZE TM2 BY 0.6)
MTT2D_BK    = SIZE ((MTT2DB OR MTT2) OR MD_BK) BY 1.778

//TMxDUM rectangles produce regulation when TMx Dummy NOT touching INDMY
//Notice:Some dummy patterns will ignore 1 grid X-Shift in order to guarantee the speed of filling dummy patterns
DUMTM_OFF_0 =  RECTANGLES 3.555 3.555 1.778 14.222 OFFSET 0 1.778 INSIDE OF LAYER EXTENT_MT_0
DUMTM_OFF_1 = (RECTANGLES 3.555 3.555 1.778 14.222 OFFSET 0 1.778 INSIDE OF LAYER EXTENT_TM_1) INSIDE EXTENT_MT_0
DUMTM_OFF_2 = (RECTANGLES 3.555 3.555 1.778 14.222 OFFSET 0 1.778 INSIDE OF LAYER EXTENT_TM_2) INSIDE EXTENT_MT_0



//TM1DUM rectangles when TM1 Dummy NOT touching INDMY
DUMTM1_0 = DUMTM_OFF_0 NOT INTERACT TM1D_BK
DUMTM1_1 = DUMTM_OFF_1 NOT INTERACT TM1D_BK
DUMTM1_2 = DUMTM_OFF_2 NOT INTERACT TM1D_BK
DUMTM1_ALL = (((DUMTM1_0 OR DUMTM1_1) OR DUMTM1_2) NOT INTERACT INDMY_TM_UP) INSIDE DUM_INSERT_AREA_TM1

//TM2DUM rectangles when TM2 Dummy NOT touching INDMY
DUMTM2_0 = DUMTM_OFF_0 NOT INTERACT TM2D_BK
DUMTM2_1 = DUMTM_OFF_1 NOT INTERACT TM2D_BK
DUMTM2_2 = DUMTM_OFF_2 NOT INTERACT TM2D_BK
DUMTM2_ALL = (((DUMTM2_0 OR DUMTM2_1) OR DUMTM2_2) NOT INTERACT INDMY_TM_UP) INSIDE DUM_INSERT_AREA_TM2

//MTT2DM rectangles when MTT2 Dummy NOT touching INDMY
DUMMTT2_0 = DUMTM_OFF_0 NOT INTERACT MTT2D_BK
DUMMTT2_1 = DUMTM_OFF_1 NOT INTERACT MTT2D_BK
DUMMTT2_2 = DUMTM_OFF_2 NOT INTERACT MTT2D_BK
DUMMTT2_ALL = (((DUMMTT2_0 OR DUMMTT2_1) OR DUMMTT2_2) NOT INTERACT INDMY_MTT2_UP) INSIDE DUM_INSERT_AREA_MTT2


//Output results of TMxDUM insertion when TMx Dummy NOT touching INDMY

#IFDEF TM1_insert YES
DUMTM1_ALL_OUT { COPY DUMTM1_ALL }
DRC CHECK MAP DUMTM1_ALL_OUT GDSII 120 1 AUTOREF
#ENDIF

#IFDEF TM2_insert YES
DUMTM2_ALL_OUT { COPY DUMTM2_ALL }
DRC CHECK MAP DUMTM2_ALL_OUT GDSII 122 1 AUTOREF
#ENDIF

#IFDEF MTT2_insert YES
DUMMTT2_ALL_OUT { COPY DUMMTT2_ALL }
DRC CHECK MAP DUMMTT2_ALL_OUT GDSII 231 1 AUTOREF
#ENDIF


//=================================================
//TM Dummy insertion when TM Dummy touching INDMY
//=================================================


EXTENT_TM_INDMY_1   = SHRINK (SIZE EXTENT_MT_0 BY 7.111) RIGHT BY 7.111 TOP BY 7.111 LEFT BY 10.667

//TMxDUM rectangles produce regulation when TMx Dummy touching INDMY
//Notice:Some dummy patterns will ignore 1 grid X-Shift in order to guarantee the speed of filling dummy patterns
INDMY_DOWN_TM = SIZE INDMY BY -1.778
DUMTM_OFF_INDMY_0 =  (RECTANGLES 2.4 2.4 4.711 15.378 OFFSET 0 3.556 INSIDE OF LAYER EXTENT_MT_0) INSIDE INDMY_DOWN_TM
DUMTM_OFF_INDMY_1 = ((RECTANGLES 2.4 2.4 4.711 15.378 OFFSET 0 3.556 INSIDE OF LAYER EXTENT_TM_INDMY_1) INSIDE EXTENT_MT_0) INSIDE INDMY_DOWN_TM


//TM1DUM rectangles when TM1 Dummy touching INDMY
DUMTM1_INDMY_0 = DUMTM_OFF_INDMY_0 NOT INTERACT TM1D_BK
DUMTM1_INDMY_1 = DUMTM_OFF_INDMY_1 NOT INTERACT TM1D_BK
DUMTM1_INDMY_ALL = (DUMTM1_INDMY_0 OR DUMTM1_INDMY_1) INSIDE DUM_INSERT_AREA_TM1

//TM2DUM rectangles when TM2 Dummy touching INDMY
DUMTM2_INDMY_0 = DUMTM_OFF_INDMY_0 NOT INTERACT TM2D_BK
DUMTM2_INDMY_1 = DUMTM_OFF_INDMY_1 NOT INTERACT TM2D_BK
DUMTM2_INDMY_ALL = (DUMTM2_INDMY_0 OR DUMTM2_INDMY_1) INSIDE DUM_INSERT_AREA_TM2

//MTT2DM rectangles when MTT2DM Dummy touching INDMY
DUMMTT2_INDMY_0 = DUMTM_OFF_INDMY_0 NOT INTERACT MTT2D_BK
DUMMTT2_INDMY_1 = DUMTM_OFF_INDMY_1 NOT INTERACT MTT2D_BK
DUMMTT2_INDMY_ALL = (DUMMTT2_INDMY_0 OR DUMMTT2_INDMY_1) INSIDE DUM_INSERT_AREA_MTT2


//Output results of TMxDUM insertion when TMx Dummy touching INDMY

#IFDEF TM1_insert YES
DUMTM1_INDMY_ALL_OUT { COPY DUMTM1_INDMY_ALL }
DRC CHECK MAP DUMTM1_INDMY_ALL_OUT GDSII 120 1 AUTOREF
#ENDIF

#IFDEF TM2_insert YES
DUMTM2_INDMY_ALL_OUT { COPY DUMTM2_INDMY_ALL }
DRC CHECK MAP DUMTM2_INDMY_ALL_OUT GDSII 122 1 AUTOREF
#ENDIF

#IFDEF MTT2_insert YES
DUMMTT2_INDMY_ALL_OUT { COPY DUMMTT2_INDMY_ALL }
DRC CHECK MAP DUMMTT2_INDMY_ALL_OUT GDSII 231 1 AUTOREF
#ENDIF


//=====================
//ALPA Dummy insertion 
//=====================


EXTENT_ALPA_1   = SHRINK (SIZE EXTENT_MT_0 BY 10.665) RIGHT BY 10.665 TOP BY 10.665 LEFT BY 14.221
EXTENT_ALPA_2   = SHRINK (SIZE EXTENT_ALPA_1 BY 10.665) RIGHT BY 10.665 TOP BY 10.665 LEFT BY 14.221

//ALDUM rectangles constrains
ALD_BK   = SIZE (((ALDUB OR ALPA) OR INDMY) OR MD_BK) BY 2.844

//ALDUM rectangles produce regulation
//Notice:Some dummy patterns will ignore 3 grid X-Shift in order to guarantee the speed of filling dummy patterns
DUMAL_OFF_0 =  RECTANGLES 7.110 7.110 3.555 28.441 OFFSET 0 3.556 INSIDE OF LAYER EXTENT_MT_0
DUMAL_OFF_1 = (RECTANGLES 7.110 7.110 3.555 28.441 OFFSET 0 3.556 INSIDE OF LAYER EXTENT_ALPA_1) INSIDE EXTENT_MT_0
DUMAL_OFF_2 = (RECTANGLES 7.110 7.110 3.555 28.441 OFFSET 0 3.556 INSIDE OF LAYER EXTENT_ALPA_2) INSIDE EXTENT_MT_0

//ALDUM rectangles
DUMAL_0 = DUMAL_OFF_0 NOT INTERACT ALD_BK
DUMAL_1 = DUMAL_OFF_1 NOT INTERACT ALD_BK
DUMAL_2 = DUMAL_OFF_2 NOT INTERACT ALD_BK
DUMAL_ALL = ((DUMAL_0 OR DUMAL_1) OR DUMAL_2) INSIDE DUM_INSERT_AREA_ALPA



//Output results of ALDUM insertion

#IFDEF ALPA_insert YES
DUMAL_ALL_OUT { COPY DUMAL_ALL }
DRC CHECK MAP DUMAL_ALL_OUT GDSII 83 11 AUTOREF
#ENDIF


//=====================
//Via Dummy insertion 
//=====================

}

set timestamp [clock format [clock seconds] -gmt false -format "%Y%m%d%H%M%S"]


foreach via_inner_j { 1 2 3 4 5 6 7 } {
  if { $via_inner_j == 1 } {
VERBATIM {
#IFDEF M1_insert YES
#IFDEF M2_insert YES
#IFDEF V1_insert YES
}
  }
  if { $via_inner_j == 2 } {
VERBATIM {
#IFDEF M2_insert YES
#IFDEF M3_insert YES
#IFDEF V2_insert YES
}
  }
  if { $via_inner_j == 3 } {
VERBATIM {
#IFDEF M3_insert YES
#IFDEF M4_insert YES
#IFDEF V3_insert YES
}
  }
  if { $via_inner_j == 4 } {
VERBATIM {
#IFDEF M4_insert YES
#IFDEF M5_insert YES
#IFDEF V4_insert YES
}
  }
  if { $via_inner_j == 5 } {
VERBATIM {
#IFDEF M5_insert YES
#IFDEF M6_insert YES
#IFDEF V5_insert YES
}
  }
  if { $via_inner_j == 6 } {
VERBATIM {
#IFDEF M6_insert YES
#IFDEF M7_insert YES
#IFDEF V6_insert YES
}
  }
  if { $via_inner_j == 7 } {
VERBATIM {
#IFDEF M7_insert YES
#IFDEF M8_insert YES
#IFDEF V7_insert YES
}
  }

SETLAYER DUMV${via_inner_j}A_ALL = (SIZE (DUMM${via_inner_j}A_ALL AND DUMM[expr $via_inner_j +1]A_ALL) BY -0.072) NOT INTERACT V${via_inner_j}D_BK
RULECHECK DUMV${via_inner_j}A_OUT { FLATTEN DUMV${via_inner_j}A_ALL }

DRC CHECK MAP DUMV${via_inner_j}A_OUT GDSII [expr $via_inner_j +69] 1 AREF DUMV${via_inner_j}A_OUT_CELL_$timestamp 0.3 0.3 1 \
 SUBSTITUTE 0     0       0.077  0       0.077  0.077    0     0.077    0     0 \
 SUBSTITUTE 0.221 0       0.298  0       0.298  0.077    0.221 0.077    0.221 0 \
 SUBSTITUTE 0     0.221   0.077  0.221   0.077  0.298    0     0.298    0     0.221 \
 SUBSTITUTE 0.221 0.221   0.298  0.221   0.298  0.298    0.221 0.298    0.221 0.221


VERBATIM {
#ENDIF
#ENDIF
#ENDIF
}

}
