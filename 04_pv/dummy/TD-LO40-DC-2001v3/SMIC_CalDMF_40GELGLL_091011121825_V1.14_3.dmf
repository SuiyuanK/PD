#! tvf
namespace import tvf::*
VERBATIM {
//Note 1 : This script will select to fill dummy patterns for AA, GT, M1~M8, V1~V7, TM1, TM2, MTT2, ALPA layers according to user's setting .
//Note 2 : Please select the filled dummy layers base on your layout.Set it to "YES", will fill the dummy pattern, otherwise set to "NO".
//Note 3 : This script will insert two types metal dummy (MnDUM and MnDOP) for Mn, n = 1~8.
//Note 4 : Please only set one switch to "Yes" between "TM2_insert" AND "MTT2_insert",while you must keep the other one to "NO".
//Note 5 : Vn dummy patterns can be inserted only when the switches "Mn_insert", "Mn+1_insert" and "Vn_inserted" are set to "YES", n = 1~7.
//Note 6 :"BORDER" layer must be drawn as "chip edge" in your layout in order to insert dummy patterns in it.   
//Note 7 : This runset must be run with hierarchy mode.

//*************************************
//    Swiches selection
//*************************************

#DEFINE AA_insert YES
#DEFINE GT_insert YES

#DEFINE M1_insert YES
#DEFINE V1_insert YES
#DEFINE M2_insert YES
#DEFINE V2_insert YES
#DEFINE M3_insert YES
#DEFINE V3_insert YES
#DEFINE M4_insert YES
#DEFINE V4_insert YES
#DEFINE M5_insert YES

#DEFINE V5_insert YES
#DEFINE M6_insert YES
#DEFINE V6_insert YES
#DEFINE M7_insert YES
#DEFINE V7_insert YES
#DEFINE M8_insert YES
#DEFINE TM1_insert YES

#DEFINE TM2_insert YES
#DEFINE MTT2_insert NO

#DEFINE ALPA_insert YES
 




//=================================================================================
