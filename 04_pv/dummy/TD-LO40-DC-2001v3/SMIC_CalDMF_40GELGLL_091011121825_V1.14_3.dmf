//MxDUM_B rectangles produce regulation when Mx Dummy B NOT touching INDMY

EXTENT_MT_B_1   = SHRINK (SIZE EXTENT_MT_0 BY 0.444) RIGHT BY 0.444 TOP BY 0.444 LEFT BY 0.555
EXTENT_MT_B_2   = SHRINK (SIZE EXTENT_MT_B_1 BY 0.444) RIGHT BY 0.444 TOP BY 0.444 LEFT BY 0.555
EXTENT_MT_B_3   = SHRINK (SIZE EXTENT_MT_B_2 BY 0.444) RIGHT BY 0.444 TOP BY 0.444 LEFT BY 0.555

DUMMB_OFF_0 =  (RECTANGLES 0.222 0.222 0.222 1.665 OFFSET 0 0.111 INSIDE OF LAYER EXTENT_MT_0) NOT INTERACT INDMY_UP
