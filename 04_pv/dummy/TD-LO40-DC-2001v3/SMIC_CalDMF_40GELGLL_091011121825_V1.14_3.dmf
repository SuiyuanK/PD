M7D_BK_A      = (SIZE M7 BY 1.111) OR M7D_BK_0
M7D_BK_C      = (SIZE M7 BY 0.533) OR M7D_BK_0

M8D_BK_0      = SIZE (M8DUB OR MD_BK) BY 0.6
M8D_BK_A      = (SIZE M8 BY 1.111) OR M8D_BK_0
M8D_BK_C      = (SIZE M8 BY 0.533) OR M8D_BK_0



//MxDUM_A rectangles produce regulation when Mx Dummy A NOT touching INDMY
DUMMA_OFF_0 =  (RECTANGLES 0.444 0.444 0.222 1.776 OFFSET 0 0.222 INSIDE OF LAYER EXTENT_MT_0) NOT INTERACT INDMY_UP
DUMMA_OFF_1 = ((RECTANGLES 0.444 0.444 0.222 1.776 OFFSET 0 0.222 INSIDE OF LAYER EXTENT_MT_1) INSIDE EXTENT_MT_0) NOT INTERACT INDMY_UP
DUMMA_OFF_2 = ((RECTANGLES 0.444 0.444 0.222 1.776 OFFSET 0 0.222 INSIDE OF LAYER EXTENT_MT_2) INSIDE EXTENT_MT_0) NOT INTERACT INDMY_UP



//M1DUM_A rectangles when M1 Dummy A NOT touching INDMY

DUMM1A_0 = DUMMA_OFF_0 NOT INTERACT M1D_BK_A
DUMM1A_1 = DUMMA_OFF_1 NOT INTERACT M1D_BK_A
DUMM1A_2 = DUMMA_OFF_2 NOT INTERACT M1D_BK_A
DUMM1A_ALL = ((DUMM1A_0 OR DUMM1A_1) OR DUMM1A_2) INSIDE DUM_INSERT_AREA_M1
DUMM1A_ALL_datetype_1 = DUMM1A_ALL NOT INTERACT M1_UP
DUMM1A_ALL_datetype_7 = DUMM1A_ALL NOT DUMM1A_ALL_datetype_1

//M2DUM_A rectangles when M2 Dummy A NOT touching INDMY

