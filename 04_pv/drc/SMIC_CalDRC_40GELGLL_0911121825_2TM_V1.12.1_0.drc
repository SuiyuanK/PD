    Z0 = OR PA INDMY LOGO MARKS
  X0 = TM2i_all NOT Z0
  Y0 = DRC:1 NOT Z0
  Y1 = Y0 WITH WIDTH >= 200
  X1 = X0 AND Y1
  OUT1 = DENSITY X1 Y1 < 0.15 [ AREA(X1)/AREA(Y1) ] WINDOW 200 STEP 100 BACKUP INSIDE OF LAYER DRC:1 PRINT density_report_IND_R_9_G_l_TM2_1.log RDB density_report_IND_R_9_G_l_TM2_1.rdb
  SIZE (OUT1 AND Y1) BY 25 UNDEROVER

 Y2 = (Y0 NOT Y1) WITH WIDTH >= 50 < 200
 Y3 = COPY Y2
 X2 = X0 AND Y2
 DENSITY X2 Y2 [!AREA(Y2) + !!AREA(Y2)*(AREA(X2)/(max(AREA(Y2),0.00001))) ] < 0.15 INSIDE OF LAYER Y3 BY POLYGON PRINT density_report_IND_R_9_G_l_TM2_2.log RDB density_report_IND_R_9_G_l_TM2_2.rdb
}
IND_R_9_G_h_TM2_density {
@ TM2 density range in window 200um x 200um, stepping 100um. is <=85% 
@ The following special regions are excluded while the density checking: PA,MARKS, LOGO,INDMY 
@ This rule is only applied while the width of (checking window NOT excluded region) >=50um.
  Z0 = OR PA INDMY LOGO MARKS
  X0 = TM2i_all NOT Z0
  Y0 = DRC:1 NOT Z0
  Y1 = Y0 WITH WIDTH >= 200
  X1 = X0 AND Y1
  OUT1 = DENSITY X1 Y1 > 0.85 [ AREA(X1)/AREA(Y1) ] WINDOW 200 STEP 100 BACKUP INSIDE OF LAYER DRC:1 PRINT density_report_IND_R_9_G_h_TM2_1.log RDB density_report_IND_R_9_G_h_TM2_1.rdb
  SIZE (OUT1 AND Y1) BY 25 UNDEROVER

 Y2 = (Y0 NOT Y1) WITH WIDTH >= 50 < 200
 Y3 = COPY Y2
 X2 = X0 AND Y2
 DENSITY X2 Y2 [!AREA(Y2) + !!AREA(Y2)*(AREA(X2)/(max(AREA(Y2),0.00001))) ] > 0.85 INSIDE OF LAYER Y3 BY POLYGON PRINT density_report_IND_R_9_G_h_TM2_2.log RDB density_report_IND_R_9_G_h_TM2_2.rdb
}
#ENDIF

#IFDEF UTM YES
IND_R_8_G_MTT2_density {
@ MTT2 metal density over the whole chip (include INDDMY) is >= 20%.
  DENSITY_MARK = BORDER NOT MARKS
  CHECK_LAYER = MTT2i_all NOT MARKS
  CHECK_REGION = COPY DENSITY_MARK
  X =DENSITY CHECK_LAYER CHECK_REGION [area(CHECK_LAYER)/area(CHECK_REGION)] < 0.2 PRINT density_report_IND_R_8_G_MTT2.log RDB density_report_IND_R_8_G_MTT2.db
  X NOT MARKS
}
IND_R_9_G_l_MTT2_density {
@ MTT2 density range in window 200um x 200um, stepping 100um. is >=15% 
@ The following special regions are excluded while the density checking: PA,MARKS, LOGO,INDMY 
@ This rule is only applied while the width of (checking window NOT excluded region) >=50um.
   Z0 = OR PA INDMY LOGO MARKS
  X0 = MTT2i_all NOT Z0
  Y0 = DRC:1 NOT Z0
  Y1 = Y0 WITH WIDTH >= 200
  X1 = X0 AND Y1
  OUT1 = DENSITY X1 Y1 < 0.15 [ AREA(X1)/AREA(Y1) ] WINDOW 200 STEP 100 BACKUP INSIDE OF LAYER DRC:1 PRINT density_report_IND_R_9_G_l_MTT2_1.log RDB density_report_IND_R_9_G_l_MTT2_1.rdb
  SIZE (OUT1 AND Y1) BY 25 UNDEROVER

 Y2 = (Y0 NOT Y1) WITH WIDTH >= 50 < 200
 Y3 = COPY Y2
 X2 = X0 AND Y2
 DENSITY X2 Y2 [!AREA(Y2) + !!AREA(Y2)*(AREA(X2)/(max(AREA(Y2),0.00001))) ] < 0.15 INSIDE OF LAYER Y3 BY POLYGON PRINT density_report_IND_R_9_G_l_MTT2_2.log RDB density_report_IND_R_9_G_l_MTT2_2.rdb 

}
IND_R_9_G_h_MTT2_density {
@ MTT2 density range in window 200um x 200um, stepping 100um. is <=85% 
@ The following special regions are excluded while the density checking: PA,MARKS, LOGO,INDMY 
@ This rule is only applied while the width of (checking window NOT excluded region) >=50um.
  Z0 = OR PA INDMY LOGO MARKS
  X0 = MTT2i_all NOT Z0
  Y0 = DRC:1 NOT Z0
  Y1 = Y0 WITH WIDTH >= 200
  X1 = X0 AND Y1
  OUT1 = DENSITY X1 Y1 > 0.85 [ AREA(X1)/AREA(Y1) ] WINDOW 200 STEP 100 BACKUP INSIDE OF LAYER DRC:1 PRINT density_report_IND_R_9_G_h_MTT2_1.log RDB density_report_IND_R_9_G_h_MTT2_1.rdb
  SIZE (OUT1 AND Y1) BY 25 UNDEROVER

 Y2 = (Y0 NOT Y1) WITH WIDTH >= 50 < 200
 Y3 = COPY Y2
 X2 = X0 AND Y2
