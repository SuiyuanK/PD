if { $TOPMETAL == 10 } {
VERBATIM {
TV1_square = RECTANGLE TV1 ASPECT ==1
WUTM_b = (M8 WITH WIDTH > 3) WITH EDGE (LENGTH (M8 WITH WIDTH > 3) > 10)
WUTM_EDGE_b = LENGTH WUTM_b > 0
WUTM_EXP_b = EXPAND EDGE WUTM_EDGE_b OUTSIDE BY 5
TV1_A_b = TV1_square INTERACT WUTM_EXP_b
CONNECT TV1_A_b M8
CONNECT WUTM_b M8

WTM1_b = (TM1 WITH WIDTH > 3) WITH EDGE (LENGTH (TM1 WITH WIDTH > 3) > 10)
WTM1_EDGE_b = LENGTH WTM1_b > 0
WTM1_EXP_b = EXPAND EDGE WTM1_EDGE_b OUTSIDE BY 5
WTM1_L1_b = ( TM1 not WTM1_b ) TOUCH WTM1_b
TV1_A2_b = TV1_square INTERACT WTM1_EXP_b

TM1_EMPTY = EMPTY OR TM1
TV1_A2_EMPTY_b = EMPTY  OR TV1_A2_b 
WTM1_EMPTY_b =EMPTY OR WTM1_b 
CONNECT TV1_A2_EMPTY_b  TM1_EMPTY
CONNECT WTM1_EMPTY_b TM1_EMPTY
TV1_15 {
@ At least two TV1s  when either wide metal of Mn or TM1 with both length L>10um and width W>3um, and the distance D<=5um away from this wide metal.Exclude non-square Vn and SRAM area.
WUTM_L1_b = ( M8 NOT WUTM_b ) TOUCH WUTM_b
//UTM_ENCWM = (M8 INTERACT WUTM_b) INTERACT TV1_A_b
//WUTM_VEDGE = EXT [UTM_ENCWM]  <5 ABUT<90 OPPOSITE NOTCH
//WUTM_EXT1 = DFM SPACE (WUTM_b COIN EDGE WUTM_VEDGE) [TV1_A_b] < 5 BY EXT CONNECTED 
//WUTM_EXT2 = (DFM COPY (DFM SPACE WUTM_b TV1_A_b < 5 BY EXT CONNECTED) REGION) INSIDE M8  
TV1_B = COPY TV1_square 
X1 =(M8 AND TM1) ENCLOSE TV1_square >1
X2 = ((M8 AND TM1)  AND ( WUTM_L1_b AND WUTM_EXP_b )) NOT X1 
Y0=(M8 AND TM1) ENCLOSE TV1_square ==1 
Y1 = SIZE (TV1_square INTERACT Y0) BY 5 INSIDE OF M8 STEP 0.005  
Y2= Y1 INTERACT (Y1 AND WUTM_b)
VSING1= (X2 INTERACT TV1_B ==1) INTERACT Y2
VSING1 OUTSIDE INST 


//TM1_ENCWM = (TM1 INTERACT WTM1_b) INTERACT TV1_A2_b
//WTM1_VEDGE = EXT [TM1_ENCWM]  <5 ABUT<90 OPPOSITE NOTCH
//WTM1_EXT1 = DFM SPACE (WTM1_EMPTY_b COIN EDGE WTM1_VEDGE) [TV1_A2_EMPTY_b] < 5 BY EXT CONNECTED 
//WTM1_EXT2 = (DFM COPY (DFM SPACE WTM1_EMPTY_b TV1_A2_EMPTY_b < 5 BY EXT CONNECTED) REGION) INSIDE TM1  
TV1_B2 = COPY TV1_square 
X3 = ((M8 AND TM1)  AND ( WTM1_L1_b AND WTM1_EXP_b )) NOT X1 
Y3 = SIZE (TV1_square INTERACT Y0) BY 5 INSIDE OF TM1 STEP 0.005  
Y4= Y3 INTERACT (Y3 AND WTM1_b)
VSING2= (X3 INTERACT TV1_B2 ==1) INTERACT Y4
VSING2 OUTSIDE INST
}

TV1_16 {
@ 45-degree rotated TV1 is not allowed.
  (ANGLE TV1 >= 44.9 <= 45.1) NOT INSIDE EDGE MARKS
}
TV1_19 {
@ It?s not allowed TV1 overlap with Mn and TM1 resistor.
  TV1 AND (M8 AND M8R)
  TV1 AND (TM1 AND TM1R)
}
}
}
