CONNECT M6_EMPTY5 M5_EMPTY5 BY V5_EMPTY5
CONNECT M5_EMPTY5 M4_EMPTY5 BY V4_EMPTY5
CONNECT M4_EMPTY5 M3_EMPTY5 BY V3_EMPTY5
}
if { $TOPMETAL == 9 } {
CONNECT TM1_EMPTY5 M7_EMPTY5 BY TV1_EMPTY5
CONNECT M7_EMPTY5 M6_EMPTY5 BY V6_EMPTY5
CONNECT M6_EMPTY5 M5_EMPTY5 BY V5_EMPTY5
CONNECT M5_EMPTY5 M4_EMPTY5 BY V4_EMPTY5
CONNECT M4_EMPTY5 M3_EMPTY5 BY V3_EMPTY5
}
if { $TOPMETAL == 8 } {
CONNECT TM1_EMPTY5 M6_EMPTY5 BY TV1_EMPTY5
CONNECT M6_EMPTY5 M5_EMPTY5 BY V5_EMPTY5
CONNECT M5_EMPTY5 M4_EMPTY5 BY V4_EMPTY5
CONNECT M4_EMPTY5 M3_EMPTY5 BY V3_EMPTY5
}
if { $TOPMETAL == 7 } {
CONNECT TM1_EMPTY5 M5_EMPTY5 BY TV1_EMPTY5
CONNECT M5_EMPTY5 M4_EMPTY5 BY V4_EMPTY5
CONNECT M4_EMPTY5 M3_EMPTY5 BY V3_EMPTY5
}
if { $TOPMETAL == 6 } {
