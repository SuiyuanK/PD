CHECK_REGION = COPY DENSITY_MARK
X =DENSITY CHECK_LAYER CHECK_REGION [area(CHECK_LAYER)/area(CHECK_REGION)] < 0.2 PRINT density_report_M4_7f.log RDB density_report_M4_7f.db
X NOT MARKS
}
}
}
