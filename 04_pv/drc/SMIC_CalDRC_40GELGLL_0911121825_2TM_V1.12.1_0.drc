VERBATIM {


IND_R_8_G_TM1_density {
@ TM1 metal density over the whole chip (include INDDMY) is >= 20%.
  DENSITY_MARK = BORDER NOT MARKS
  CHECK_LAYER = TM1i_all NOT MARKS
  CHECK_REGION = COPY DENSITY_MARK
  X =DENSITY CHECK_LAYER CHECK_REGION [area(CHECK_LAYER)/area(CHECK_REGION)] < 0.2 PRINT density_report_IND_R_8_G_TM1.log RDB density_report_IND_R_8_G_TM1.db
  X NOT MARKS
}
IND_R_9_G_l_TM1_density {
@ TM1 density range in window 200um x 200um, stepping 100um. is >=15% 
@ The following special regions are excluded while the density checking: PA,MARKS, LOGO,INDMY 
@ This rule is only applied while the width of (checking window NOT excluded region) >=50um.
  Z0 = OR PA INDMY LOGO MARKS
  X0 = TM1i_all NOT Z0
  Y0 = DRC:1 NOT Z0
  Y1 = Y0 WITH WIDTH >= 200
  X1 = X0 AND Y1
  OUT1 = DENSITY X1 Y1 < 0.15 [ AREA(X1)/AREA(Y1) ] WINDOW 200 STEP 100 BACKUP INSIDE OF LAYER DRC:1 PRINT density_report_IND_R_9_G_l_TM1_1.log RDB density_report_IND_R_9_G_l_TM1_1.rdb
  SIZE (OUT1 AND Y1) BY 25 UNDEROVER

 Y2 = (Y0 NOT Y1) WITH WIDTH >= 50 < 200
 Y3 = COPY Y2
 X2 = X0 AND Y2
 DENSITY X2 Y2 [!AREA(Y2) + !!AREA(Y2)*(AREA(X2)/(max(AREA(Y2),0.00001))) ] < 0.15 INSIDE OF LAYER Y3 BY POLYGON PRINT density_report_IND_R_9_G_l_TM1_2.log RDB density_report_IND_R_9_G_l_TM1_2.rdb
}


IND_R_9_G_h_TM1_density {
@ TM1 density range in window 200um x 200um, stepping 100um. is <=85% 
@ The following special regions are excluded while the density checking: PA,MARKS, LOGO,INDMY 
@ This rule is only applied while the width of (checking window NOT excluded region) >=50um.
  Z0 = OR PA INDMY LOGO MARKS
  X0 = TM1i_all NOT Z0
  Y0 = DRC:1 NOT Z0
  Y1 = Y0 WITH WIDTH >= 200
  X1 = X0 AND Y1
  OUT1 = DENSITY X1 Y1 > 0.85 [ AREA(X1)/AREA(Y1) ] WINDOW 200 STEP 100 BACKUP INSIDE OF LAYER DRC:1 PRINT density_report_IND_R_9_G_h_TM1_1.log RDB density_report_IND_R_9_G_h_TM1_1.rdb
  SIZE (OUT1 AND Y1) BY 25 UNDEROVER

 Y2 = (Y0 NOT Y1) WITH WIDTH >= 50 < 200
 Y3 = COPY Y2
 X2 = X0 AND Y2
 DENSITY X2 Y2 [!AREA(Y2) + !!AREA(Y2)*(AREA(X2)/(max(AREA(Y2),0.00001))) ] > 0.85 INSIDE OF LAYER Y3 BY POLYGON PRINT density_report_IND_R_9_G_h_TM1_2.log RDB density_report_IND_R_9_G_h_TM1_2.rdb
}
#IFDEF UTM NO
