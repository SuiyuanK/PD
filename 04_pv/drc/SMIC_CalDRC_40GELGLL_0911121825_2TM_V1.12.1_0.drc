  CONVEX EDGE (LENGTH PC < 0.070)  ANGLE1 >0 ANGLE2 >0
}
SE_3 {
@ SN vertex must not be connected to two short edges with length < 0.14um
  CONVEX EDGE (LENGTH SN < 0.140)  ANGLE1 >=0 ANGLE2 >0
}
SE_4 {
