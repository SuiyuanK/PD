if { $TOPMETAL == 10 } {
VERBATIM {
TV1_13 {
@ At least 2 TV1 connect Mx to TM1 intersection area if either TM1 or Mx width>1.8 um
  X1 = M8 WITH WIDTH > 1.8
  X2 = TM1 WITH WIDTH > 1.8
  Y1 = (M8 AND TM1) INTERACT X1
  Y2 = (M8 AND TM1) INTERACT X2
  (Y1 OR Y2) INTERACT TV1 == 1
}
TV1_17 {
@ TV1 connected to Mn, TM1DUM is not allowed.
@ This rule is not applied for LOGO covered region.
  (TV1 INTERACT (M8DUM OR TM1DUM)) NOT LOGO
}
TV1_18 {
@ TV1 must be fully covered by Mn and TM1.
  TV1 NOT (M8 AND TM1)
}
}
}
