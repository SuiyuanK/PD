 ((EXT V4_voltage_33 M4i < 0.11 ABUT < 90 SINGULAR REGION EXTENTS MEASURE ALL) INTERACT M4i>1 ) NOT INSIDE MARKS
}
 M4_18 {
@ Space between Mn and neighboring (Vn or Vn-1) when either Mn or (Vn or Vn-1) connects to >3.3v and ≤5v net.
@ DRC doesn't check Mn which the neighboring (Vn or Vn-1) is landed.	≥	0.16
 ((EXT M4i_voltage_50 V3i < 0.16 ABUT < 90 SINGULAR REGION EXTENTS MEASURE ALL) INTERACT M4i>1 ) NOT INSIDE MARKS
 ((EXT V3_voltage_50 M4i < 0.16 ABUT < 90 SINGULAR REGION EXTENTS MEASURE ALL) INTERACT M4i>1 ) NOT INSIDE MARKS
 ((EXT M4i_voltage_50 V4i < 0.16 ABUT < 90 SINGULAR REGION EXTENTS MEASURE ALL) INTERACT M4i>1 ) NOT INSIDE MARKS
 ((EXT V4_voltage_50 M4i < 0.16 ABUT < 90 SINGULAR REGION EXTENTS MEASURE ALL) INTERACT M4i>1 ) NOT INSIDE MARKS
}
 M4_19 {
@ Space between Mn line end (when metal line width ≤0.12um and length ≥0.13um)
@ and neighboring (Vn or Vn-1) when either Mn or (Vn or Vn-1) connects to >3.3v and ≤5v net	≥	0.21
@ DRC doesn't check Mn which the neighboring Vn is landed.
 line_end1 = CONVEX EDGE M4i_voltage_50 ANGLE1 > 0 LENGTH1 >= 0.13  ANGLE2 > 0 LENGTH2 >= 0.13 WITH LENGTH <= 0.12  
 line_end2 = CONVEX EDGE M4i ANGLE1 > 0 LENGTH1 >= 0.13  ANGLE2 > 0 LENGTH2 >= 0.13 WITH LENGTH <= 0.12
 ((EXT line_end1 V3i < 0.21 ABUT < 90  REGION EXTENTS MEASURE ALL) INTERACT M4i>1 ) NOT INSIDE MARKS
 ((EXT line_end2 V3_voltage_50 < 0.21 ABUT < 90  REGION EXTENTS MEASURE ALL) INTERACT M4i>1 ) NOT INSIDE MARKS
 ((EXT line_end1 V4i < 0.21 ABUT < 90  REGION EXTENTS MEASURE ALL) INTERACT M4i>1 ) NOT INSIDE MARKS
 ((EXT line_end2 V4_voltage_50 < 0.21 ABUT < 90  REGION EXTENTS MEASURE ALL) INTERACT M4i>1 ) NOT INSIDE MARKS
}
M4_20 {
@ Space between Mn and neighboring (Vn or Vn-1) when either Mn or (Vn or Vn-1) connects to >=1.8v and <=2.5v net.
@ DRC doesn't check Mn which the neighboring (Vn or Vn-1) is landed.	≥	0.1
 ((EXT M4i_voltage_18 V3i < 0.1 ABUT < 90 SINGULAR REGION EXTENTS MEASURE ALL) INTERACT M4i>1 ) NOT INSIDE MARKS
 ((EXT V3_voltage_18 M4i < 0.1 ABUT < 90 SINGULAR REGION EXTENTS MEASURE ALL) INTERACT M4i>1 ) NOT INSIDE MARKS
 ((EXT M4i_voltage_18 V4i < 0.1 ABUT < 90 SINGULAR REGION EXTENTS MEASURE ALL) INTERACT M4i>1 ) NOT INSIDE MARKS
 ((EXT V4_voltage_18 M4i < 0.1 ABUT < 90 SINGULAR REGION EXTENTS MEASURE ALL) INTERACT M4i>1 ) NOT INSIDE MARKS

( (EXT M4i_voltage_25 V3i < 0.1 ABUT < 90 SINGULAR REGION EXTENTS MEASURE ALL) INTERACT M4i>1 ) NOT INSIDE MARKS
 ((EXT V3_voltage_25 M4i < 0.1 ABUT < 90 SINGULAR REGION EXTENTS MEASURE ALL) INTERACT M4i>1 ) NOT INSIDE MARKS
 ((EXT M4i_voltage_25 V4i < 0.1 ABUT < 90 SINGULAR REGION EXTENTS MEASURE ALL) INTERACT M4i>1 ) NOT INSIDE MARKS
 ((EXT V4_voltage_25 M4i < 0.1 ABUT < 90 SINGULAR REGION EXTENTS MEASURE ALL) INTERACT M4i>1 ) NOT INSIDE MARKS

}
}
