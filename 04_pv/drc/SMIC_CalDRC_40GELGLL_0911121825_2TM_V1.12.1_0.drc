  CONVEX EDGE (LENGTH M4 < 0.070)  ANGLE1 >=0 ANGLE2 >0
}
SE_5d {
@ M5 vertex must not be connected to two short edges with lengths < 0.07 um
  CONVEX EDGE (LENGTH M5 < 0.070)  ANGLE1 >=0 ANGLE2 >0
}
SE_5e {
