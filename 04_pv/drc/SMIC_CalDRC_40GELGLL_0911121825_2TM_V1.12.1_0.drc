#! tvf
namespace import tvf::*





#################################################
#     Environmental Variables Setting           #
#################################################

#TOP Metal select. The value can be 10,9,8,7,6,5(include double top metals(TM1,TM2/MTT2)).
#Default value is 10.
set TOPMETAL 8              ;#valid value is: {10,9,8,7,6,5}

VERBATIM {
#DEFINE CONNECT_ALL_RESISTOR 0  //;#valid value is: {0,1}   
                             //;#default 0 
                             //;#The switch (to connect AA resistor, Hi-R resistor, well resistor between PAD and AA injector) can control the connectivity of resistor.   
                             //;#if 0,the connection is broken; 
                             //;#if 1,the connection is not broken;

#DEFINE DEFINE_PAD_BY_TEXT  1   // ;# valid value is: {0,1}
                             //;# default is 1
                             //;# when“?VDD?”,”?VCC?”,“?VSS?”,”?GND?” as text name using layer ALPATXT on ALPA,
                             //;# if 0, it is regarded as I/O PAD; if 1, it is regarded POWER PAD. 


//***********************************************
//   SMIC internal choice
//***********************************************


//AA resistor layout guideline selection. Default is YES.
//when check AA resistor layout guidelines, please set it to "YES".
//when not to check AA resistor layout guidelines, please set it to "NO".
#DEFINE RESAA_CHECK YES           //valid value is: {YES, NO}


//NW resistor layout guideline selection. Default is YES.
//when check NW resistor layout guidelines, please set it to "YES".
//when not to check NW resistor layout guidelines, please set it to "NO".
#DEFINE RESNW_CHECK YES           //valid value is: {YES, NO}


//Poly resistor layout guideline selection. Default is YES.
//when check Poly resistor layout guidelines, please set it to "YES".
//when not to check Poly resistor layout guidelines, please set it to "NO".
#DEFINE RESP_CHECK YES           //valid value is: {YES, NO}


//ESD layout guideline selection. Default is NO.
//when check ESD layout guidelines, please set it to "YES".
//when not to check ESD layout guidelines, please set it to "NO".
#DEFINE ESD_CHECK NO           //valid value is: {YES, NO}


//Latch Up Prevention Layout Guidelines selection. Default is YES.
//when check Latch up guidelines, please set it to "YES".
//when not to check Latch up guidelines, please set it to "NO".
#DEFINE LATCH_UP_CHECK YES           //valid value is: {YES, NO}

// LDMOS rule selection. Defaults to NO.
// when check LDMOS rules , please set it to "YES"; 
// when not to check LDMOS rules, please set it to "NO".	
#DEFINE LD NO           //valid value is: {YES, NO}

//Inductor rule selection. Defaults to YES.
//when check inductor rules , please set it to "YES".
//when not to check inductor rules, please set it to "NO".
#DEFINE INDUCTOR YES           //valid value is: {YES, NO}

//BUMP rule selection. Default is "NO".
//when check BUMP rules , please set it to "YES".
//when not to check BUMP rules, please set it to "NO".
#DEFINE BUMP NO           //valid value is: {YES, NO}




//LOGO guideline selection. Default is YES.
//when check LOGO guidelines, please set it to "YES".
//when not to check LOGO guidelines, please set it to "NO".
#DEFINE LOGO YES           //valid value is: {YES, NO}


//MOM(metal oxide metal) capacitor rule selection for MOM.4[G]. Defaults to YES.
//when check MOM.4[G] guidelines,please set it to "YES";
//when not to check MOM.4[G] guidelines,please set it to "NO".
#DEFINE MOM_4_CHECK YES           //valid value is: {YES, NO}


//MOM(metal oxide metal) capacitor rule selection for MOM.5[G]. Default is YES.
//when check MOM.5[G],guidelines,please set it to "YES".
//when not to check MOM.5[G] guidelines,please set it to "NO".
#DEFINE MOM_5_CHECK YES           //valid value is: {YES, NO}


//MOM(metal oxide metal) capacitor rule selection for MOM.6[G]. Default is YES.
//when check MOM.6[G] guidelines,please set it to "YES".
//when not to check MOM.6[G] guidelines,please set it to "NO".
#DEFINE MOM_6_CHECK YES           //valid value is: {YES, NO}






//This switch is for default turn on DFM rules.
//Default value is "YES" to check default turn on DFM rules.
//Please change the value "YES" into "NO" if you don't want to check these rules.
#DEFINE DFM_rules_CHECK_ON YES           //valid value is: {YES, NO}
   

//This switch is for default turn off DFM rules.
//Default value is "NO" not to check default turn off DFM rules.
//Please change the value "NO" into "YES" if you want to check these rules.
#DEFINE DFM_rules_CHECK_OFF NO           //valid value is: {YES, NO}


//If top metal is layer TM2 (layer 122, top metal with regular thickness), then please use default value NO.
//If top metal is layer MTT2 (layer 231, top metal with ultra thickness), then please change it into YES.
#DEFINE UTM NO           //valid value is: {YES, NO}








//CORN rule selection. Default is YES.
//when check Chip without SEAL RING , please set it to "YES".
//when check Chip with SEAL RING, please set it to "NO".
#DEFINE CHK_CORN NO           //valid value is: {YES, NO}


//BORDER rule selection. Default is YES.
//If customer check the chip level , please set it to "YES".
//If customer check the IP level , please set it to "NO".
#DEFINE CHK_BORDER NO           //valid value is: {YES, NO}


//SRAM GT direction selection.
//Default is V (vertical).
//But it can also be changed into H (horizontal).
#DEFINE SRAM_GT_DIRECTION V           //valid value is: {H,V}




//This switch is only for LU_3_3a_G,LU_3_3b_G,LU_3_3c_G, LU_3_3d_G rules 
// default value is "FAST" to fast check LU_3_? rules and reduce runtime,yet it may report false alarm in min space value 
// please change the value "FAST" into "ACCURATE",if you want to accurately check LU_3_? rules, yet it have long runtime.
#DEFINE LU_3_CHECK FAST   //valid value is: {FAST, ACCURATE}
//****************************the END for switch setting

//***********************************************
//   SMIC internal choice
//***********************************************
/*This switch can control all the recommended or guideline rules.
  the default set is NO,Change "NO" to "YES" could open all the recommended or guideline rules.
  NOTICE:this switch is only for SMIC PDE internal use.
  Customer or other users please keep the default set "NO".
  SMIC don't bear any responsibility for use this switch!
*/
#DEFINE OPEN_ALL_RECOMMENDED_GUIDELINE NO

