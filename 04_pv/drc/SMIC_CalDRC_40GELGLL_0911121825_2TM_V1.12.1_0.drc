#for { set i 1 } { $i <= $M1_and_1XMn_metal_counts } { incr i} {
#SETLAYER M${i}_0 = M$i NOT M${i}_VOLTAGE
#}
for { set i 1 } { $i <= [expr $M1_and_1XMn_metal_counts - 1] } { incr i} {
SETLAYER V${i}_voltage_50 = V$i INTERACT (M${i}i_voltage_50 OR M[expr $i +1]i_voltage_50) 
SETLAYER V${i}_voltage_33 = V$i INTERACT (M${i}i_voltage_33 OR M[expr $i +1]i_voltage_33) 
SETLAYER V${i}_voltage_25 = V$i INTERACT (M${i}i_voltage_25 OR M[expr $i +1]i_voltage_25) 
SETLAYER V${i}_voltage_18 = V$i INTERACT (M${i}i_voltage_18 OR M[expr $i +1]i_voltage_18) 
SETLAYER V${i}_voltage_15 = V$i INTERACT (M${i}i_voltage_15 OR M[expr $i +1]i_voltage_15) 
 
