#IFDEF LOGO YES
//============================
//  Logo Design Guideline
//============================

GROUP GLOGO LOGO_?

LOGO_1_G_AA {
@ Space between LOGO and AA, GT or Metal is >= 10um.
@ DRC doesn't check dummy AA, dummy GT, dummy metal.
  EXT LOGO (AA NOT INTERACT LOGO) < 10 ABUT<90 SINGULAR REGION
}
LOGO_1_G_GT {
@ Space between LOGO and AA, GT or Metal is >= 10um.
@ DRC doesn't check dummy AA, dummy GT, dummy metal.
  EXT LOGO (GT NOT INTERACT LOGO) < 10 ABUT<90 SINGULAR REGION
}
LOGO_1_G_M1 {
@ Space between LOGO and AA, GT or Metal is >= 10um.
@ DRC doesn't check dummy AA, dummy GT, dummy metal.
  EXT LOGO (M1 NOT INTERACT LOGO) < 10 ABUT<90 SINGULAR REGION
}
LOGO_1_G_M2 {
@ Space between LOGO and AA, GT or Metal is >= 10um.
@ DRC doesn't check dummy AA, dummy GT, dummy metal.
  EXT LOGO (M2 NOT INTERACT LOGO) < 10 ABUT<90 SINGULAR REGION
}
LOGO_1_G_M3 {
@ Space between LOGO and AA, GT or Metal is >= 10um.
@ DRC doesn't check dummy AA, dummy GT, dummy metal.
  EXT LOGO (M3 NOT INTERACT LOGO) < 10 ABUT<90 SINGULAR REGION
}
LOGO_1_G_M4 {
@ Space between LOGO and AA, GT or Metal is >= 10um.
@ DRC doesn't check dummy AA, dummy GT, dummy metal.
  EXT LOGO (M4 NOT INTERACT LOGO) < 10 ABUT<90 SINGULAR REGION
}
LOGO_1_G_M5 {
@ Space between LOGO and AA, GT or Metal is >= 10um.
@ DRC doesn't check dummy AA, dummy GT, dummy metal.
  EXT LOGO (M5 NOT INTERACT LOGO) < 10 ABUT<90 SINGULAR REGION
}
LOGO_1_G_M6 {
@ Space between LOGO and AA, GT or Metal is >= 10um.
@ DRC doesn't check dummy AA, dummy GT, dummy metal.
  EXT LOGO (M6 NOT INTERACT LOGO) < 10 ABUT<90 SINGULAR REGION
}
LOGO_1_G_M7 {
@ Space between LOGO and AA, GT or Metal is >= 10um.
@ DRC doesn't check dummy AA, dummy GT, dummy metal.
  EXT LOGO (M7 NOT INTERACT LOGO) < 10 ABUT<90 SINGULAR REGION
}
LOGO_1_G_M8 {
@ Space between LOGO and AA, GT or Metal is >= 10um.
@ DRC doesn't check dummy AA, dummy GT, dummy metal.
  EXT LOGO (M8 NOT INTERACT LOGO) < 10 ABUT<90 SINGULAR REGION
}
LOGO_1_G_TM1 {
@ Space between LOGO and AA, GT or Metal is >= 10um.
@ DRC doesn't check dummy AA, dummy GT, dummy metal.
  EXT LOGO (TM1 NOT INTERACT LOGO) < 10 ABUT<90 SINGULAR REGION
}
#IFDEF UTM NO
LOGO_1_G_TM2 {
@ Space between LOGO and AA, GT or Metal is >= 10um.
@ DRC doesn't check dummy AA, dummy GT, dummy metal.
  EXT LOGO (TM2 NOT INTERACT LOGO) < 10 ABUT<90 SINGULAR REGION
}
#ENDIF
#IFDEF UTM YES
LOGO_1_G_MTT2 {
@ Space between LOGO and AA, GT or Metal is >= 10um.
@ DRC doesn't check dummy AA, dummy GT, dummy metal.
  EXT LOGO (MTT2 NOT INTERACT LOGO) < 10 ABUT<90 SINGULAR REGION
}
#ENDIF
LOGO_2_G {
@ LOGO overlap with PA, ALPA is not allowed.
  LOGO AND PA
  LOGO AND ALPA
}
#ENDIF


//============================
//  Conventional Check
//============================

GROUP GConvention Convention_?

Convention_1 {
@ NW without N+ pick up is not allowed.
  (NWi NOT INTERACT NTAPi) NOT MARKS
}
Convention_2 {
@ (SP AND (AA AND GT)) in PW is not allowed, except LDMOS,VARMOS and OCCD region.
  X = PW AND ((SPi AND AAi) AND GTi)
  (X NOT ((LDBK OR VARMOS) OR OCCD)) NOT MARKS
}
Convention_3 {
@ (SN AND (AA AND GT)) in NW is not allowed, except LDMOS and VARMOS region.
@ This rule is not applied for (DNSRAM OR LRSRAM) OR D2SRAM) OR RFSRAM) covered region.
  X = NWi AND ((SNi AND AAi) AND GTi)
  (X NOT ((LDBK OR VARMOS) OR SRAM)) NOT MARKS
}


//*******************************************************************************************************************************
//          ESD Design Rules and Guideline
//*******************************************************************************************************************************


ESD = ESD1 AND ESDIO2

ENACT = NACT AND ESDIO2
EPACT = PACT AND ESDIO2
ENTAP = ENACT AND NW
EPTAP = EPACT NOT NW

EGATE = Real_GATE AND ESDIO2
ENGATE = EGATE AND ENACT
EPGATE = EGATE AND EPACT

//SETLAYER EGATEHV = (EGATE AND DG) AND DGOD               //2.5V
//SETLAYER EGATEMV = (EGATE AND DG) NOT DGOD               //1.8V or 1.5V
EGATEHV = EGATE AND TG 
ENGATEHV = ENGATE AND TG
EPGATEHV = EPGATE AND TG
EGATEMV = EGATE AND DG                          //1.8V or 1.5V
EGATELV = EGATE NOT INSIDE (DG OR TG)                          //1.05V


EGATE_CASCODED = (EGATE AND ESDIO2) AND ESD5V   //Cascoded 1.8V/2.5V NMOS

EGATE_CASCODED_OVLAP = EGATE_CASCODED CUT ESAB
EGATE_CASCODED_INSID = EGATE_CASCODED INSIDE ESAB

EGATE_W = EGATE COIN EDGE GATE_WE
EGATE_L = EGATE COIN EDGE GATE_LE

EGATE_POLY = GT ENCLOSE EGATE
ENGATE_POLY = GT ENCLOSE ENGATE
EPGATE_POLY = GT ENCLOSE EPGATE

ECT = CT AND ESDIO2
ESAB = SAB AND ESDIO2
ESAB_HO = HOLES ESAB INNER EMPTY
ECT_S = ECT INSIDE EMOS_S
ECT_D = ECT INSIDE EMOS_D

ENMOS = ENACT ENCLOSE EGATE
EPMOS = EPACT ENCLOSE EGATE
ENMOS_SD = ENMOS NOT EGATE
EPMOS_SD = EPMOS NOT EGATE


ENAA_DRAIN = ((ENACT NOT GT)INTERACT GT) INTERACT SAB >= 1
EPAA_DRAIN = ((EPACT NOT GT)INTERACT GT) INTERACT SAB >= 1
EAA_DRAIN = ENAA_DRAIN OR EPAA_DRAIN
ENAA_SOURCE = ((ENACT NOT GT)INTERACT GT) NOT INTERACT SAB
EPAA_SOURCE = ((EPACT NOT GT)INTERACT GT) NOT INTERACT SAB
EAA_SOURCE = ENAA_SOURCE OR EPAA_SOURCE
ECT_D1 = (ECT INTERACT EAA_DRAIN)NOT INTERACT SAB
ECT_S1 = (ECT INTERACT EAA_SOURCE)NOT INTERACT SAB



ENMOS_S = ENMOS_SD ENCLOSE ECT_S1
ENMOS_D = ENMOS_SD ENCLOSE ECT_D1
EPMOS_S = EPMOS_SD ENCLOSE ECT_S1
EPMOS_D = EPMOS_SD ENCLOSE ECT_D1

//ENMOS_S = ENMOS_SD ENCLOSE ECT_S
//ENMOS_S = (ENMOS_SD NOT ESAB) TOUCH EGATE
//ENMOS_D = ENMOS_SD ENCLOSE ECT_D
//ENMOS_D = (ENMOS_SD NOT ESAB) NOT TOUCH EGATE
//EPMOS_S = EPMOS_SD ENCLOSE ECT_S
//EPMOS_S = (EPMOS_SD NOT ESAB) TOUCH EGATE
//EPMOS_D = EPMOS_SD ENCLOSE ECT_D
//EPMOS_D = (EPMOS_SD NOT ESAB) NOT TOUCH EGATE
EMOS_D = ENMOS_D OR EPMOS_D
EMOS_S = ENMOS_S OR EPMOS_S


ENGUARDRING = HOLES ENTAP INNER
EPGUARDRING = HOLES EPTAP INNER
ENGUARDHOLE_2 = (HOLES ENTAP INNER) ENCLOSE EPGUARDRING
EPGUARDHOLE_2 = (HOLES EPTAP INNER) ENCLOSE ENGUARDRING

ESD3C_1 = EXPAND EDGE ((EGATE NOT EGATE_CASCODED) INSIDE EDGE AA) INSIDE BY 0.001
ESD3C_2 = EXPAND EDGE ((EGATE_CASCODED NOT INSIDE SAB) INSIDE EDGE AA) INSIDE BY 0.001
ESD3C = ESD3C_1 OR ESD3C_2


LAYER MAP 9998 DATATYPE 1234 5432
LAYER EMPTY1 5432
ENGATE_D_EMPTY = EMPTY1 OR (ESDIO2 AND ENMOS_D)
EPGATE_D_EMPTY = EMPTY1 OR (ESDIO2 AND EPMOS_D)
ESD3C_EMPTY = EMPTY1 OR ESD3C

EM1_EMPTY = EMPTY1 OR M1i
EV1_EMPTY = EMPTY1 OR V1i
EM2_EMPTY = EMPTY1 OR M2i
EV2_EMPTY = EMPTY1 OR V2i
EM3_EMPTY = EMPTY1 OR M3i
EV3_EMPTY = EMPTY1 OR V3i
EM4_EMPTY = EMPTY1 OR M4i
EV4_EMPTY = EMPTY1 OR V4i
EM5_EMPTY = EMPTY1 OR M5i
EV5_EMPTY = EMPTY1 OR V5i
EM6_EMPTY = EMPTY1 OR M6i
EV6_EMPTY = EMPTY1 OR V6i
EM7_EMPTY = EMPTY1 OR M7i
EV7_EMPTY = EMPTY1 OR V7i
EM8_EMPTY = EMPTY1 OR M8i
ETV1_EMPTY = EMPTY1 OR TV1i
ETM1_EMPTY = EMPTY1 OR TM1i
ETV2_EMPTY = EMPTY1 OR TV2i
ETM2_EMPTY = EMPTY1 OR TM2i
EMTT2_EMPTY = EMPTY1 OR MTT2i
ECT_EMPTY = EMPTY1 OR (ESDIO2 AND ECT)
EALPA_EMPTY = EMPTY1 OR ALPAi
EPA_EMPTY = EMPTY1 OR PA
EMD_EMPTY = EMPTY1 OR MD
ENMOS_SD_EMPTY = EMPTY1 OR ENMOS_SD
EPMOS_SD_EMPTY = EMPTY1 OR EPMOS_SD


CONNECT ENGATE_D_EMPTY ENMOS_SD_EMPTY
CONNECT ENMOS_SD_EMPTY ESD3C_EMPTY
CONNECT EPGATE_D_EMPTY EPMOS_SD_EMPTY 
CONNECT EPMOS_SD_EMPTY ESD3C_EMPTY
CONNECT ENGATE_D_EMPTY EM1_EMPTY BY ECT_EMPTY
CONNECT EPGATE_D_EMPTY EM1_EMPTY BY ECT_EMPTY
CONNECT EM1_EMPTY EM2_EMPTY BY EV1_EMPTY
}
if { $TOPMETAL == 5 } {
CONNECT EM2_EMPTY EM3_EMPTY BY EV2_EMPTY
CONNECT EM3_EMPTY ETM1_EMPTY BY ETV1_EMPTY
}
if { $TOPMETAL == 6 } {
CONNECT EM2_EMPTY EM3_EMPTY BY EV2_EMPTY
CONNECT EM3_EMPTY EM4_EMPTY BY EV3_EMPTY
CONNECT EM4_EMPTY ETM1_EMPTY BY ETV1_EMPTY
}
if { $TOPMETAL == 7 } {
CONNECT EM2_EMPTY EM3_EMPTY BY EV2_EMPTY
CONNECT EM3_EMPTY EM4_EMPTY BY EV3_EMPTY
CONNECT EM4_EMPTY EM5_EMPTY BY EV4_EMPTY
CONNECT EM5_EMPTY ETM1_EMPTY BY ETV1_EMPTY
}
if { $TOPMETAL == 8 } {
CONNECT EM2_EMPTY EM3_EMPTY BY EV2_EMPTY
CONNECT EM3_EMPTY EM4_EMPTY BY EV3_EMPTY
CONNECT EM4_EMPTY EM5_EMPTY BY EV4_EMPTY
CONNECT EM5_EMPTY EM6_EMPTY BY EV5_EMPTY
CONNECT EM6_EMPTY ETM1_EMPTY BY ETV1_EMPTY
}
if { $TOPMETAL == 9 } {
CONNECT EM2_EMPTY EM3_EMPTY BY EV2_EMPTY
CONNECT EM3_EMPTY EM4_EMPTY BY EV3_EMPTY
CONNECT EM4_EMPTY EM5_EMPTY BY EV4_EMPTY
CONNECT EM5_EMPTY EM6_EMPTY BY EV5_EMPTY
CONNECT EM6_EMPTY EM7_EMPTY BY EV6_EMPTY
CONNECT EM7_EMPTY ETM1_EMPTY BY ETV1_EMPTY
}
if { $TOPMETAL == 10 } {
CONNECT EM2_EMPTY EM3_EMPTY BY EV2_EMPTY
CONNECT EM3_EMPTY EM4_EMPTY BY EV3_EMPTY
CONNECT EM4_EMPTY EM5_EMPTY BY EV4_EMPTY
CONNECT EM5_EMPTY EM6_EMPTY BY EV5_EMPTY
CONNECT EM6_EMPTY EM7_EMPTY BY EV6_EMPTY
CONNECT EM7_EMPTY EM8_EMPTY BY EV7_EMPTY
CONNECT EM8_EMPTY ETM1_EMPTY BY ETV1_EMPTY
}
VERBATIM {
CONNECT ETM1_EMPTY EMTT2_EMPTY BY ETV2_EMPTY
CONNECT ETM1_EMPTY ETM2_EMPTY BY ETV2_EMPTY
CONNECT ETM2_EMPTY EALPA_EMPTY BY EPA_EMPTY
CONNECT EMTT2_EMPTY EALPA_EMPTY BY EPA_EMPTY
CONNECT EALPA_EMPTY EMD_EMPTY

#IFDEF ESD_CHECK YES
//==============================================
//  ESD design and layout guideline
//==============================================

GROUP GESD ESD_?

ESDLO_2_G {
@ Unit finger width (F) of NMOS and PMOS for ESD protection device (Fig.2). >= 10um and <= 60um
 (LENGTH EGATE_W < 10) NOT INSIDE EDGE MARKS
 (LENGTH EGATE_W > 60) NOT INSIDE EDGE MARKS
}
ESDLO_3a_G {
    @ Channel width (W) of NMOS for ESD protection device (Channel width = Finger width x Finger No.). >= 300um
    @ Note: The total channel width is calculated by the ESD MOS in the same Drain connection. The connectivity is not broken by resistor for this check.
    @ SAB is used for drain recognition in DRC runset.
    X = NET AREA RATIO ENGATE_D_EMPTY ESD3C_EMPTY [AREA(ESD3C_EMPTY)/0.001] < 300
    X  NOT MARKS
}
ESDLO_3b_G {
    @ Channel width (W) of PMOS for ESD protection device (Channel width=Finger width x Finger No.)
    @ Note: The total channel width is calculated by the ESD MOS in the same Drain connection. The connectivity is not broken by resistor for this check.
    @ SAB is used for drain recognition in DRC runset. ? 450 um
    X = NET AREA RATIO EPGATE_D_EMPTY ESD3C_EMPTY [AREA(ESD3C_EMPTY)/0.001] < 450
    X NOT MARKS
}
ESDLO_4a_G {
    @ Channel length of 2.5V I/O N/PMOS for protection device is >= 0.27
    X = (EGATEHV NOT (OVERDR OR TGV)) COIN EDGE GATE_LE
    (LENGTH X < 0.27) NOT INSIDE EDGE MARKS
}
ESDLO_4b_N_G {
    @ Channel length of 2.5V I/O overdrive 3.3V NMOS for protection device is >= 0.55
    X = (ENGATEHV AND OVERDR) COIN EDGE GATE_LE
    (LENGTH X < 0.55) NOT INSIDE EDGE MARKS
}
ESDLO_4b_P_G {
    @ Channel length of 2.5V I/O overdrive 3.3V PMOS for protection device is >= 0.44
    X = (EPGATEHV AND OVERDR) COIN EDGE GATE_LE
    (LENGTH X < 0.44) NOT INSIDE EDGE MARKS
}
ESDLO_4c_G {
    @ Channel length of 2.5V I/O underdrive 1.8V N/PMOS for protection device >= 0.24
    X = (EGATEHV AND TGV) COIN EDGE GATE_LE
    (LENGTH X < 0.24) NOT INSIDE EDGE MARKS
}
ESDLO_4d_G {
    @ Channel length of 1.8V I/O N/PMOS for protection device >= 0.2
    X = EGATEMV COIN EDGE GATE_LE
    (LENGTH X < 0.2) NOT INSIDE EDGE MARKS
}
ESDLO_4e_G {
    @ Channel length of 1.1V N/PMOS for protection device >= 0.07
    X = EGATELV COIN EDGE GATE_LE
    (LENGTH X < 0.07) NOT INSIDE EDGE MARKS
}
ESDLO_5_G {
    @ Space from poly edge to CT edge on source side (SCP) for NMOS and PMOS >= 0.2um
    (EXT EGATE_W ECT_S < 0.2 ABUT< 90 REGION) NOT MARKS
}
/*
ESDLO_6_G {
    @ Space from poly edge to CT edge on drain side (DCP) >= 1.3um
    (EXT EGATE_W ECT_D < 1.3 ABUT< 90 REGION) NOT MARKS
}
*/
ESDLO_7_G {
    @ SAB should block on drain side of NMOS and PMOS (contact region should be kept silicided.)
    (EGATE NOT INTERACT ESAB) NOT INSIDE MARKS
    (ECT AND ESAB) NOT INSIDE MARKS
    //(EMOS_S AND ESAB) NOT MARKS
}
ESDLO_8a_G {
    @ Width of SAB on the drain side (A) for NMOS, note: A does not include the overlap of SAB area and GT >= 1.0um
    (EXT (ENMOS_D NOT ESAB) EGATE_W < 1.0 ABUT < 90 REGION) NOT MARKS
}
ESDLO_8b_G {
    @ Width of SAB on the drain side (A) for PMOS, note: A does not include the overlap of SAB area and GT >= 0.6um
    (EXT (EPMOS_D NOT ESAB) EGATE_W < 0.6 ABUT < 90 REGION) NOT MARKS
}
ESDLO_9_G {
    @ ESD protection devices should be surrounded by guard ring, this guard ring also can be designed as the pickup of the ESD device.
    (NOT EPGATE ENGUARDRING) NOT MARKS
    (NOT ENGATE EPGUARDRING) NOT MARKS
}

}

SETLAYER N_NOSAB = (NACT AND ESDIO2) NOT INTERACT SAB
SETLAYER N_SAB = (NACT AND ESDIO2) INTERACT SAB
SETLAYER P_NOSAB = (PACT AND ESDIO2) NOT INTERACT SAB
SETLAYER P_SAB = (PACT AND ESDIO2) INTERACT SAB
SETLAYER ENGATE_NOSAB = GATE AND N_NOSAB
SETLAYER ENGATE_SAB = GATE AND N_SAB
SETLAYER EPGATE_NOSAB = GATE AND P_NOSAB
SETLAYER EPGATE_SAB = GATE AND P_SAB
SETLAYER EGATE_NOSAB = ENGATE_NOSAB OR EPGATE_NOSAB
SETLAYER EGATE_SAB = ENGATE_SAB OR EPGATE_SAB
SETLAYER EGATE_NOSAB_W = EGATE_NOSAB COIN EDGE GATE_WE
SETLAYER EGATEHV_NOSAB = EGATE_NOSAB AND TG
SETLAYER EGATEHV_SAB = EGATE_SAB AND TG
SETLAYER EGATEMV_NOSAB = EGATE_NOSAB AND DG                          
SETLAYER EGATEMV_SAB = EGATE_SAB AND DG
SETLAYER EGATELV_NOSAB = EGATE_NOSAB NOT INSIDE (DG OR TG)

RULECHECK ESDLO_14a_G {
@ The overlap (Sd) of SAB and poly for all I/O ESD N/PMOS (Fig. 4). >= 0.05um
 SETLAYER EGATE_14 = GATE AND ESDIO2
 SETLAYER ENGATE_14 = EGATE_14 AND ENACT
 SETLAYER EPGATE_14 = EGATE_14 AND EPACT

 SETLAYER EGATEHV_14 = EGATE_14 AND TG 
 SETLAYER ENGATEHV_14 = ENGATE_14 AND TG
 SETLAYER EPGATEHV_14 = EPGATE_14 AND TG
 SETLAYER EGATEMV_14 = EGATE_14 AND DG                          
 SETLAYER EGATELV_14 = EGATE_14 NOT INSIDE (DG OR TG)
 OUTLAYER (INT EGATEHV_14 ESAB < 0.05 ABUT < 90 SINGULAR REGION)  NOT MARKS
 OUTLAYER (INT EGATEMV_14 ESAB < 0.05 ABUT < 90 SINGULAR REGION)  NOT MARKS
 SETLAYER X = EXT (ESAB OR ESAB_HO) < 0.005 ABUT INTERSECTING ONLY REGION
 SETLAYER A = X AND AA
 SETLAYER Y = (SAB AND DGTG) TOUCH EDGE A
 SETLAYER Z = (SAB AND DGTG) INSIDE EDGE (EGATEHV_14 OR EGATEMV_14)
 OUTLAYER (Y NOT TOUCH EDGE Z) NOT INSIDE EDGE MARKS 
}

RULECHECK ESDLO_14b_G {
@ The overlap (Sd) of the SAB and poly for core ESD N/PMOS. >= 0.02um
 SETLAYER EGATE_14 = GATE AND ESDIO2
 SETLAYER ENGATE_14 = EGATE_14 AND ENACT
 SETLAYER EPGATE_14 = EGATE_14 AND EPACT

 SETLAYER EGATEHV_14 = EGATE_14 AND TG 
 SETLAYER ENGATEHV_14 = ENGATE_14 AND TG
 SETLAYER EPGATEHV_14 = EPGATE_14 AND TG
 SETLAYER EGATEMV_14 = EGATE_14 AND DG                          
 SETLAYER EGATELV_14 = EGATE_14 NOT INSIDE (DG OR TG)
 OUTLAYER (INT EGATELV_14 ESAB < 0.02 ABUT < 90 SINGULAR REGION)  NOT  MARKS
 SETLAYER X = EXT (ESAB OR ESAB_HO) < 0.005 ABUT INTERSECTING ONLY REGION
SETLAYER A = X AND AA
 SETLAYER Y = SAB TOUCH EDGE A
 SETLAYER Z = SAB INSIDE EDGE (EGATELV_14 OR EGATEMV_14)
 OUTLAYER (Y NOT TOUCH EDGE Z) NOT INSIDE EDGE (OR DGTG MARKS)
}
VERBATIM {
ESDLO_15_G {
    @ For high voltage tolerant I/O using Cascoded 1.8V/2.5V NMOS, (ESDIO2 AND ESD5V) must overlap with ESD1.
    ((ESDIO2 AND ESD5V) NOT ENCLOSE ((ESDIO2 AND ESD5V) AND ESD1)) NOT MARKS
}
ESDLO_16_G {
    @ The space (S) between active poly gate and inactive poly gate of cascoded NMOS should be <= 0.3um
    (DFM COPY (DFM SPACE EGATE_CASCODED_OVLAP EGATE_CASCODED_INSID > 0.3 <10 BY EXT) REGION) NOT MARKS
   // (EGATE_CASCODED_OVLAP COIN OUTSIDE EDGE EGATE_CASCODED_INSID) NOT INSIDE EDGE MARKS
}
ESDLO_17a_G {
@ Channel length of 3.3V tolerant I/O (covered by marking layer ESDIO2 and ESDHV) using cascaded 2.5V overdrive 3.3V NMOS.≥0.27um
  X = EGATEHV COIN EDGE GATE_LE_1
  (((EGATEHV AND ESD5V) AND ESDIO2)  WITH EDGE (LENGTH X < 0.27)) NOT INSIDE MARKS
}

ESDLO_17b_G {
@ Channel length of 5V tolerant I/O (covered by marking layer ESDIO2, ESDHV and OVERDR) using cascaded 2.5V overdrive 3.3V NMOS.≥0.55um
  X = EGATEHV COIN EDGE GATE_LE_1
  ((((EGATEHV AND ESD5V)AND ESDIO2) AND OVERDR)  WITH EDGE (LENGTH X < 0.55)) NOT INSIDE MARKS			
}


ESDLO_18_G {
    @ For high voltage tolerant I/O designed by 1.8V/2.5V N/PMOS, SAB should cover all top poly gates and extend to overlap the second poly gate by >= 0.05um
    X = EGATE_CASCODED INTERACT ESAB
    (INT X ESAB < 0.05 ABUT < 90 SINGULAR REGION) NOT MARKS
    (EGATE_CASCODED OUTSIDE ESAB) NOT MARKS
}
#ENDIF

#IFDEF LATCH_UP_CHECK YES
//===========================================
//  Latch-Up Prevention Layout Guidelines
//===========================================
GROUP GLU LU_?
}


SETLAYER PAA = AA AND SP
SETLAYER NAA = AA AND SN


SETLAYER ENMOS_OV = SIZE ENMOS BY 5.000
SETLAYER EPMOS_OV = SIZE EPMOS BY 5.000


#SETLAYER AARES = (AA AND DIFRES) AND RESAA
SETLAYER AARES = (AA AND RESAA) OR (AA AND DIFRES)
SETLAYER NWAARES = (RESNW AND AA) AND NW
SETLAYER NWSTRES = (RESNW AND NW) NOT AA
#SETLAYER HRRES = ((GT AND RESP1) AND SAB) AND SP
SETLAYER GTRES = ((GT AND RESP1) OR (GT AND PLRES)) OR (GT AND HRPDMY)





SETLAYER AARES_1 = AA ENCLOSE AARES
SETLAYER NW_RES = NWAARES OR NWSTRES
#SETLAYER HR_RES = GT ENCLOSE HRRES
SETLAYER GR_RES = GT ENCLOSE GTRES
#SETLAYER ALL_RES1 = OR AARES_1 HR_RES NW_RES
SETLAYER ALL_RES1 = OR AARES_1 GR_RES NW_RES
 

SETLAYER NSD_0 = ((SN AND AA) NOT NW) NOT GT    
SETLAYER PSD_0 = ((SP AND AA) AND NW) NOT GT 

for {set j 1} { $j <= [expr $TOPMETAL-2 ] } {incr j} {
  SETLAYER M${j}i_EMPTY6 = EMPTY6 OR M${j}i
}
  SETLAYER TM1i_EMPTY6 = EMPTY6 OR TM1i
  SETLAYER TM2i_EMPTY6 = EMPTY6 OR TM2i
  SETLAYER MTT2i_EMPTY6 = EMPTY6 OR MTT2i
  SETLAYER ALPAi_EMPTY6 = EMPTY6 OR ALPAi

for {set a 1} { $a < [expr $TOPMETAL-2 ] } {incr a} {
  SETLAYER V${a}_EMPTY6 = EMPTY6 OR V${a}
}
  SETLAYER TV1_EMPTY6 = EMPTY6 OR TV1
  SETLAYER TV2_EMPTY6 = EMPTY6 OR TV2


VERBATIM {
#IFDEF CONNECT_ALL_RESISTOR 0 
}

SETLAYER  NSD_1 = EMPTY6 OR (NSD_0 NOT ALL_RES1) 
SETLAYER  PSD_1 = EMPTY6 OR (PSD_0 NOT ALL_RES1)
SETLAYER  NTAP_1 = EMPTY6 OR (NTAP NOT ALL_RES1)
SETLAYER  PTAP_1 = EMPTY6 OR (PTAP NOT ALL_RES1) 
SETLAYER  NW_1 = EMPTY6 OR (NW NOT ALL_RES1)
SETLAYER  GT_1  =  EMPTY6 OR (GT NOT ALL_RES1)
VERBATIM {
#ENDIF
}
VERBATIM {
#IFDEF CONNECT_ALL_RESISTOR 1 
}
SETLAYER NSD_1 = EMPTY6 OR NSD_0  
SETLAYER PSD_1 = EMPTY6 OR PSD_0
SETLAYER NTAP_1 = EMPTY6 OR NTAP 
SETLAYER PTAP_1 = EMPTY6 OR PTAP 
SETLAYER NW_1 = EMPTY6 OR NW
SETLAYER GT_1  =  EMPTY6 OR GT
VERBATIM {
#ENDIF
}


SETLAYER MD_1  = EMPTY6 OR MD 
SETLAYER CT_1 = EMPTY6 OR CT
SETLAYER PA_1 = EMPTY6 OR PA
SETLAYER PW_1 = EMPTY6 OR PW



set p [expr $TOPMETAL-2]
for { set c 1 } { $c < $p } { incr c } {
CONNECT M${c}i_EMPTY6 M[expr $c + 1]i_EMPTY6 BY V${c}_EMPTY6
}
CONNECT M[expr $TOPMETAL-2]i_EMPTY6 TM1i_EMPTY6 BY TV1_EMPTY6
VERBATIM {
#IFDEF UTM NO
}
CONNECT TM1i_EMPTY6 TM2i_EMPTY6 BY TV2_EMPTY6
VERBATIM {
#ENDIF
#IFDEF UTM YES
}
CONNECT TM1i_EMPTY6 MTT2i_EMPTY6 BY TV2_EMPTY6
VERBATIM {
#ENDIF
}

CONNECT M1i_EMPTY6 GT_1 NTAP_1 PTAP_1 NSD_1 PSD_1 BY CT_1
VERBATIM {
#IFDEF UTM NO
}
CONNECT TM2i_EMPTY6 ALPAi_EMPTY6 BY PA_1
VERBATIM {
#ENDIF
#IFDEF UTM YES
}
CONNECT MTT2i_EMPTY6 ALPAi_EMPTY6 BY PA_1
VERBATIM {
#ENDIF
}
CONNECT ALPAi_EMPTY6 MD_1
CONNECT NTAP_1 NW_1
#CONNECT PTAP_1 PW_1
#CONNECT PTAP_1 NSD_1
#CONNECT NTAP_1 PSD_1



set M1_and_1XMn_list_temp { M1 M2 M3 M4 M5 M6 M7 M8 }
set 1XVn_list_temp { V1 V2 V3 V4 V5 V6 V7 }

set M1_and_1XMn_list [lrange $M1_and_1XMn_list_temp 0 [expr $M1_and_1XMn_metal_counts -1] ]
set 1XVn_list [lrange $1XVn_list_temp 0 [expr $M1_and_1XMn_metal_counts -2] ]
set inter_metal_list [concat $M1_and_1XMn_list]
set inter_via_list [concat $1XVn_list]
#//recognise POWER PAD

VERBATIM {
#IFDEF UTM NO
}
set total_metal_list_ALPA [concat $inter_metal_list TM1 TM2 ALPA]
foreach j $total_metal_list_ALPA {
SETLAYER all_pad_${j}_vdd1 = with text ${j}i "?VDD?" ${j}TXT primary only  
SETLAYER all_pad_${j}_vss1 = with text ${j}i "?VSS?" ${j}TXT primary only 
SETLAYER all_pad_${j}_vcc1 = with text ${j}i "?VCC?" ${j}TXT primary only 
SETLAYER all_pad_${j}_gnd1 = with text ${j}i "?GND?" ${j}TXT primary only
}

set inter_metal_list_ALPA [concat $inter_metal_list TM1 TM2 ALPA]
foreach i $inter_metal_list_ALPA {
SETLAYER all_pad_TXT_${i} = OR all_pad_${i}_vdd1 all_pad_${i}_vss1 all_pad_${i}_vcc1 all_pad_${i}_gnd1
SETLAYER all_pad_TXT1_${i} = STAMP all_pad_TXT_${i} BY ${i}i_EMPTY6
SETLAYER power_pad_TXT_${i} = ${i}i_EMPTY6 INTERACT (NET AREA RATIO ${i}i_EMPTY6 all_pad_TXT1_${i} > 0)
}
VERBATIM {
#ENDIF
}

VERBATIM {
#IFDEF UTM YES
}
set total_metal_list_ALPA [concat $inter_metal_list TM1 MTT2 ALPA]
foreach j $total_metal_list_ALPA {
SETLAYER all_pad_${j}_vdd1 = with text ${j}i "?VDD?" ${j}TXT primary only  
SETLAYER all_pad_${j}_vss1 = with text ${j}i "?VSS?" ${j}TXT primary only 
SETLAYER all_pad_${j}_vcc1 = with text ${j}i "?VCC?" ${j}TXT primary only 
SETLAYER all_pad_${j}_gnd1 = with text ${j}i "?GND?" ${j}TXT primary only
}

set inter_metal_list_ALPA [concat $inter_metal_list TM1 MTT2 ALPA]
foreach i $inter_metal_list_ALPA {
SETLAYER all_pad_TXT_${i} = OR all_pad_${i}_vdd1 all_pad_${i}_vss1 all_pad_${i}_vcc1 all_pad_${i}_gnd1
SETLAYER all_pad_TXT1_${i} = STAMP all_pad_TXT_${i} BY ${i}i_EMPTY6
SETLAYER power_pad_TXT_${i} = ${i}i_EMPTY6 INTERACT (NET AREA RATIO ${i}i_EMPTY6 all_pad_TXT1_${i} > 0)
}
VERBATIM {
#ENDIF
}

SETLAYER POWER_PAD1 = VSSMK1 OR VDDMK1
SETLAYER POWER_PAD2 = STAMP POWER_PAD1 BY MD_1
SETLAYER POWER_PAD3 = MD_1 INTERACT (NET AREA RATIO MD_1 POWER_PAD2 > 0)
SETLAYER MD_IO_PAD = MD_1 NOT INTERACT POWER_PAD3
SETLAYER NMOS_1 = NACT ENCLOSE GATE 
SETLAYER PMOS_1 = PACT ENCLOSE GATE 


VERBATIM {
#IFDEF DEFINE_PAD_BY_TEXT 0 
}
SETLAYER NAA_IO_PAD = NET AREA RATIO NSD_1 MD_IO_PAD > 0 
SETLAYER PAA_IO_PAD = NET AREA RATIO PSD_1 MD_IO_PAD > 0 
SETLAYER NMOS_IO_PAD = NMOS_1 INTERACT NAA_IO_PAD 
SETLAYER PMOS_IO_PAD = PMOS_1 INTERACT PAA_IO_PAD 
VERBATIM {
#ENDIF
}
VERBATIM {
#IFDEF DEFINE_PAD_BY_TEXT 1 
}

SETLAYER NAA_PAD = NET AREA RATIO NSD_1 MD_IO_PAD > 0 
SETLAYER PAA_PAD = NET AREA RATIO PSD_1 MD_IO_PAD > 0

set list1 ""
set list2 ""

VERBATIM {
#IFDEF UTM NO
}
foreach metal_list1 [ concat $inter_metal_list { TM1 TM2 ALPA } ] {
  SETLAYER NAA_POWER_PAD_${metal_list1} = NET AREA RATIO NAA_PAD power_pad_TXT_${metal_list1} > 0
  SETLAYER PAA_POWER_PAD_${metal_list1} = NET AREA RATIO PAA_PAD power_pad_TXT_${metal_list1} > 0 
  lappend list1 NAA_POWER_PAD_${metal_list1}
  lappend list2 PAA_POWER_PAD_${metal_list1}
}


SETLAYER NAA_POWER_PAD_all_1 = COPY NAA_POWER_PAD_M1
SETLAYER PAA_POWER_PAD_all_1 = COPY PAA_POWER_PAD_M1
for { set i 1 } { $i < [ llength $list1 ] } { incr i } {
SETLAYER NAA_POWER_PAD_all_[ expr $i + 1 ] = NAA_POWER_PAD_all_$i OR [ lindex $list1 $i ]
}
VERBATIM "  "
for { set i 1 } { $i < [ llength $list2 ] } { incr i } {
SETLAYER PAA_POWER_PAD_all_[ expr $i + 1 ] = PAA_POWER_PAD_all_$i OR [ lindex $list2 $i ]
}
VERBATIM {
#ENDIF
#IFDEF UTM YES
}

set list1 ""
set list2 ""

foreach metal_list1 [ concat $inter_metal_list { TM1 MTT2 ALPA } ] {
  SETLAYER NAA_POWER_PAD_${metal_list1} = NET AREA RATIO NAA_PAD power_pad_TXT_${metal_list1} > 0
  SETLAYER PAA_POWER_PAD_${metal_list1} = NET AREA RATIO PAA_PAD power_pad_TXT_${metal_list1} > 0 
  lappend list1 NAA_POWER_PAD_${metal_list1}
  lappend list2 PAA_POWER_PAD_${metal_list1}
}


SETLAYER NAA_POWER_PAD_all_1 = COPY NAA_POWER_PAD_M1
SETLAYER PAA_POWER_PAD_all_1 = COPY PAA_POWER_PAD_M1
for { set i 1 } { $i < [ llength $list1 ] } { incr i } {
SETLAYER NAA_POWER_PAD_all_[ expr $i + 1 ] = NAA_POWER_PAD_all_$i OR [ lindex $list1 $i ]
}
VERBATIM "  "
for { set i 1 } { $i < [ llength $list2 ] } { incr i } {
SETLAYER PAA_POWER_PAD_all_[ expr $i + 1 ] = PAA_POWER_PAD_all_$i OR [ lindex $list2 $i ]
}

VERBATIM {
#ENDIF
}



SETLAYER NAA_IO_PAD = NAA_PAD NOT INTERACT NAA_POWER_PAD_all_${i}
SETLAYER PAA_IO_PAD = PAA_PAD NOT INTERACT PAA_POWER_PAD_all_${i}
SETLAYER NMOS_IO_PAD = NMOS_1 INTERACT NAA_IO_PAD 
SETLAYER PMOS_IO_PAD = PMOS_1 INTERACT PAA_IO_PAD 
VERBATIM {
#ENDIF
}


SETLAYER PMOS1 = PAA ENCLOSE GATE
SETLAYER NMOS1 = NAA ENCLOSE GATE
SETLAYER NGUARDRING = HOLES NTAP INNER
SETLAYER PGUARDRING = HOLES PTAP INNER

SETLAYER GATEHV = GATE AND TG
SETLAYER GATEHV_3e = ((GATE AND TG) AND OVERDR ) AND ESD5V 
SETLAYER NGATEHV = NGATE AND TG
SETLAYER PGATEHV = PGATE AND TG
SETLAYER GATEMV = GATE AND DG                          
SETLAYER GATELV = GATE NOT INSIDE (DG OR TG)

RULECHECK LU_1_G {
@ Guard ring should be used to surround AA injector or a group of AA injectors which are connected to an I/O pad.
@ N+ injector must be surrounded by a P+ guard-ring.
@ P+ injector must be surrounded by a N+ guard-ring.
@ NW/PW pickups rings can be used as guard rings.
@ DRC doesn’t check OCCD region.
 OUTLAYER ((((NAA_IO_PAD INTERACT GT) NOT PGUARDRING) NOT INSIDE MARKS) NOT INSIDE LUWMK1 ) NOT INSIDE OCCD
 OUTLAYER ((((PAA_IO_PAD INTERACT GT) NOT NGUARDRING) NOT INSIDE MARKS) NOT INSIDE LUWMK1 ) NOT INSIDE OCCD
}

RULECHECK LU_2_G {
@ Guard-ring width for AA injector connected to an I/O pad.
@ For N+ injector, DRC checks guardring width of the nearest P+ guard-ring.
@ For P+ injector, DRC checks guardring width of the nearest N+ guard-ring.	≥	0.12	um
 SETLAYER X = SIZE (((HOLES NTAP INNER)NOT INTERACT LUWMK1) ENCLOSE (PAA_IO_PAD INTERACT GT)) BY 0.12 
 SETLAYER Y = SIZE (((HOLES PTAP INNER)NOT INTERACT LUWMK1) ENCLOSE (NAA_IO_PAD INTERACT GT)) BY 0.12
 OUTLAYER (X NOT ((HOLES NTAP INNER) OR (DONUT NTAP))) NOT INSIDE MARKS
 OUTLAYER (Y NOT ((HOLES PTAP INNER) OR (DONUT PTAP))) NOT INSIDE MARKS
}
#//LU_3_G LU.3a-LU.3d define minimum space (S1) between NMOS and PMOS with either one of NMOS or PMOS AA connected to I/O pad. (Fig.1). 

VERBATIM { 
#IFDEF LU_3_CHECK FAST
} 
RULECHECK LU_3_3a_G {
@ LU.3a-LU.3d define minimum space (S1) between NMOS and PMOS with either one of NMOS or PMOS AA connected to I/O pad. (Fig.1).    
@ LU.3a	For core N/PMOS AA connected to an I/O pad
@ Spacing between NMOS and PMOS.	≥	2	um
 SETLAYER  X = (NMOS_IO_PAD ENCLOSE GATELV) NOT (MARKS OR LUWMK1)
 SETLAYER  Y = (PMOS_IO_PAD ENCLOSE GATELV) NOT (MARKS OR LUWMK1)
 SETLAYER  M = (NMOS ENCLOSE GATELV) NOT (MARKS OR LUWMK1)
 SETLAYER  N = (PMOS ENCLOSE GATELV) NOT (MARKS OR LUWMK1)
 SETLAYER  Z1 = SIZE X BY 1.036 BEVEL 3
 SETLAYER  Z2 = SIZE N BY 1.036 BEVEL 3
 OUTLAYER  Z1 AND Z2     
 SETLAYER  Z3 = SIZE M BY 1.036 BEVEL 3
 SETLAYER  Z4 = SIZE Y BY 1.036 BEVEL 3
 OUTLAYER  ((Z3 AND Z4 )NOT INSIDE MARKS) NOT INSIDE LUWMK1
}
		
RULECHECK LU_3_3b_G {
@ LU.3a-LU.3d define minimum space (S1) between NMOS and PMOS with either one of NMOS or PMOS AA connected to I/O pad. (Fig.1).
@ For 1.8V N/PMOS AA connected to an I/O pad
@ Spacing between 1.8V NMOS and 1.8V/Core PMOS and Spacing between 1.8V PMOS and 1.8V/Core NMOS. >= 2.3um
 SETLAYER X = NMOS_IO_PAD ENCLOSE GATEMV
 SETLAYER Y = PMOS_IO_PAD ENCLOSE GATEMV
 SETLAYER M = NMOS_1 ENCLOSE (GATELV OR GATEMV)
 SETLAYER N = PMOS_1 ENCLOSE (GATELV OR GATEMV)
 #OUTLAYER (EXT M Y < 2.3 ABUT<90 SINGULAR REGION) NOT (MARKS OR LUWMK1)
 #OUTLAYER (EXT X  N < 2.3 ABUT<90 SINGULAR REGION) NOT (MARKS OR LUWMK1)
  SETLAYER Z1 = SIZE X BY 1.191 BEVEL 3
  SETLAYER Z2 = SIZE N BY 1.191 BEVEL 3
  OUTLAYER (Z1 AND Z2) NOT (MARKS OR LUWMK1)
  SETLAYER Z3 = SIZE M BY 1.191 BEVEL 3
  SETLAYER Z4 = SIZE Y BY 1.191 BEVEL 3
  OUTLAYER ((Z3 AND Z4) NOT INSIDE MARKS) NOT INSIDE LUWMK1
}

RULECHECK LU_3_3c_G {
@ LU.3a-LU.3d define minimum space (S1) between NMOS and PMOS with either one of NMOS or PMOS AA connected to I/O pad. (Fig.1).
@ For 2.5V N/PMOS AA connected to an I/O pad
@ Spacing between 2.5V NMOS and 2.5V/Core PMOS and Spacing between 2.5V PMOS and 2.5V/Core NMOS. >= 3.2um
 SETLAYER X = NMOS_IO_PAD ENCLOSE GATEHV
 SETLAYER Y = PMOS_IO_PAD ENCLOSE GATEHV
 SETLAYER M = NMOS_1 ENCLOSE (GATELV OR GATEHV )
 SETLAYER N = PMOS_1 ENCLOSE (GATELV OR GATEHV)
 #OUTLAYER (EXT M Y < 3.2 ABUT<90 SINGULAR REGION) NOT (MARKS OR LUWMK1)
 #OUTLAYER (EXT X N < 3.2 ABUT<90 SINGULAR REGION) NOT (MARKS OR LUWMK1)
 SETLAYER Z1 = SIZE X BY 1.657 BEVEL 3
 SETLAYER Z2 = SIZE N BY 1.657 BEVEL 3
 OUTLAYER (Z1 AND Z2) NOT (MARKS OR LUWMK1)
 SETLAYER Z3 = SIZE M BY 1.657 BEVEL 3
 SETLAYER Z4 = SIZE Y BY 1.657 BEVEL 3
 OUTLAYER ((Z3 AND Z4) NOT INSIDE MARKS) NOT INSIDE LUWMK1
}

RULECHECK LU_3_3d_G {
@ LU.3a-LU.3d define minimum space (S1) between NMOS and PMOS with either one of NMOS or PMOS AA connected to I/O pad. (Fig.1).
@ For 3.3 V N/PMOS AA (2.5V overdrive) connected to an I/O pad
@ Spacing between 3.3V NMOS and 3.3V/Core PMOS and Spacing between 3.3V PMOS and 3.3V/Core NMOS.	≥	4
 SETLAYER X = NMOS_IO_PAD ENCLOSE (GATEHV AND OVERDR)
 SETLAYER Y = PMOS_IO_PAD ENCLOSE (GATEHV AND OVERDR)
 SETLAYER M = NMOS ENCLOSE (GATELV OR (GATEHV AND OVERDR))
 SETLAYER N = PMOS ENCLOSE (GATELV OR (GATEHV AND OVERDR))
 #OUTLAYER (EXT X N < 4 ABUT<90 SINGULAR REGION) NOT (MARKS OR LUWMK1)
 #OUTLAYER (EXT Y M < 4 ABUT<90 SINGULAR REGION) NOT (MARKS OR LUWMK1)
 SETLAYER  Z1 = SIZE X BY 2.071 BEVEL 3
 SETLAYER  Z2 = SIZE N BY 2.071 BEVEL 3
 OUTLAYER  (Z1 AND Z2) NOT (MARKS OR LUWMK1)
 SETLAYER  Z3 = SIZE M BY 2.071 BEVEL 3
 SETLAYER  Z4 = SIZE Y BY 2.071 BEVEL 3
 OUTLAYER  ((Z3 AND Z4) NOT INSIDE MARKS) NOT INSIDE LUWMK1
}
RULECHECK LU_3_3e_G {
@ For 5V tolerant N/PMOS (covered by ESDHV and OVERDR mark layer) connected to an I/O pad
@ Spacing between 5V NMOS and 5V/2.5V/1.8V/core PMOS and 
@ Spacing between 5V PMOS and 5V/2.5V/1.8V/core NMOS >= 10 um
 SETLAYER X = NMOS_IO_PAD ENCLOSE ((GATEHV AND OVERDR) AND ESD5V)
 SETLAYER Y = PMOS_IO_PAD ENCLOSE ((GATEHV AND OVERDR) AND ESD5V)
 SETLAYER M = NMOS ENCLOSE (GATELV OR ((GATEHV AND OVERDR) AND ESD5V))
 SETLAYER N = PMOS ENCLOSE (GATELV OR ((GATEHV AND OVERDR) AND ESD5V))
 #OUTLAYER (EXT X N < 10 ABUT<90 SINGULAR REGION) NOT (MARKS OR LUWMK1)
 #OUTLAYER (EXT Y M < 10 ABUT<90 SINGULAR REGION) NOT (MARKS OR LUWMK1)
 SETLAYER  Z1 = SIZE X BY 5.178 BEVEL 3
 SETLAYER  Z2 = SIZE N BY 5.178 BEVEL 3
 OUTLAYER  (Z1 AND Z2) NOT (MARKS OR LUWMK1)
 SETLAYER  Z3 = SIZE M BY 5.178 BEVEL 3
 SETLAYER  Z4 = SIZE Y BY 5.178 BEVEL 3
 OUTLAYER  ((Z3 AND Z4) NOT INSIDE MARKS) NOT INSIDE LUWMK1
}



VERBATIM {
#ENDIF 
#IFDEF LU_3_CHECK ACCURATE 
}
RULECHECK LU_3_3a_G {
@ LU.3a-LU.3d define minimum space (S1) between NMOS and PMOS with either one of NMOS or PMOS AA connected to I/O pad. (Fig.1).
@ LU.3a For core N/PMOS AA connected to an I/O pad
@ Spacing between NMOS and PMOS. >= 2um
 SETLAYER X = NMOS_IO_PAD ENCLOSE GATELV
 SETLAYER Y = PMOS_IO_PAD ENCLOSE GATELV
 SETLAYER M = NMOS_1 ENCLOSE GATELV
 SETLAYER N = PMOS_1 ENCLOSE GATELV
 OUTLAYER ((EXT X N < 2 ABUT<90 SINGULAR REGION) NOT INSIDE MARKS) NOT INSIDE LUWMK1
 OUTLAYER ((EXT M Y < 2 ABUT<90 SINGULAR REGION) NOT INSIDE MARKS) NOT INSIDE LUWMK1
}

RULECHECK LU_3_3b_G {
@ LU.3a-LU.3d define minimum space (S1) between NMOS and PMOS with either one of NMOS or PMOS AA connected to I/O pad. (Fig.1).
@ For 1.8V N/PMOS AA connected to an I/O pad
@ Spacing between 1.8V NMOS and 1.8V/Core PMOS and Spacing between 1.8V PMOS and 1.8V/Core NMOS. >= 2.3um
 SETLAYER X = NMOS_IO_PAD ENCLOSE GATEMV
 SETLAYER Y = PMOS_IO_PAD ENCLOSE GATEMV
 SETLAYER M = NMOS_1 ENCLOSE (GATELV OR GATEMV)
 SETLAYER N = PMOS_1 ENCLOSE (GATELV OR GATEMV)
 OUTLAYER ((EXT M Y < 2.3 ABUT<90 SINGULAR REGION) NOT INSIDE MARKS) NOT INSIDE LUWMK1
 OUTLAYER ((EXT X N < 2.3 ABUT<90 SINGULAR REGION) NOT INSIDE MARKS) NOT INSIDE LUWMK1
}

RULECHECK LU_3_3c_G {
@ LU.3a-LU.3d define minimum space (S1) between NMOS and PMOS with either one of NMOS or PMOS AA connected to I/O pad. (Fig.1).
@ For 2.5V N/PMOS AA connected to an I/O pad
@ Spacing between 2.5V NMOS and 2.5V/Core PMOS and Spacing between 2.5V PMOS and 2.5V/Core NMOS. >= 3.2um
 SETLAYER X = NMOS_IO_PAD ENCLOSE GATEHV
 SETLAYER Y = PMOS_IO_PAD ENCLOSE GATEHV
 SETLAYER M = NMOS_1 ENCLOSE (GATELV OR GATEHV )
 SETLAYER N = PMOS_1 ENCLOSE (GATELV OR GATEHV)
 OUTLAYER ((EXT M Y < 3.2 ABUT<90 SINGULAR REGION) NOT INSIDE MARKS) NOT INSIDE LUWMK1
 OUTLAYER ((EXT X N < 3.2 ABUT<90 SINGULAR REGION) NOT INSIDE MARKS) NOT INSIDE LUWMK1
}

RULECHECK LU_3_3d_G {
@ LU.3a-LU.3d define minimum space (S1) between NMOS and PMOS with either one of NMOS or PMOS AA connected to I/O pad. (Fig.1).
@ For 3.3 V N/PMOS AA (2.5V overdrive) connected to an I/O pad
@ Spacing between 3.3V NMOS and 3.3V/Core PMOS and Spacing between 3.3V PMOS and 3.3V/Core NMOS.	≥	4
 SETLAYER X = NMOS_IO_PAD ENCLOSE (GATEHV AND OVERDR)
 SETLAYER Y = PMOS_IO_PAD ENCLOSE (GATEHV AND OVERDR)
 SETLAYER M = NMOS_1 ENCLOSE (GATELV OR (GATEHV AND OVERDR))
 SETLAYER N = PMOS_1 ENCLOSE (GATELV OR (GATEHV AND OVERDR))
 OUTLAYER ((EXT X N < 4 ABUT<90 SINGULAR REGION) NOT INSIDE MARKS) NOT INSIDE LUWMK1
 OUTLAYER ((EXT Y M < 4 ABUT<90 SINGULAR REGION) NOT INSIDE MARKS) NOT INSIDE LUWMK1
}

RULECHECK LU_3_3e_G {
@ For 5V tolerant N/PMOS (covered by ESDHV and OVERDR mark layer) connected to an I/O pad
@ Spacing between 5V NMOS and 5V/2.5V/1.8V/core PMOS and 
@ Spacing between 5V PMOS and 5V/2.5V/1.8V/core NMOS >= 10 um
 SETLAYER X = NMOS_IO_PAD ENCLOSE ((GATEHV AND OVERDR) AND ESD5V)
 SETLAYER Y = PMOS_IO_PAD ENCLOSE ((GATEHV AND OVERDR) AND ESD5V)
 SETLAYER M = NMOS_1 ENCLOSE (GATELV OR ((GATEHV AND OVERDR) AND ESD5V))
 SETLAYER N = PMOS_1 ENCLOSE (GATELV OR ((GATEHV AND OVERDR) AND ESD5V))
 OUTLAYER ((EXT X N < 10 ABUT<90 SINGULAR REGION) NOT INSIDE MARKS) NOT INSIDE LUWMK1
 OUTLAYER ((EXT Y M < 10 ABUT<90 SINGULAR REGION) NOT INSIDE MARKS) NOT INSIDE LUWMK1

}

VERBATIM {
#ENDIF 
}
RULECHECK LU_4_NTAP_G {
@ Space (S2) from any point within the Source/Drain region to the nearest pickup AA region inside the same well for I/O and internal circuits. (Fig.2). 
@ DRC doesn’t check OCCD region. <= 35um
 SETLAYER A = INT NTAP < 0.005 ABUT INTERSECTING ONLY REGION
 SETLAYER B = (NTAP INTERACT A) NOT A
 SETLAYER C = INT B < 0.001 ABUT INTERSECTING ONLY REGION
 SETLAYER D = (B INTERACT C) NOT C
#SETLAYER NW_MINUS_NTAP = SIZE D BY 35 INSIDE OF NW STEP 0.38
#SETLAYER X = PMOS1 AND NW
 SETLAYER NW_MINUS_NTAP_0 = SIZE D BY 15 INSIDE OF NW STEP 0.38 TRUNCATE 0.1
 SETLAYER MAYBE_BAD_b = NW NOT NW_MINUS_NTAP_0
 SETLAYER NW_FILTER = NW INTERACT MAYBE_BAD_b
 SETLAYER NW_MINUS_NTAP_1 = NW_MINUS_NTAP_0 AND NW_FILTER
 SETLAYER NW_MINUS_NTAP = SIZE NW_MINUS_NTAP_1 BY 20 INSIDE OF NW_FILTER STEP 0.38 TRUNCATE 0.1
 SETLAYER X = PMOS1 AND NW_FILTER
 OUTLAYER ((OUTSIDE EDGE X NW_MINUS_NTAP) NOT INSIDE EDGE MARKS) NOT INSIDE EDGE OCCD
}

RULECHECK LU_4_PTAP_G {
@ Space (S2) from any point within the Source/Drain region to the nearest pickup AA region inside the same well for I/O and internal circuits. (Fig.2). 
@ DRC doesn’t check OCCD region. <= 35um
 SETLAYER A = INT PTAP < 0.005 ABUT INTERSECTING ONLY REGION
 SETLAYER B = (PTAP INTERACT A) NOT A
 SETLAYER C = INT B < 0.001 ABUT INTERSECTING ONLY REGION
 SETLAYER D = (B INTERACT C) NOT C
#SETLAYER PW_MINUS_PTAP = SIZE D BY 35 INSIDE OF PW STEP 0.38
#SETLAYER X = NMOS1 AND PW
 SETLAYER PW_MINUS_PTAP_0 = SIZE D BY 15 INSIDE OF PW STEP 0.38 TRUNCATE 0.1
 SETLAYER MAYBE_BAD_b = PW NOT PW_MINUS_PTAP_0
 SETLAYER PW_FILTER = PW INTERACT MAYBE_BAD_b
 SETLAYER PW_MINUS_PTAP_1 = PW_MINUS_PTAP_0 AND PW_FILTER
 SETLAYER PW_MINUS_PTAP = SIZE PW_MINUS_PTAP_1 BY 20 INSIDE OF PW_FILTER STEP 0.38 TRUNCATE 0.1
 SETLAYER X = NMOS1 AND PW_FILTER
 OUTLAYER ((OUTSIDE EDGE X PW_MINUS_PTAP) NOT INSIDE EDGE MARKS) NOT INSIDE EDGE OCCD
}

VERBATIM {

#ENDIF





}


RULECHECK GRC_13 {
@ Seal ring must be a close ring.
@ DRC check CT/Metal/Via/Top metal/PA/ALPA layers and all the listed layers must be drawn.
if { $TOPMETAL == 10 } {
for { set i 1 } { $i <= 8 } { incr i } {
OUTLAYER MARKS NOT ENCLOSE (M${i}i TOUCH (HOLES M${i}i))
}
for { set i 1 } { $i <= 7 } { incr i } {
OUTLAYER MARKS NOT ENCLOSE (V${i}i TOUCH (HOLES V${i}i))
}
}
if { $TOPMETAL == 9 } {
for { set i 1 } { $i <= 7 } { incr i } {
OUTLAYER MARKS NOT ENCLOSE (M${i}i TOUCH (HOLES M${i}i))
}
for { set i 1 } { $i <= 6 } { incr i } {
OUTLAYER MARKS NOT ENCLOSE (V${i}i TOUCH (HOLES V${i}i))
}
}
if { $TOPMETAL == 8 } {
for { set i 1 } { $i <= 6 } { incr i } {
OUTLAYER MARKS NOT ENCLOSE (M${i}i TOUCH (HOLES M${i}i))
}
for { set i 1 } { $i <= 5 } { incr i } {
OUTLAYER MARKS NOT ENCLOSE (V${i}i TOUCH (HOLES V${i}i))
}
}
if { $TOPMETAL == 7 } {
for { set i 1 } { $i <= 5 } { incr i } {
OUTLAYER MARKS NOT ENCLOSE (M${i}i TOUCH (HOLES M${i}i))
}
for { set i 1 } { $i <= 4 } { incr i } {
OUTLAYER MARKS NOT ENCLOSE (V${i}i TOUCH (HOLES V${i}i))
}
}
if { $TOPMETAL == 6 } {
for { set i 1 } { $i <= 4 } { incr i } {
OUTLAYER MARKS NOT ENCLOSE (M${i}i TOUCH (HOLES M${i}i))
}
for { set i 1 } { $i <= 3 } { incr i } {
OUTLAYER MARKS NOT ENCLOSE (V${i}i TOUCH (HOLES V${i}i))
}
}
if { $TOPMETAL == 5 } {
for { set i 1 } { $i <= 3 } { incr i } {
OUTLAYER MARKS NOT ENCLOSE (M${i}i TOUCH (HOLES M${i}i))
}
for { set i 1 } { $i <= 2 } { incr i } {
OUTLAYER MARKS NOT ENCLOSE (V${i}i TOUCH (HOLES V${i}i))
}
}
VERBATIM {
#IFDEF UTM NO
MARKS NOT ENCLOSE (TM2i TOUCH (HOLES TM2i))
#ENDIF
#IFDEF UTM YES
MARKS NOT ENCLOSE (MTT2i TOUCH (HOLES MTT2i))
#ENDIF
}
OUTLAYER MARKS NOT ENCLOSE (CTi TOUCH (HOLES CTi))
OUTLAYER MARKS NOT ENCLOSE (TM1i TOUCH (HOLES TM1i))
OUTLAYER MARKS NOT ENCLOSE (TV1i TOUCH (HOLES TV1i))
OUTLAYER MARKS NOT ENCLOSE (TV2i TOUCH (HOLES TV2i))
OUTLAYER MARKS NOT ENCLOSE (PA TOUCH (HOLES PA))
OUTLAYER MARKS NOT ENCLOSE (ALPAi TOUCH (HOLES ALPAi))
}



#//=============================================
#// DUP  (Device Under Pad) design rules
#//=============================================
VERBATIM {
GROUP GWBPAD WBPAD_?

WBPAD_area = (DUPMK1 AND (MD interact DUPMK1)) OR ((SIZE (MD NOT INTERACT DUPMK1) BY 17.5 UNDEROVER) AND MD)
			
WBPAD_1 {
@ DUPMK1 is must for wire bond pad region.
  (WBPAD_area NOT INTERACT DUPMK1) NOT MARKS
}

WBPAD_2 {
@ DUPMK1 width
@ DRC waive the 3um jog violation for each side. 	≥	35	um
  Y1 = INT (ANGLE DUPMK1 == 45 ) [DUPMK1] < 0.005 ABUT   
  M = ((EXPAND EDGE Y1 INSIDE BY 0.001 EXTEND BY 4.998) OR (EXPAND EDGE (ANGLE DUPMK1 == 45) INSIDE BY 0.001)) HOLES   
  corner_1 = (EXPAND EDGE M OUTSIDE BY 0.001 CORNER FILL) OR M
  
  X1 = CONVEX EDGE DUPMK1 ANGLE1 == 270 ANGLE2 == 270
  X2_l = (EXPAND EDGE X1 OUTSIDE BY 3) INSIDE X3
  X2_s = (EXPAND EDGE X1 OUTSIDE BY 3) NOT INSIDE X3
  X3 = EXTENTS DUPMK1
  X5 = ((X3 NOT (OR X2_l X2_s DUPMK1)) NOT corner_1) NOT INTERACT X2_s
  Y = (X5 OR X2_l) NOT DUPMK1
  OUT1_l = INT (DUPMK1 COIN EDGE Y) X3 > 3 < 35 ABUT < 90 OPPOSITE REGION
  OUT2_s = INT (EXTENTS (DUPMK1 NOT INTERACT X2_l)) < 35 ABUT < 90 OPPOSITE REGION
  (OUT1_l OR OUT2_s) NOT MARKS
}

WBPAD_3 {
@ MD must be fully enclosed by DUPMK1.	≥	0	um
  bond_pad1 =  DUPMK1 AND (MD interact DUPMK1)
  ((MD INTERACT bond_pad1) NOT (DUPMK1 INTERACT bond_pad1)) NOT MARKS
}

WBPAD_4 {
@ In wire bond pad area, MD must interact with PA. (MD AND PA) width.
@ DRC waive the 3um jog violation for each side.	≥	35	um
  ((MD AND WBPAD_area) NOT INTERACT PA) NOT MARKS
  MDPA = (MD AND PA) AND WBPAD_area
  Y1 = INT (ANGLE MDPA == 45 ) [MDPA] < 0.005 ABUT   
  M = ((EXPAND EDGE Y1 INSIDE BY 0.001 EXTEND BY 4.998) OR (EXPAND EDGE (ANGLE MDPA == 45) INSIDE BY 0.001)) HOLES   
  corner_1 = (EXPAND EDGE M OUTSIDE BY 0.001 CORNER FILL) OR M
 
  X1 = CONVEX EDGE MDPA ANGLE1 == 270 ANGLE2 == 270
  X2_l = (EXPAND EDGE X1 OUTSIDE BY 3) INSIDE X3
  X2_s = (EXPAND EDGE X1 OUTSIDE BY 3) NOT INSIDE X3
  X3 = EXTENTS MDPA
  X5 = ((X3 NOT (OR X2_l X2_s MDPA)) NOT corner_1) NOT INTERACT X2_s
  Y = (X5 OR X2_l) NOT MDPA
  OUT1_l = INT (MDPA COIN EDGE Y) X3 > 3 < 35 ABUT < 90 OPPOSITE REGION
  OUT2_s = INT (EXTENTS (MDPA NOT INTERACT X2_l)) < 35 ABUT < 90 OPPOSITE REGION
  (OUT1_l OR OUT2_s) NOT MARKS
}

#IFDEF UTM NO
}

RULECHECK WBPAD_5 {
@ Wire bond pad should include one layer of solid ALPA and two layers of solid Cu metal (TM and TM-1).  It is not allowed to draw metal slot for ALPA, TM and TM-1 in wire bond pad area.
@ For example: For 40nm 1P8M design
@ Two thick top metal case: TM2 and TM1 should be solid.
@ One thick top metal case: TM2 and M7 should be solid.
  OUTLAYER (WBPAD_area NOT ALPA) NOT MARKS 
  OUTLAYER (WBPAD_area NOT TM2) NOT MARKS
  OUTLAYER (WBPAD_area NOT TM1) NOT MARKS
}
VERBATIM {
#ENDIF
#IFDEF UTM YES
}
RULECHECK WBPAD_5 {
@ Wire bond pad should include one layer of solid ALPA and two layers of solid Cu metal (TM and TM-1).  It is not allowed to draw metal slot for ALPA, TM and TM-1 in wire bond pad area.
@ For example: For 40nm 1P8M design
@ Two thick top metal case: TM2 and TM1 should be solid.
@ One thick top metal case: TM2 and M7 should be solid.
  OUTLAYER (WBPAD_area NOT ALPA) NOT MARKS 
  OUTLAYER (WBPAD_area NOT MTT2) NOT MARKS
  OUTLAYER (WBPAD_area NOT TM1) NOT MARKS
}
VERBATIM {
#ENDIF
}
RULECHECK WBPAD_6 {
@ TV-1 pattern must be outside of wire bond pad area.
@ For example: For 40nm 1P8M design
@ Two thick top metal case: TV1 must outside of wire bond pad area.
@ One thick top metal case: V6 must outside of wire bond pad area.
  OUTLAYER (WBPAD_area AND TV1) NOT MARKS
}
VERBATIM {
#IFDEF UTM NO
}

RULECHECK WBPAD_7 {
@ ALPA, TM, TM-1 should fully enclose wire bond pad area	≥	1	um
  OUTLAYER (ENC WBPAD_area ALPA < 1 ABUT < 90 SINGULAR REGION OUTSIDE ALSO) NOT MARKS
  OUTLAYER (ENC WBPAD_area TM2 < 1 ABUT < 90 SINGULAR REGION OUTSIDE ALSO) NOT MARKS
  OUTLAYER (ENC WBPAD_area TM1 < 1 ABUT < 90 SINGULAR REGION OUTSIDE ALSO) NOT MARKS
}
VERBATIM {
#ENDIF
#IFDEF UTM YES
}
RULECHECK WBPAD_7 {
@ ALPA, TM, TM-1 should fully enclose wire bond pad area	≥	1	um
  OUTLAYER (ENC WBPAD_area ALPA < 1 ABUT < 90 SINGULAR REGION OUTSIDE ALSO) NOT MARKS
  OUTLAYER (ENC WBPAD_area MTT2 < 1 ABUT < 90 SINGULAR REGION OUTSIDE ALSO) NOT MARKS
  OUTLAYER (ENC WBPAD_area TM1 < 1 ABUT < 90 SINGULAR REGION OUTSIDE ALSO) NOT MARKS
}
VERBATIM {
#ENDIF
}

proc WBPAD_cut_corner_length {layer} {
  SETLAYER ${layer}_EXTENT = EXTENTS ${layer}
  SETLAYER ${layer}_EXTENT_REDUNDANT = ${layer}_EXTENT NOT ${layer} 
  SETLAYER ${layer}_EXTENT_JOG = ${layer}_EXTENT_REDUNDANT WITH EDGE (${layer}_EXTENT_REDUNDANT COIN EDGE ${layer}_EXTENT) == 1
  SETLAYER ${layer}_EXTENT_JOG_WAIVE = INT ${layer}_EXTENT_JOG ${layer}_EXTENT < 3 MEASURE COIN OPPOSITE REGION
  SETLAYER ${layer}_SUMMARRY = ${layer} OR ${layer}_EXTENT_JOG_WAIVE
  SETLAYER ${layer}_SUMMARY = (SIZE ${layer}_SUMMARRY BY 17.5 UNDEROVER) AND ${layer}_SUMMARRY

  OUTLAYER (${layer}_SUMMARY INTERACT WBPAD_area) WITH EDGE (ANGLE (${layer}_SUMMARY INTERACT WBPAD_area) > 44.9 < 45.1) != 4
  OUTLAYER (${layer}_SUMMARY INTERACT WBPAD_area) NOT WITH EDGE (ANGLE (${layer}_SUMMARY INTERACT WBPAD_area) > 44.9 < 45.1)
  SETLAYER ${layer}_SUMMARY_WBPAD_NOT = (EXTENTS (${layer}_SUMMARY INTERACT WBPAD_area)) NOT (${layer}_SUMMARY INTERACT WBPAD_area)
  SETLAYER ${layer}_SUMMARY_WBPAD_CORNER = ${layer}_SUMMARY_WBPAD_NOT WITH EDGE (${layer}_SUMMARY_WBPAD_NOT COIN EDGE (EXTENTS (${layer}_SUMMARY INTERACT WBPAD_area))) == 2
  OUTLAYER LENGTH (${layer}_SUMMARY_WBPAD_CORNER COIN EDGE (EXTENTS (${layer}_SUMMARY INTERACT WBPAD_area))) <2
  OUTLAYER LENGTH (${layer}_SUMMARY_WBPAD_CORNER COIN EDGE (EXTENTS (${layer}_SUMMARY INTERACT WBPAD_area))) >5
}
RULECHECK WBPAD_8_MD_R_OFF {
@ MD/ALPA/PA/TM/TM-1 interact wire bond pad area should have 4 corners with 45° cut to reduce corner stress. The length of corner cut >=2um <=5um
  WBPAD_cut_corner_length MD
}
RULECHECK WBPAD_8_ALPA_R_OFF {
@ MD/ALPA/PA/TM/TM-1 interact wire bond pad area should have 4 corners with 45° cut to reduce corner stress. The length of corner cut >=2um <=5um
  WBPAD_cut_corner_length ALPA
}
RULECHECK WBPAD_8_PA_R_OFF {
@ MD/ALPA/PA/TM/TM-1 interact wire bond pad area should have 4 corners with 45° cut to reduce corner stress. The length of corner cut >=2um <=5um
  WBPAD_cut_corner_length PA
}
RULECHECK WBPAD_8_TM2_R_OFF {
@ MD/ALPA/PA/TM/TM-1 interact wire bond pad area should have 4 corners with 45° cut to reduce corner stress. The length of corner cut >=2um <=5um
  WBPAD_cut_corner_length TM2
}
RULECHECK WBPAD_8_TM1_R_OFF {
@ MD/ALPA/PA/TM/TM-1 interact wire bond pad area should have 4 corners with 45° cut to reduce corner stress. The length of corner cut >=2um <=5um
  WBPAD_cut_corner_length TM1
}
RULECHECK WBPAD_9 {
@ Wire bond pad area must have dense TV between TM and TM-1.TV density under wire bond pad. ≥	10%
@ DRC check methodology:
@ DRC check the (wire bond pad opening sd 1um) area.
 SETLAYER CHECK_REGION = SIZE WBPAD_area BY -1
 SETLAYER CHECK_LAYER = TV2 AND CHECK_REGION
 SETLAYER bond_padX = COPY CHECK_REGION
 OUTLAYER DENSITY CHECK_LAYER CHECK_REGION \[area(CHECK_LAYER)/area(CHECK_REGION)\] < 0.1 INSIDE OF LAYER bond_padX PRINT density_report_WBPAD_9.log RDB density_report_WBPAD_9.db  
}

RULECHECK WBPAD_10 {
@ TV density under wire bond pad area checked with window size 10umx10um, step 5um. ≥	10%
@ DRC check the (wire bond pad opening sd 1um) area. 
@ DRC need check the TV within wire bond pad opening area , where density ratio= (TV area)/( wire bond pad opening area).
@ (1) Firstly exclude the region which is defined in the rule, then check the layer density. 
@ (2) If design size is ≥ check window, please follow check window to check, if remained design size is < check window, please base on real size to check when the width of remained design ≥ (check window)/4 and <check window, and please ignore to check when the width of remained design < (check window)/4.
SETLAYER bond_pad_check = SIZE WBPAD_area BY -1
SETLAYER bond_padX = WITH WIDTH bond_pad_check >= 10 
SETLAYER X1 = TV2 AND bond_padX 
SETLAYER X2 = COPY bond_padX 
SETLAYER OUT1 = DENSITY X1 X2 < 0.1 \[area(X1)/area(X2)\] WINDOW 10 STEP 5 BACKUP INSIDE OF LAYER bond_padX PRINT density_report_WBPAD_10_1.log RDB density_report_WBPAD_10_1.rdb 
OUTLAYER SIZE (OUT1 AND X2) BY 1.25 UNDEROVER 

SETLAYER Y = (bond_pad_check NOT X2) WITH WIDTH >= 2.5 < 10 
SETLAYER Y1 = COPY Y 
SETLAYER Y2 = TV2 AND Y 
OUTLAYER DENSITY Y2 Y1 \[!AREA(Y1) + !!AREA(Y1)*(AREA(Y2)/(max(AREA(Y1),0.00001)))\] < 0.1 INSIDE OF LAYER Y BY POLYGON PRINT density_report_WBPAD_10_2.log RDB density_report_WBPAD_10_2.rdb
}
