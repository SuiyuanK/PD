///////////////////////////////////////////////////////////////////////////////////
//                                                                               //
//                             Environment Setting                               //
//                                                                               //
///////////////////////////////////////////////////////////////////////////////////


//*Please set the following options to proper values according to your design:
//==================================================================================
//*OPTION 1a: Define total number of Metal.The value can be 10~4. Default value is 10.

#DEFINE TOPMETAL 9
//===================================================================================
//*OPTION 1b: Define type of top metal.The value can be single or double.  
//*If use double top metal process, set this option to double(Lower Case).
//*If use single top metal process, set this option to single(Lower Case).
//*Single top metal for 1P10M is not allowed!
//*Double top metal for 1P4M is not allowdd!
//*Default value is double.

#DEFINE TOP_METAL_NUM double
//===================================================================================
//*OPTION 1c: Define top metal type.The value can be 0 or 1. Default value is 0.
//*0: TM2(122:0) is chosen as top metal2, TM2 width is 0.4um, and TM2 thickness is 9K;
//*1: MTT2(231:0) is chosen as top metal2,MTT2 width is 1.5um, and MTT2 thickness is 34k;

#DEFINE TM_METAL_TYPE 0
//====================================================================================
//*OPTION 1d: Define thickness of ALPA.The value can be THIN or THICK. Default value is THIN.
//*THIN:  ALPA thickness is 14.5K,the model name is ralpa_2t_ckt or ralpa_3t_ckt. 
//*THICK: ALPA thickness is 28K, the model name is ralpa_2p8_2t_ckt or ralpa_2p8_3t_ckt.

#DEFINE ALPA_THICK THIN
//===================================================================================
//*OPTION 2a: Define RC RUN or not.The value can be TRUE or FALSE(Upper Case) .
//*If LVS RUN, please set this option to FALSE. 
//*If LVS+RC RUN,please set this option to TRUE.Parameters for simulation will be extracted.
//*Default value is FALSE.

#DEFINE RC_RUN FALSE 
//===================================================================================
//*OPTION 2b: Define the back annotation flow.The value can be 1 or 2,Default value is 1.
//*For BJT's back annotation, RC_RUN needs to be TRUE.
//*1: extrview flow, LVS will reserve some extra parameters for back-annotation.
//*2: netlist flow, LVS will not reserve the back-annotation parameters.

#DEFINE BACK_ANNOTATION_FLOW 2
//===================================================================================
//*OPTION 3a: Define ERC Check or Not. The value can be TRUE or FALSE(Upper Case).
//*Default value is TRUE.

#DEFINE ERCCHECK FALSE
//===================================================================================
//*OPTION 3b: Turn on nwell floating check or not. The value can be TRUE or FALSE(Upper Case).
//*Nwell resistor and BJT are not checked.
//*Default value is FALSE.

#DEFINE NWELL_FLOATING_CHECK FALSE
//===================================================================================
//*OPTION 3c: Turn on nwell not connecting to power check or not. The value can be TRUE or FALSE(Upper Case).
//*Nwell resistor and BJT are not checked.
//*Default value is FALSE.

#DEFINE NWELL_NOT_TO_POWER_CHECK TRUE
//===================================================================================
//*OPTION 3d: Turn on pwell not connecting to ground check or not. The value can be TRUE or FALSE(Upper Case).
//*Default value is FALSE.

#DEFINE PWELL_NOT_TO_GROUND_CHECK TRUE
//====================================================================================
//*OPTION 4a: Compare diode number and connectivity or not for parasitic DIODE.The value can be TRUE or FALSE(Upper Case).
//*Default value is FALSE.

#DEFINE PARASI_DIO_CMP_NW FALSE
//===================================================================================
//*OPTION 4b: Compare parameters for parasitic DIODE.The value can be TRUE or FALSE(Upper Case).
//*Default value is FALSE.

#DEFINE PARASI_DIO_PROPERTY_CMP_NW FALSE
//===================================================================================
//*OPTION 4c: Compare diode number and connectivity or not for parasitic DIODE.The value can be TRUE or FALSE(Upper Case).
//*Default value is FALSE.

#DEFINE PARASI_DIO_CMP_DNW FALSE
//===================================================================================
//*OPTION 4d: Compare parameters for parasitic DIODE.The value can be TRUE or FALSE(Upper Case).
//*Default value is FALSE.

#DEFINE PARASI_DIO_PROPERTY_CMP_DNW FALSE
//===================================================================================
//*OPTION 4e: Compare PJ parameter or not for DIODE.The value can be TRUE or FALSE(Upper Case).
//*Default value is FALSE.

#DEFINE DIO_PJ FALSE
//====================================================================================
//*OPTION 5a: Define the mos mismatch model or not. The value can be 0 or 1;
//*MOS_MISMOD 0: Turn off the mismatch flag mismod for mos;
//*MOS_MISMOD 1: Turn on the mismatch flag mismod for mos;
//*Default value is 1.

#DEFINE MOS_MISMOD 1
//===================================================================================
//*OPTION 5b: Define the mos global model or not. The value can be 0 or 1;
//*MOS_GLOBALMOD 0: Turn off the globalmod for mos;
//*MOS_GLOBALMOD 1: Turn on the globalmod for mos;
//*Default value is 1.

#DEFINE MOS_GLOBALMOD 1
//===================================================================================
//*OPTION 5c: Define the lpemod for mos. The value can be 0 or 1;
//*MOS_LPEMOD 0: Turn off the lpemod for mos;
//*MOS_LPEMOD 1: Turn on the lpemod for mos;
//*Default value is 1.

#DEFINE MOS_LPEMOD 1
//===================================================================================
//*OPTION 5d: Define the resistor mismatch model or not.This value can be 0 or 1;
//*RES_MISMOD 0:turn off the mismatch flag mismod for resistor;
//*RES_MISMOD 1:turn on  the mismatch flag mismod for resistor;
//*Default value is 1.

#DEFINE RES_MISMOD 1
//====================================================================================
//*OPTION 5e: Define the BJT mismatch model or not.This value can be 0 or 1;
//*BJT_MISMOD 0:turn off the mismatch flag mismod for BJT;
//*BJT_MISMOD 1:turn on  the mismatch flag mismod for BJT;
//*Default value is 1.

#DEFINE BJT_MISMOD 1
//====================================================================================
//*OPTION 5f: Define the MOM mismatch model or not.This value can be 0 or 1;
//*MOM_MISMOD 0:turn off the mismatch flag mismod for MOM;
//*MOM_MISMOD 1:turn on  the mismatch flag mismod for MOM;
//*Default value is 1.

#DEFINE MOM_MISMOD 1
//====================================================================================
//*OPTION 5g: Define the Varactor mismatch model or not.This value can be 0 or 1;
//*VAR_MISMOD 0:turn off the mismatch flag mismod for Varactor;
//*VAR_MISMOD 1:turn on  the mismatch flag mismod for Varactor;
//*Default value is 1.

#DEFINE VAR_MISMOD 1
//====================================================================================
//*OPTION 5h: Define the sram mismatch mode or not. The value can be 0,1;
//*SRAM_MISMOD 0: turn off the mismatch flag mismod for sram;
//*SRAM_MISMOD 1: turn on the mismatch flag mismod for sram;
//*Default value is 1.

#DEFINE SRAM_MISMOD 1
//====================================================================================
//*OPTION 5i: Define the sram globalmod. The value can be 0,1;
//*SRAM_GLOBALMOD 0: turn off the globalmod for sram;
//*SRAM_GLOBALMOD 1: turn on the globalmod for sram;
//*Default value is 1.

#DEFINE SRAM_GLOBALMOD 1
//====================================================================================
//*OPTION 6: Define whether to control CASE SENSIVITY during circuit parsing and comparison.
//*The value can be TRUE or FALSE(Upper Case).
//*Default value is FALSE. 

#DEFINE CASE_SENSITIVITY FALSE
//===================================================================================
//*OPTION 7: Define whether to extract special loigc mos as a capacitor with holes on gates.
//*The value can be TRUE or FALSE(Upper Case).
//*Default value is FALSE. 

#DEFINE SPECIAL_GATES FALSE 
//===================================================================================
//*OPTION 8: Define whether to extract and compare psflag for MOM.
//*The value can be TRUE or FALSE(Upper Case).
//*Default value is TRUE. 

#DEFINE PSFLAG_MOM TRUE
//===================================================================================
//*OPTION 9: Extact and compare EFUSE_res or not;
//*The value can be TRUE or FALSE(Upper Case).
//*Default value is FALSE.

#DEFINE EFUSE_RES FALSE
//===================================================================================


//=======================================================
//Device tolerance setting
//user can change below tolerance according to the design 
//=======================================================
VARIABLE logmos_err 5
VARIABLE dio_err    5
VARIABLE res_err    5
VARIABLE bjt_err    5
VARIABLE mom_err    5
VARIABLE var_err    5
VARIABLE ldmos_err  5
VARIABLE sram_err   5
//==============================

SOURCE PATH "/home/master/Desktop/04_pv/v2lvs/top.spi"
SOURCE PRIMARY "top" 
SOURCE SYSTEM SPICE

LAYOUT PATH "/home/master/Desktop/04_pv/merge/Calibredrv/top_merged.gds"
LAYOUT PRIMARY "top" 
LAYOUT SYSTEM GDSII


PRECISION 1000

#IFDEF CASE_SENSITIVITY TRUE
LAYOUT  CASE YES
SOURCE  CASE YES
LVS COMPARE CASE NO
#ENDIF

LVS REPORT "lvs.rep"
LVS REPORT OPTION A B C D S

UNIT CAPACITANCE FF
UNIT RESISTANCE OHM
UNIT LENGTH U

#IFDEF RC_RUN TRUE
PEX NETLIST LUMPED "lumped.dist" HSPICE LAYOUT GROUND VSS MASK
PEX REPORT LUMPED none
PEX REPORT DISTRIBUTED none
PEX NETLIST DISTRIBUTED "distributed.dist" HSPICE LAYOUT GROUND VSS MASK
//MASK SVDB DIRECTORY "svdb" QUERY XRC
LVS PUSH DEVICES YES
LVS PUSH DEVICES SEPARATE PROPERTIES YES AGF
lvs netlist property mom_4t_ckt nn mm tm bm l
lvs netlist property mom_5t_ckt nn mm tm bm l
lvs netlist property mom33_4t_ckt nn mm tm bm l
lvs netlist property mom33_5t_ckt nn mm tm bm l
lvs netlist property mom50_4t_ckt nn mm tm bm l
lvs netlist property mom50_5t_ckt nn mm tm bm l
MASK SVDB DIRECTORY "svdb" QUERY CCI
#ELSE
MASK SVDB DIRECTORY "svdb" QUERY
#ENDIF

ERC MAXIMUM RESULTS 100
ERC RESULTS DATABASE erc.db
ERC SUMMARY REPORT erc.rep
FLAG SKEW YES
FLAG OFFGRID YES
LVS ISOLATE SHORTS YES
LVS SPICE PREFER PINS          YES
LVS SPICE REPLICATE DEVICES    YES // added due to solve 'RC == issue'
LVS SPICE STRICT WL            YES
LVS RECOGNIZE GATES            NONE
LVS ABORT ON SUPPLY ERROR      NO
LVS ALL CAPACITOR PINS SWAPPABLE NO
LVS IGNORE PORTS               NO
LVS CHECK PORT NAMES           YES
LVS REDUCE PARALLEL BIPOLAR    YES
LVS REDUCE PARALLEL MOS        YES [ TOLERANCE L 0 ]
LVS REDUCE PARALLEL DIODES     YES
LVS REDUCE PARALLEL CAPACITORS YES
LVS REDUCE PARALLEL RESISTORS  YES 
LVS REDUCE SERIES RESISTORS    YES
LVS REDUCE SERIES CAPACITORS   YES
LVS REDUCE SPLIT GATES         YES 
LVS FILTER UNUSED OPTION AB RC RE RG
LVS PROPERTY RESOLUTION MAXIMUM 65536
LAYOUT BASE LAYER iAA SN SP iGT CT NW iMOMDMY
LVS SPICE MULTIPLIER NAME "M" "MR" "MM" //special multipler factor name
VIRTUAL CONNECT COLON YES // Please set to "NO" when running full chip level.
//VIRTUAL CONNECT NAME "?"

LVS GROUND NAME "VSS" "SAVSS?" "?gnd?" "?GND?" "?VSS?" "?vss?"
LVS POWER  NAME "VDD" "SAVDD?" "?VDD?" "?VCC?" "?vcc?" "?vdd?"

