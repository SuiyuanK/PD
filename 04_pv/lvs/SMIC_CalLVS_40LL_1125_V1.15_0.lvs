DEVICE nld50ll_ckt nld50ll_gate_body nld50ll_d(D) nld50ll_gate(G) nld50ll_s(S)  pwell(B) <ndif> <nld50ll_ad> <nld50ll_gate_body:prop>
       [ PROPERTY W,L,AS,AD,PS,PD,NF,mr
         W1 = PERIM_CO(nld50ll_gate,nld50ll_s)
         W  = W1
         L1 = AREA(nld50ll_gate)/W1
         L  = L1
         NF = count(G)
         AS = 1e-12 * DFM_NUM_VALUE(nld50ll_gate_body:prop,"ar")
         PS = 1e-6 * DFM_NUM_VALUE(nld50ll_gate_body:prop,"pm")
         AD1= AREA(nld50ll_ad)
         AD = AD1
         PD1= PERIMETER(nld50ll_ad)
         PD = PD1
         mr = 1
       ]
CMACRO MOS_REDUCE nld50ll_ckt

