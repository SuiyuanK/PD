mom14reg_mes_4t = (((mom14reg_mes NOT INTERACT RFDEV) NOT INTERACT RF3T) NOT INTERACT MOM33) NOT INTERACT MOM50
mom14reg_mes_4t_33 = (((mom14reg_mes NOT INTERACT RFDEV) NOT INTERACT RF3T) INTERACT MOM33) NOT INTERACT MOM50
