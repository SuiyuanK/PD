//*End of Resistor

//*Define MOM Device
MOMDMY = iMOMDMY NOT mom_none_layers

mom_metal1         = metal1a AND MOMDMY
mom_v1             = Via1 AND MOMDMY
V1                 = copy Via1
mom_metal2         = metal2a AND MOMDMY
mom_v2             = Via2 AND MOMDMY
V2                 = copy Via2
mom_metal3         = metal3a AND MOMDMY

nwell_mom1  = nwell enclose MOMDMY
nwell_mom2  = size (nwell and MOMMES) by 0.5 overunder
nwell_mom  = nwell_mom1 OR nwell_mom2
pwell_mom  = pwell NOT (pwell inside MOMDMY)
mom_wips     = GT INTERACT (MOMDMY with text "mom_wips")
mom_wims     = MOMDMY with text "mom_wims"
mom_row = MOMDMY INSIDE MOMROW
mom_col = MOMDMY INSIDE MOMCOL

#IFDEF TOPMETAL 10
#IFDEF TOP_METAL_NUM double
mom_v3     = Via3 AND MOMDMY
V3         = copy Via3
mom_metal4 = metal4a AND MOMDMY
mom_metal5 = metal5a AND MOMDMY
mom_v4     = Via4 AND MOMDMY
V4         = copy Via4
mom_metal6 = metal6a AND MOMDMY
mom_v5     = Via5 AND MOMDMY
V5         = copy Via5
mom_metal7 = metal7a AND MOMDMY
mom_v6     = Via6 AND MOMDMY
V6         = copy Via6
mom_metal8 = metal8a AND MOMDMY
mom_v7     = Via7 AND MOMDMY
V7         = copy Via7

//----------MOM12--------------------------
mom12reg_1 = MOMDMY with text "momcap12"
mom12tt    = (mom_metal1 AND mom_metal2) INTERACT mom12reg_1
mom12f     = mom12tt NOT INTERACT mom_v1 
mom12_via  = copy mom_v1 
mom12reg_2= (EXTENTS (SIZE (mom12f AND mom12reg_1) BY 0.1 INSIDE OF MOMDMY)) NOT INTERACT MOMMES
mom12reg   = ((mom12reg_2 AND MOMDMY )  NOT INTERACT RF3T ) NOT INTERACT RFDEV

mom12reg_3t_nw = ((((mom12reg_2 AND RF3T) AND nwell_mom ) NOT INTERACT RFDEV) NOT INTERACT mom_wips) NOT INTERACT mom_wims
mom12reg_3t_pw = ((((mom12reg_2 AND RF3T) NOT INTERACT nwell_mom ) NOT INTERACT RFDEV) NOT INTERACT mom_wips) NOT INTERACT mom_wims
mom12reg_3t_wips = (((mom12reg_2 AND RF3T) NOT INTERACT RFDEV) AND mom_wips) NOT INTERACT mom_wims

mom_terminal12 = (((mom12tt INTERACT mom12reg_2) ENCLOSE mom12_via ) NOT MOMP1) NOT MOMP2
                    
mom12reg_mes    = (MOMMES ENCLOSE mom12tt) interact mom12reg_1
mom12reg_mes_4t = (mom12reg_mes NOT INTERACT RFDEV) NOT INTERACT RF3T
mom12reg_mes_5t = (((mom12reg_mes NOT INTERACT RFDEV) INTERACT RF3T) NOT INTERACT mom_wips) NOT INTERACT mom_wims
mom12reg_mes_5t_nw = mom12reg_mes_5t AND nwell_mom
mom12reg_mes_5t_pw = mom12reg_mes_5t NOT nwell_mom
mom12reg_mes_5t_wips = (((mom12reg_mes NOT INTERACT RFDEV) INTERACT RF3T) INTERACT mom_wips) NOT INTERACT mom_wims
mom12reg_mes_5t_wims = (((mom12reg_mes NOT INTERACT RFDEV) INTERACT RF3T) NOT INTERACT mom_wips) INTERACT mom_wims

mom_terminal12_one = (mom12tt AND MOMP1) ENCLOSE mom_v1
mom_terminal12_two = (mom12tt AND MOMP2) ENCLOSE mom_v1
               

//----------MOM13--------------------------
mom13reg_1 = MOMDMY with text "momcap13"
mom13tt    = ((mom_metal1 AND mom_metal2) AND mom_metal3) INTERACT mom13reg_1
mom13f     = mom13tt NOT INTERACT ( mom_v1 OR mom_v2) 
mom13_via  = mom_v1 AND mom_v2
mom13reg_2 = (EXTENTS (SIZE (mom13f AND mom13reg_1) BY 0.1 INSIDE OF MOMDMY)) NOT INTERACT MOMMES

mom13reg_3 = (EXTENTS (SIZE (mom13f AND mom13reg_1) BY 0.09 INSIDE OF MOMDMY)) NOT INTERACT MOMMES
mom13reg_4 = (EXTENTS (SIZE (mom13f AND mom13reg_1) BY 0.18 INSIDE OF MOMDMY)) NOT INTERACT MOMMES
mom13reg   = ((((mom13reg_2 AND MOMDMY) NOT INTERACT RF3T ) NOT INTERACT RFDEV ) NOT INTERACT MOM33) NOT INTERACT MOM50
mom13reg_33   = ((((mom13reg_3 AND MOMDMY) NOT INTERACT RF3T ) NOT INTERACT RFDEV ) AND MOM33) NOT INTERACT MOM50
mom13reg_50   = ((((mom13reg_4 AND MOMDMY) NOT INTERACT RF3T ) NOT INTERACT RFDEV ) AND MOM50) NOT INTERACT MOM33

mom13reg_3t_nw = ((((((mom13reg_2 AND RF3T) AND nwell_mom) NOT INTERACT RFDEV) NOT INTERACT mom_wips) NOT INTERACT mom_wims) NOT INTERACT MOM33) NOT INTERACT MOM50
mom13reg_3t_nw_33 = ((((((mom13reg_3 AND RF3T) AND nwell_mom) NOT INTERACT RFDEV) NOT INTERACT mom_wips) NOT INTERACT mom_wims) AND MOM33) NOT INTERACT MOM50
mom13reg_3t_nw_50 = ((((((mom13reg_4 AND RF3T) AND nwell_mom) NOT INTERACT RFDEV) NOT INTERACT mom_wips) NOT INTERACT mom_wims) AND MOM50) NOT INTERACT MOM33
mom13reg_3t_pw = ((((((mom13reg_2 AND RF3T) NOT INTERACT nwell_mom) NOT INTERACT RFDEV) NOT INTERACT mom_wips) NOT INTERACT mom_wims) NOT INTERACT MOM33) NOT INTERACT MOM50
mom13reg_3t_pw_33 = ((((((mom13reg_3 AND RF3T) NOT INTERACT nwell_mom) NOT INTERACT RFDEV) NOT INTERACT mom_wips) NOT INTERACT mom_wims) AND MOM33) NOT INTERACT MOM50
mom13reg_3t_pw_50 = ((((((mom13reg_4 AND RF3T) NOT INTERACT nwell_mom) NOT INTERACT RFDEV) NOT INTERACT mom_wips) NOT INTERACT mom_wims) AND MOM50) NOT INTERACT MOM33
mom13reg_3t_wips = (((((mom13reg_2 AND RF3T) NOT INTERACT RFDEV) AND mom_wips) NOT INTERACT mom_wims) NOT INTERACT MOM33) NOT INTERACT MOM50
mom13reg_3t_wips_33 = (((((mom13reg_3 AND RF3T) NOT INTERACT RFDEV) AND mom_wips) NOT INTERACT mom_wims) AND MOM33) NOT INTERACT MOM50
mom13reg_3t_wips_50 = (((((mom13reg_4 AND RF3T) NOT INTERACT RFDEV) AND mom_wips) NOT INTERACT mom_wims) AND MOM50) NOT INTERACT MOM33

mom_terminal13 = (((mom13tt INTERACT ((mom13reg_2 or mom13reg_3) or mom13reg_4)) ENCLOSE mom13_via) NOT MOMP1) NOT MOMP2

mom13reg_mes    = (MOMMES ENCLOSE mom13tt) interact mom13reg_1
mom13reg_mes_4t = (((mom13reg_mes NOT INTERACT RFDEV) NOT INTERACT RF3T) NOT INTERACT MOM33) NOT INTERACT MOM50
mom13reg_mes_4t_33 = (((mom13reg_mes NOT INTERACT RFDEV) NOT INTERACT RF3T) INTERACT MOM33) NOT INTERACT MOM50
mom13reg_mes_4t_50 = (((mom13reg_mes NOT INTERACT RFDEV) NOT INTERACT RF3T) INTERACT MOM50) NOT INTERACT MOM33
mom13reg_mes_5t = (((mom13reg_mes NOT INTERACT RFDEV) INTERACT RF3T) NOT INTERACT mom_wips) NOT INTERACT mom_wims
mom13reg_mes_5t_nw = ((mom13reg_mes_5t AND nwell_mom) NOT INTERACT MOM33) NOT INTERACT MOM50
mom13reg_mes_5t_nw_33 = ((mom13reg_mes_5t AND nwell_mom) INTERACT MOM33) NOT INTERACT MOM50
mom13reg_mes_5t_nw_50 = ((mom13reg_mes_5t AND nwell_mom) INTERACT MOM50) NOT INTERACT MOM33
mom13reg_mes_5t_pw = ((mom13reg_mes_5t NOT nwell_mom) NOT INTERACT MOM33) NOT INTERACT MOM50
mom13reg_mes_5t_pw_33 = ((mom13reg_mes_5t NOT nwell_mom) INTERACT MOM33) NOT INTERACT MOM50
mom13reg_mes_5t_pw_50 = ((mom13reg_mes_5t NOT nwell_mom) INTERACT MOM50) NOT INTERACT MOM33

mom13reg_mes_5t_wips = (((((mom13reg_mes NOT INTERACT RFDEV) INTERACT RF3T) INTERACT mom_wips) NOT INTERACT mom_wims) NOT INTERACT MOM33) NOT INTERACT MOM50
mom13reg_mes_5t_wips_33 = (((((mom13reg_mes NOT INTERACT RFDEV) INTERACT RF3T) INTERACT mom_wips) NOT INTERACT mom_wims) INTERACT MOM33) NOT INTERACT MOM50
mom13reg_mes_5t_wips_50 = (((((mom13reg_mes NOT INTERACT RFDEV) INTERACT RF3T) INTERACT mom_wips) NOT INTERACT mom_wims) INTERACT MOM50) NOT INTERACT MOM33
mom13reg_mes_5t_wims = (((((mom13reg_mes NOT INTERACT RFDEV) INTERACT RF3T) NOT INTERACT mom_wips) INTERACT mom_wims) NOT INTERACT MOM33) NOT INTERACT MOM50
mom13reg_mes_5t_wims_33 = (((((mom13reg_mes NOT INTERACT RFDEV) INTERACT RF3T) NOT INTERACT mom_wips) INTERACT mom_wims) INTERACT MOM33) NOT INTERACT MOM50
mom13reg_mes_5t_wims_50 = (((((mom13reg_mes NOT INTERACT RFDEV) INTERACT RF3T) NOT INTERACT mom_wips) INTERACT mom_wims) INTERACT MOM50) NOT INTERACT MOM33

mom_terminal13_one = ((mom13tt AND MOMP1) ENCLOSE mom_v1) ENCLOSE mom_v2
mom_terminal13_two = ((mom13tt AND MOMP2) ENCLOSE mom_v1) ENCLOSE mom_v2
//----------MOM23--------------------------
mom23reg_1 = MOMDMY with text "momcap23"
mom23tt    = (mom_metal2 AND mom_metal3) INTERACT mom23reg_1
mom23f     = mom23tt NOT INTERACT  mom_v2
mom23_via  = copy mom_v2
mom23reg_2= (EXTENTS (SIZE (mom23f AND mom23reg_1) BY 0.1 INSIDE OF MOMDMY)) NOT INTERACT MOMMES

mom23reg_3= (EXTENTS (SIZE (mom23f AND mom23reg_1) BY 0.09 INSIDE OF MOMDMY)) NOT INTERACT MOMMES
mom23reg_4= (EXTENTS (SIZE (mom23f AND mom23reg_1) BY 0.18 INSIDE OF MOMDMY)) NOT INTERACT MOMMES
mom23reg   = ((((mom23reg_2 AND MOMDMY ) NOT INTERACT RF3T ) NOT INTERACT RFDEV) NOT INTERACT MOM33) NOT INTERACT MOM50
mom23reg_33   = ((((mom23reg_3 AND MOMDMY ) NOT INTERACT RF3T ) NOT INTERACT RFDEV) AND MOM33) NOT INTERACT MOM50
mom23reg_50   = ((((mom23reg_4 AND MOMDMY ) NOT INTERACT RF3T ) NOT INTERACT RFDEV) AND MOM50) NOT INTERACT MOM33

mom23reg_3t_nw = ((((((mom23reg_2 AND RF3T) AND nwell_mom) NOT INTERACT RFDEV) NOT INTERACT mom_wips) NOT INTERACT mom_wims) NOT INTERACT MOM33) NOT INTERACT MOM50
mom23reg_3t_nw_33 = ((((((mom23reg_3 AND RF3T) AND nwell_mom) NOT INTERACT RFDEV) NOT INTERACT mom_wips) NOT INTERACT mom_wims) AND MOM33) NOT INTERACT MOM50
mom23reg_3t_nw_50 = ((((((mom23reg_4 AND RF3T) AND nwell_mom) NOT INTERACT RFDEV) NOT INTERACT mom_wips) NOT INTERACT mom_wims) AND MOM50) NOT INTERACT MOM33
mom23reg_3t_pw = ((((((mom23reg_2 AND RF3T) NOT INTERACT nwell_mom) NOT INTERACT RFDEV) NOT INTERACT mom_wips) NOT INTERACT mom_wims) NOT INTERACT MOM33) NOT INTERACT MOM50
mom23reg_3t_pw_33 = ((((((mom23reg_3 AND RF3T) NOT INTERACT nwell_mom) NOT INTERACT RFDEV) NOT INTERACT mom_wips) NOT INTERACT mom_wims) AND MOM33) NOT INTERACT MOM50
mom23reg_3t_pw_50 = ((((((mom23reg_4 AND RF3T) NOT INTERACT nwell_mom) NOT INTERACT RFDEV) NOT INTERACT mom_wips) NOT INTERACT mom_wims) AND MOM50) NOT INTERACT MOM33
mom23reg_3t_wips = (((((mom23reg_2 AND RF3T) NOT INTERACT RFDEV) AND mom_wips) NOT INTERACT mom_wims) NOT INTERACT MOM33) NOT INTERACT MOM50
mom23reg_3t_wips_33 = (((((mom23reg_3 AND RF3T) NOT INTERACT RFDEV) AND mom_wips) NOT INTERACT mom_wims) AND MOM33) NOT INTERACT MOM50
mom23reg_3t_wips_50 = (((((mom23reg_4 AND RF3T) NOT INTERACT RFDEV) AND mom_wips) NOT INTERACT mom_wims) AND MOM50) NOT INTERACT MOM33
mom23reg_3t_wims = ((((((mom23reg_2 AND RF3T) NOT INTERACT RFDEV) NOT INTERACT mom_wips) INTERACT mom_wims) INTERACT metal1) NOT INTERACT MOM33) NOT INTERACT MOM50
mom23reg_3t_wims_33 = ((((((mom23reg_3 AND RF3T) NOT INTERACT RFDEV) NOT INTERACT mom_wips) INTERACT mom_wims) INTERACT metal1) AND MOM33) NOT INTERACT MOM50
mom23reg_3t_wims_50 = ((((((mom23reg_4 AND RF3T) NOT INTERACT RFDEV) NOT INTERACT mom_wips) INTERACT mom_wims) INTERACT metal1) AND MOM50) NOT INTERACT MOM33

mom_terminal23 = (((mom23tt INTERACT ((mom23reg_2 or mom23reg_3) or mom23reg_4)) ENCLOSE mom23_via) NOT MOMP1) NOT MOMP2

mom23reg_mes    = (MOMMES ENCLOSE mom23tt) interact mom23reg_1
mom23reg_mes_4t = (((mom23reg_mes NOT INTERACT RFDEV) NOT INTERACT RF3T) NOT INTERACT MOM33) NOT INTERACT MOM50
mom23reg_mes_4t_33 = (((mom23reg_mes NOT INTERACT RFDEV) NOT INTERACT RF3T) INTERACT MOM33) NOT INTERACT MOM50
mom23reg_mes_4t_50 = (((mom23reg_mes NOT INTERACT RFDEV) NOT INTERACT RF3T) INTERACT MOM50) NOT INTERACT MOM33
mom23reg_mes_5t = (((mom23reg_mes NOT INTERACT RFDEV) INTERACT RF3T) NOT INTERACT mom_wips) NOT INTERACT mom_wims
mom23reg_mes_5t_nw = ((mom23reg_mes_5t AND nwell_mom) NOT INTERACT MOM33) NOT INTERACT MOM50
mom23reg_mes_5t_nw_33 = ((mom23reg_mes_5t AND nwell_mom) INTERACT MOM33) NOT INTERACT MOM50
mom23reg_mes_5t_nw_50 = ((mom23reg_mes_5t AND nwell_mom) INTERACT MOM50) NOT INTERACT MOM33
mom23reg_mes_5t_pw =((mom23reg_mes_5t NOT nwell_mom) NOT INTERACT MOM33) NOT INTERACT MOM50
mom23reg_mes_5t_pw_33 =((mom23reg_mes_5t NOT nwell_mom) INTERACT MOM33) NOT INTERACT MOM50
mom23reg_mes_5t_pw_50 =((mom23reg_mes_5t NOT nwell_mom) INTERACT MOM50) NOT INTERACT MOM33
mom23reg_mes_5t_wips = (((((mom23reg_mes NOT INTERACT RFDEV) INTERACT RF3T) INTERACT mom_wips) NOT INTERACT mom_wims) NOT INTERACT MOM33) NOT INTERACT MOM50
mom23reg_mes_5t_wips_33 = (((((mom23reg_mes NOT INTERACT RFDEV) INTERACT RF3T) INTERACT mom_wips) NOT INTERACT mom_wims) INTERACT MOM33) NOT INTERACT MOM50
mom23reg_mes_5t_wips_50 = (((((mom23reg_mes NOT INTERACT RFDEV) INTERACT RF3T) INTERACT mom_wips) NOT INTERACT mom_wims) INTERACT MOM50) NOT INTERACT MOM33
mom23reg_mes_5t_wims = (((((mom23reg_mes NOT INTERACT RFDEV) INTERACT RF3T) NOT INTERACT mom_wips) INTERACT mom_wims) NOT INTERACT MOM33) NOT INTERACT MOM50
mom23reg_mes_5t_wims_33 = (((((mom23reg_mes NOT INTERACT RFDEV) INTERACT RF3T) NOT INTERACT mom_wips) INTERACT mom_wims) INTERACT MOM33) NOT INTERACT MOM50
mom23reg_mes_5t_wims_50 = (((((mom23reg_mes NOT INTERACT RFDEV) INTERACT RF3T) NOT INTERACT mom_wips) INTERACT mom_wims) INTERACT MOM50) NOT INTERACT MOM33

mom_terminal23_one = (mom23tt AND MOMP1) ENCLOSE mom_v2
mom_terminal23_two = (mom23tt AND MOMP2) ENCLOSE mom_v2
               
//----------MOM14--------------------------
mom14reg_1 = MOMDMY with text "momcap14"
mom14tt    = (((mom_metal1 AND mom_metal2) AND mom_metal3) AND mom_metal4) INTERACT mom14reg_1
mom14f     = mom14tt NOT INTERACT (( mom_v1 OR mom_v2) OR mom_v3)
mom14_via  = (mom_v1 AND mom_v2) AND mom_v3
mom14reg_2= (EXTENTS (SIZE (mom14f AND mom14reg_1) BY 0.1 INSIDE OF MOMDMY)) NOT INTERACT MOMMES

mom14reg_3= (EXTENTS (SIZE (mom14f AND mom14reg_1) BY 0.09 INSIDE OF MOMDMY)) NOT INTERACT MOMMES
mom14reg_4= (EXTENTS (SIZE (mom14f AND mom14reg_1) BY 0.18 INSIDE OF MOMDMY)) NOT INTERACT MOMMES
mom14reg   = ((((mom14reg_2 AND MOMDMY )  NOT INTERACT RF3T ) NOT INTERACT RFDEV) NOT INTERACT MOM33) NOT INTERACT MOM50
mom14reg_33   = ((((mom14reg_3 AND MOMDMY )  NOT INTERACT RF3T ) NOT INTERACT RFDEV) AND MOM33) NOT INTERACT MOM50
mom14reg_50   = ((((mom14reg_4 AND MOMDMY )  NOT INTERACT RF3T ) NOT INTERACT RFDEV) AND MOM50) NOT INTERACT MOM33

mom14reg_3t_nw = ((((((mom14reg_2 AND RF3T) AND nwell_mom ) NOT INTERACT RFDEV) NOT INTERACT mom_wips) NOT INTERACT mom_wims) NOT INTERACT MOM33) NOT INTERACT MOM50
mom14reg_3t_nw_33 = ((((((mom14reg_3 AND RF3T) AND nwell_mom ) NOT INTERACT RFDEV) NOT INTERACT mom_wips) NOT INTERACT mom_wims) AND MOM33) NOT INTERACT MOM50
mom14reg_3t_nw_50 = ((((((mom14reg_4 AND RF3T) AND nwell_mom ) NOT INTERACT RFDEV) NOT INTERACT mom_wips) NOT INTERACT mom_wims) AND MOM50) NOT INTERACT MOM33
mom14reg_3t_pw = ((((((mom14reg_2 AND RF3T) NOT INTERACT nwell_mom ) NOT INTERACT RFDEV) NOT INTERACT mom_wips) NOT INTERACT mom_wims) NOT INTERACT MOM33) NOT INTERACT MOM50
mom14reg_3t_pw_33 = ((((((mom14reg_3 AND RF3T) NOT INTERACT nwell_mom ) NOT INTERACT RFDEV) NOT INTERACT mom_wips) NOT INTERACT mom_wims) AND MOM33) NOT INTERACT MOM50
mom14reg_3t_pw_50 = ((((((mom14reg_4 AND RF3T) NOT INTERACT nwell_mom ) NOT INTERACT RFDEV) NOT INTERACT mom_wips) NOT INTERACT mom_wims) AND MOM50) NOT INTERACT MOM33
mom14reg_3t_wips = (((((mom14reg_2 AND RF3T) NOT INTERACT RFDEV) AND mom_wips) NOT INTERACT mom_wims) NOT INTERACT MOM33) NOT INTERACT MOM50
mom14reg_3t_wips_33 = (((((mom14reg_3 AND RF3T) NOT INTERACT RFDEV) AND mom_wips) NOT INTERACT mom_wims) AND MOM33) NOT INTERACT MOM50
mom14reg_3t_wips_50 = (((((mom14reg_4 AND RF3T) NOT INTERACT RFDEV) AND mom_wips) NOT INTERACT mom_wims) AND MOM50) NOT INTERACT MOM33

mom_terminal14 = (((mom14tt INTERACT ((mom14reg_2 or mom14reg_3) or mom14reg_4)) ENCLOSE mom14_via) NOT MOMP1) NOT MOMP2
                    
