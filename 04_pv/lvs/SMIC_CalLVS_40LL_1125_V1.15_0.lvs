rm1_2t        =(M1 AND M1R) NOT RESP3T
rm1_3t        =(M1 AND M1R) AND RESP3T
rm1_3t_nwell  =rm1_3t AND nwell
rm1_3t_pwell  =rm1_3t NOT nwell
metal1a       =M1 NOT M1R
rm2_2t        =(M2 AND M2R) NOT RESP3T
rm2_3t        =(M2 AND M2R) AND RESP3T
rm2_3t_nwell  =rm2_3t AND nwell
rm2_3t_pwell  =rm2_3t NOT nwell
metal2a       =M2 NOT M2R
rm3_2t        =(M3 AND M3R) NOT RESP3T
rm3_3t        =(M3 AND M3R) AND RESP3T
rm3_3t_nwell  =rm3_3t AND nwell
rm3_3t_pwell  =rm3_3t NOT nwell
metal3a       =M3 NOT M3R
rm4_2t        =(M4 AND M4R) NOT RESP3T
rm4_3t        =(M4 AND M4R) AND RESP3T
rm4_3t_nwell  =rm4_3t AND nwell
rm4_3t_pwell  =rm4_3t NOT nwell
metal4a       =M4 NOT M4R

#IFDEF TM_METAL_TYPE 0
rm5_2t        =((TM2 AND TM2R) NOT RESP3T ) NOT RFDEV
rm5_3t        =((TM2 AND TM2R) AND RESP3T ) NOT RFDEV
rm5_3t_nwell  =(rm5_3t AND nwell ) NOT RFDEV
rm5_3t_pwell  =(rm5_3t NOT nwell ) NOT RFDEV
metal5a       =(TM2 NOT TM2R) OR TM2DUM  //
#ENDIF

#IFDEF TM_METAL_TYPE 1
rm5_2t        =((MTT2 AND TM2R) NOT RESP3T ) NOT RFDEV
rm5_3t        =((MTT2 AND TM2R) AND RESP3T ) NOT RFDEV
rm5_3t_nwell  =(rm5_3t AND nwell ) NOT RFDEV
rm5_3t_pwell  =(rm5_3t NOT nwell ) NOT RFDEV
metal5a       = MTT2 NOT TM2R  //
#ENDIF
#ENDIF

#IFDEF TOP_METAL_NUM double
rm1_2t        =(M1 AND M1R) NOT RESP3T
rm1_3t        =(M1 AND M1R) AND RESP3T
