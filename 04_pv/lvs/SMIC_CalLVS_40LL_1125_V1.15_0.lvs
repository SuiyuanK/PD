DMACRO MOS_PRO_MIS_LPE fet_seed sd_seed proclayer1 proclayer2 proclayer3 proclayer4 proclayer5 type{
       [ PROPERTY W,L,AS,AD,PS,PD,SA,SB,SD,SCA,SCB,SCC,NRS,NRD,DPS,DSTS,DPCS,PRELAYOUT,DCN,LPEMOD,MISMOD,globalmod,nf,mr
	 W = PERIM_CO(fet_seed,sd_seed)/2
	 L = AREA(fet_seed)/W  
         A = 5E-06
         PER_S = perimeter_inside(SRC,proclayer1)
         PER_D = perimeter_inside(DRN,proclayer1)
         IF(PER_S==0) {
           AD = AREA(DRN)*W/PER_D
           PD = perimeter(DRN)*W/PER_D
           AS = AD
           PS = PD
         }ELSE IF(PER_D==0){
            AS=AREA(SRC)*W/PER_S
            PS =perimeter(SRC)*W/PER_S
            AD =AS
            PD =PS
         }ELSE{
            AD=AREA(DRN)*W/PER_D
            PD = perimeter(DRN)*W/PER_D
            AS = AREA(SRC)*W/PER_S
            PS = perimeter(SRC)*W/PER_S
         }
     //LOD parameters
        LOD_1 = DFM_VEC_VAL( proclayer5, "PER_1" )
        LOD_2 = DFM_VEC_VAL( proclayer5, "PER_2" )

        sa =  TVF_NUM_FUN( "calc_lod_dfm", "device_function", LOD_1, W,L )
        sb =  TVF_NUM_FUN( "calc_lod_dfm", "device_function", LOD_2, W,L )
        sd = 0

         PRELAYOUT = 0
         DCN = 0 
         nf = 1 
         mr = 1 
       #IFDEF MOS_MISMOD 0
         MISMOD = 0
       #ENDIF  
       #IFDEF MOS_MISMOD 1
         MISMOD = 1
       #ENDIF
       #IFDEF MOS_GLOBALMOD 0
         globalmod = 0
       #ENDIF
       #IFDEF MOS_GLOBALMOD 1
         globalmod = 1
       #ENDIF
       #IFDEF MOS_LPEMOD 0
         LPEMOD = 0
       #ENDIF
       #IFDEF MOS_LPEMOD 1
         LPEMOD = 1
       #ENDIF

// Well proximity.
   SCH_1 = DFM_VEC_VAL( proclayer3, "PER_1" )
   SCH_2 = DFM_VEC_VAL( proclayer3, "PER_2" )
   SCV_1 = DFM_VEC_VAL( proclayer3, "PAR_1" )
   SCV_2 = DFM_VEC_VAL( proclayer3, "PAR_2" )
   SCA = TVF_NUM_FUN( "calc_sca_dfm", "device_function", SCH_1, SCH_2, SCV_1, SCV_2, W, L, UNIT_LENGTH() )
   SCB = TVF_NUM_FUN( "calc_scb_dfm", "device_function", SCH_1, SCH_2, SCV_1, SCV_2, W, L, UNIT_LENGTH() )
   SCC = TVF_NUM_FUN( "calc_scc_dfm", "device_function", SCH_1, SCH_2, SCV_1, SCV_2, W, L, UNIT_LENGTH() )
// LPE effect
   G2P_S_V     = DFM_VEC_ARR(proclayer4,"G2P_S")
   G2P_D_V     = DFM_VEC_ARR(proclayer4,"G2P_D")
   G2G_V       = DFM_VEC_ARR(proclayer4,"G2G")
   CT_NUM_S    = DFM_NUM_VAL(proclayer4, "CT_NUM_S")
   CT_NUM_D    = DFM_NUM_VAL(proclayer4, "CT_NUM_D")
   G2CT_S_V    = DFM_VEC_ARR(proclayer4,"G2CT_S")
   G2CT_D_V    = DFM_VEC_ARR(proclayer4,"G2CT_D")
   G2AA_S      = DFM_VEC_VAL(proclayer4,"G2AA_S")
   G2AA_D      = DFM_VEC_VAL(proclayer4,"G2AA_D")
   DPCS        = TVF_NUM_FUN("GET_DPCS","device_function",G2CT_S_V,G2CT_D_V,type)
   DSTS        = TVF_NUM_FUN("GET_DSTS","device_function",G2AA_S,G2AA_D,W,type)
   DPS         = TVF_NUM_FUN("GET_DPS","device_function",G2P_S_V,G2P_D_V,G2G_V,W,L,1,type)
   NRS         = AS/(W*W)
   NRD         = AD/(W*W)
   ]
}

DMACRO MOS_PRO_MIS_WPE fet_seed sd_seed proclayer1 proclayer2 proclayer3 proclayer4 proclayer5 type{
       [ PROPERTY W,L,AS,AD,PS,PD,SA,SB,SD,NRS,NRD,PRELAYOUT,DCN,MISMOD,globalmod,nf,mr
	 W = PERIM_CO(fet_seed,sd_seed)/2
	 L = AREA(fet_seed)/W
         A = 5E-06
         PER_S = perimeter_inside(SRC,proclayer1)
         PER_D = perimeter_inside(DRN,proclayer1)
         IF(PER_S==0) {
           AD = AREA(DRN)*W/PER_D
           PD = perimeter(DRN)*W/PER_D
           AS = AD
           PS = PD
         }ELSE IF(PER_D==0){
            AS=AREA(SRC)*W/PER_S
            PS =perimeter(SRC)*W/PER_S
            AD =AS
            PD =PS
         }ELSE{
            AD=AREA(DRN)*W/PER_D
            PD = perimeter(DRN)*W/PER_D
            AS = AREA(SRC)*W/PER_S
            PS = perimeter(SRC)*W/PER_S
         }
     //LOD parameters
         LOD_1 = DFM_VEC_VAL( proclayer5, "PER_1" )
         LOD_2 = DFM_VEC_VAL( proclayer5, "PER_2" )

         sa =  TVF_NUM_FUN( "calc_lod_dfm", "device_function", LOD_1, W,L )
         sb =  TVF_NUM_FUN( "calc_lod_dfm", "device_function", LOD_2, W,L )
         sd = 0

         PRELAYOUT = 0
         DCN = 0 
         nf = 1 
         mr = 1
       #IFDEF MOS_MISMOD 0
         MISMOD = 0
       #ENDIF
      #IFDEF MOS_MISMOD 1
         MISMOD = 1
       #ENDIF
      #IFDEF MOS_GLOBALMOD 0
         globalmod = 0
       #ENDIF
      #IFDEF MOS_GLOBALMOD 1
         globalmod = 1
       #ENDIF


// Well proximity.
   SCH_1 = DFM_VEC_VAL( proclayer3, "PER_1" )
   SCH_2 = DFM_VEC_VAL( proclayer3, "PER_2" )
   SCV_1 = DFM_VEC_VAL( proclayer3, "PAR_1" )
   SCV_2 = DFM_VEC_VAL( proclayer3, "PAR_2" )
   SCA = TVF_NUM_FUN( "calc_sca_dfm", "device_function", SCH_1, SCH_2, SCV_1, SCV_2, W, L, UNIT_LENGTH() )
   SCB = TVF_NUM_FUN( "calc_scb_dfm", "device_function", SCH_1, SCH_2, SCV_1, SCV_2, W, L, UNIT_LENGTH() )
   SCC = TVF_NUM_FUN( "calc_scc_dfm", "device_function", SCH_1, SCH_2, SCV_1, SCV_2, W, L, UNIT_LENGTH() )
   NRS         = AS/(W*W)
   NRD         = AD/(W*W)
   ]
}

DMACRO SRAM_PRO fet_seed sd_seed proclayer1 proclayer2 {
       [ PROPERTY W,L,AS,AD,PS,PD,SA,SB,NRS,NRD,SCA,SCB,SCC,mismod,globalmod
         W = PERIM_CO(fet_seed,sd_seed)/2
         L = AREA(fet_seed)/W
         S = ENCLOSURE_VECTOR(proclayer2,5)
         A = 5E-06
         PER_S = perimeter_inside(SRC,proclayer1)
         PER_D = perimeter_inside(DRN,proclayer1)
         IF(PER_S==0) {
           AD = AREA(DRN)*W/PER_D
           PD = perimeter(DRN)*W/PER_D
           AS = AD
           PS = PD
         }ELSE IF(PER_D==0){
            AS=AREA(SRC)*W/PER_S
            PS =perimeter(SRC)*W/PER_S
            AD =AS
            PD =PS
         }ELSE{
            AD=AREA(DRN)*W/PER_D
            PD = perimeter(DRN)*W/PER_D
            AS = AREA(SRC)*W/PER_S
            PS = perimeter(SRC)*W/PER_S
         }
         SA = 0 
         SB = 0
         SCA = 0
         SCB = 0
         SCC = 0

         NRD = 0
         NRS = 0
         #IFDEF SRAM_MISMOD 0
         mismod = 0
         #ENDIF
         #IFDEF SRAM_MISMOD 1
         mismod = 1
         #ENDIF
         #IFDEF SRAM_GLOBALMOD 0
         globalmod = 0
         #ENDIF
         #IFDEF SRAM_GLOBALMOD 1
         globalmod = 1 
         #ENDIF
         ]
}

