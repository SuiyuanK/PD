#IFDEF RC_RUN FALSE
DEVICE nld50ll_ckt nld50ll_gate_body nld50ll_d(D) nld50ll_gate(G) nld50ll_s(S)  pwell(B)
       [ PROPERTY W,L,NF
         W1 = PERIM_CO(nld50ll_gate,nld50ll_s)
         W  = W1
         L1 = AREA(nld50ll_gate)/W1
         L  = L1
         NF = count(G)
       ]
CMACRO MOS_REDUCE nld50ll_ckt

DEVICE pld50ll_ckt pld50ll_gate_body pld50ll_d(D) pld50ll_gate(G) pld50ll_s(S) nwell(B)
       [ PROPERTY W,L,NF
         W1 = PERIM_CO(pld50ll_gate,pld50ll_s)
         W  = W1
         L1 = AREA(pld50ll_gate)/W1
         L  = L1
         NF = count(G)
       ]
CMACRO MOS_REDUCE pld50ll_ckt

