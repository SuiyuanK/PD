rm3_3t        =(M3 AND M3R) AND RESP3T
rm3_3t_nwell  =rm3_3t AND nwell
rm3_3t_pwell  =rm3_3t NOT nwell
metal3a       =M3 NOT M3R

rm4_2t        =(TM1 AND TM1R) NOT RESP3T
rm4_3t        =(TM1 AND TM1R) AND RESP3T
