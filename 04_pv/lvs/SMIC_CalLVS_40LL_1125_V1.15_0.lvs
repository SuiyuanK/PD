//Define MOM 3.3V
DMACRO MOM_PRO_50  mom_finger mom_metal tm_num bm_num {
        [PROPERTY L,NN,TM,BM,MISMOD,flag_width,mm
        NN = count(mom_finger)
        A = AREA(mom_finger)/NN
        W1= perim_in(mom_finger,mom_metal)
        W = W1/NN
        L = A/W+18.0E-08
        TM = tm_num
        BM = bm_num
        flag_width = 0
        mm = 1
        #IFDEF MOM_MISMOD 0
        MISMOD = 0
        #ENDIF
        #IFDEF MOM_MISMOD 1
        MISMOD = 1
        #ENDIF
        ]
}

