//////////////////////////////////////////////
// Loigc Operation                          //
//////////////////////////////////////////////
//*Form Bulk layer
DRC:1   = EXTENT
BULK    = SIZE DRC:1 BY 2.0

//*Define Pwell layer
scut    = SIZE SUBD  BY 0.005
cutring = scut NOT SUBD
wella   = cutring OR NW
pwell   = BULK NOT wella
pwell_wpe_core = ((((SIZE DRC:1 BY 10.000) NOT NW) NOT DG) NOT TG) NOT PSUB
pwell_wpe_IO1   = ((((SIZE DRC:1 BY 10.000) NOT NW) AND DG) NOT TG) NOT PSUB
pwell_wpe_IO2   = ((((SIZE DRC:1 BY 10.000) NOT NW) NOT DG) AND TG) NOT PSUB
//rwell = (NW HOLES INNER) INSIDE DNW
rwella  = (NW HOLES) AND DNW
rwellb  = rwella NOT nwell
rwell   = rwellb NOT cutring
rwell_wpe_core = ((rwell NOT DG) NOT TG) NOT PSUB
rwell_wpe_IO1   = ((rwell AND DG) NOT TG) NOT PSUB
rwell_wpe_IO2   = ((rwell NOT DG) AND TG) NOT PSUB
pwell1  = pwell AND rwell
dnwd_psub = pwell NOT pwell1 
psub_all  = (BULK NOT DNW) NOT cutring
bulk_all  = BULK NOT cutring

ndifi   = AA AND SN
pdifi   = AA AND SP

npoly_1   = GT AND SN //
ppoly_1   = GT AND SP

//*Diffusion Resistor

DIFNOSILI   = (RESAA AND SAB) NOT INTERACT DIFRES
DIFDUMSAB   = RESAA INTERACT SAB
DIFSILI     = (DIFRES NOT DIFDUMSAB) NOT INTERACT SAB

RES_RNDIFSAB_3T_old = ((ndifi AND DIFNOSILI) NOT RFDEV) NOT RESCKT
RES_RNDIFSAB_old    = ((ndifi AND DIFNOSILI) NOT RFDEV) AND RESCKT
RES_RPDIFSAB_3T_old = ((pdifi AND DIFNOSILI) NOT RFDEV) NOT RESCKT
RES_RPDIFSAB_old    = ((pdifi AND DIFNOSILI) NOT RFDEV) AND RESCKT
RES_RNDIF_3T_old = (ndifi AND DIFSILI) NOT RESCKT
RES_RNDIF_old    = (ndifi AND DIFSILI) AND RESCKT
RES_RPDIF_3T_old = (pdifi AND DIFSILI) NOT RESCKT
RES_RPDIF_old    = (pdifi AND DIFSILI) AND RESCKT

ndif_t = (ndifi  NOT RES_RNDIFSAB) NOT RES_RNDIF
pdif_t = (pdifi  NOT RES_RPDIFSAB) NOT RES_RPDIF
ndif   = ((((ndifi  NOT RES_RNDIFSAB) NOT RES_RNDIFSAB_3T) NOT RES_RNDIF_3T) NOT RES_RNDIF) NOT PLDMK //
pdif   = ((((pdifi  NOT RES_RPDIFSAB) NOT RES_RPDIF) NOT RES_RPDIFSAB_3T) NOT RES_RPDIF_3T) NOT PLDMK //


//*Poly Resistor

POLYNOSILI  = (RESP1 AND SAB) NOT INTERACT PLRES
POLYDUMSAB  = RESP1 INTERACT SAB
POLYSILI    = (PLRES NOT POLYDUMSAB) NOT INTERACT SAB

RES_RNPOSAB_3T = ((npoly_1 AND POLYNOSILI) NOT RFDEV) NOT RESCKT
RES_RNPOSAB_old    = ((npoly_1 AND POLYNOSILI) NOT RFDEV) AND RESCKT
RES_RNPOSAB_NW_old = RES_RNPOSAB_3T AND nwell
RES_RNPOSAB_PW_old = RES_RNPOSAB_3T NOT nwell

RES_RPPOSAB_3T    = ((ppoly_1 AND POLYNOSILI) NOT RFDEV) NOT RESCKT
RES_RPPOSAB_old       = ((ppoly_1 AND POLYNOSILI) NOT RFDEV) AND RESCKT

RES_RPPOSAB_NW_old    = RES_RPPOSAB_3T AND nwell
RES_RPPOSAB_PW_old    = RES_RPPOSAB_3T NOT nwell 


RES_RNPO_3T       = (npoly_1 AND POLYSILI) NOT RESCKT
RES_RNPO_old          = (npoly_1 AND POLYSILI) AND RESCKT
RES_RNPO_NW_old       = RES_RNPO_3T AND nwell
RES_RNPO_PW_old       = RES_RNPO_3T NOT nwell


RES_RPPO_3T       = (ppoly_1 AND POLYSILI) NOT RESCKT
RES_RPPO_old          = (ppoly_1 AND POLYSILI) AND RESCKT
RES_RPPO_NW_old       = RES_RPPO_3T AND nwell
RES_RPPO_PW_old       = RES_RPPO_3T NOT nwell 


npr = ((((RES_RNPOSAB OR RES_RNPOSAB_NW) OR RES_RNPOSAB_PW) OR RES_RNPO) OR RES_RNPO_NW) OR RES_RNPO_PW
ppr = ((((RES_RPPOSAB OR RES_RPPOSAB_NW) OR RES_RPPOSAB_PW) OR RES_RPPO) OR RES_RPPO_NW) OR RES_RPPO_PW

RES_RHRPO_old         = (((((GT AND HRP) AND HRPDMY) AND SAB) NOT RESP3T) NOT RFDEV) INTERACT SP
RES_RHRPO_3T      = (((((GT AND HRP) AND HRPDMY) AND SAB) AND RESP3T) NOT RFDEV ) INTERACT SP
RES_RHRPO_3T_NW_old   = RES_RHRPO_3T AND nwell
RES_RHRPO_3T_PW_old   = RES_RHRPO_3T NOT nwell 

rpoly    = ((((npr OR ppr) OR RES_RHRPO) OR RES_RHRPO_3T_NW) OR RES_RHRPO_3T_PW ) OR efgate
poly1    = GT  NOT rpoly

efpoly1 = GT AND EFUSE
efpoly2 = efpoly1 INTERACT CT 
efgate_old  = efpoly2 AND GTFUSE 

//*NWELL Resistor
nwr     = NW AND RESNW
sabaa   = aa AND sab
RES_RNWAA_3T_old   = (nwr AND sabaa) NOT RESCKT
RES_RNWAA_old      = (nwr AND sabaa) AND RESCKT
RES_RNWSTI_3T_old  = ((nwr NOT sabaa) AND DUMBA) NOT RESCKT 
RES_RNWSTI_old     = ((nwr NOT sabaa) AND DUMBA) AND RESCKT 

nwell   = NW not nwr
nwell_wpe_core = ((nwell NOT DG) NOT TG) NOT PSUB
nwell_wpe_IO1   = ((nwell AND DG) NOT TG) NOT PSUB
nwell_wpe_IO2   = ((nwell NOT DG) AND TG) NOT PSUB

//*Metal Resistor
iALPA2 = iALPA OR iALPADUM
ALPA   = iALPA2 NOT ALPAR

alpa_res_2t       = (iALPA2 AND ALPAR) NOT RESP3T
alpa_res_3t       = (iALPA2 AND ALPAR) AND RESP3T
alpa_res_3t_nwell = alpa_res_3t AND nwell
alpa_res_3t_pwell = alpa_res_3t NOT nwell
//ALPA_NORES        = iALPA2 NOT ALPAR

