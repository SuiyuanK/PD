//Define Resistor
DMACRO RES_REDUCE device_name {
       LVS REDUCE device_name SERIES PLUS MINUS yes
        [TOLERANCE W 0
         effective L,W
         P = sum ( W * L ) 
         Q = sum ( L / W ) 
         L = sqrt( P * Q )
         W = sqrt( P / Q )
       ]
       LVS REDUCE device_name PARALLEL yes
        [TOLERANCE L 0
         effective L,W
         P = sum ( W * L ) 
         Q = sum ( W / L )
         L = sqrt( P / Q )
         W = sqrt( P * Q )
       ]
}

DMACRO RES_PRO_FLAG_MIS res_seed res_ter rsh_value dw_value dl_value {
       #IFDEF BACK_ANNOTATION_FLOW 1
       [PROPERTY W,L,MISMOD,flag_cc,FR,MR
       #ENDIF
       #IFDEF BACK_ANNOTATION_FLOW 2
       [PROPERTY W,L,MISMOD,flag_cc,MR
       #ENDIF
       W = PERIM_CO(res_seed,res_ter)/2
       L = AREA(res_seed)/W
       flag_cc = 0
       RS    = rsh_value
       DW    = dw_value
       DL    = dl_value
       R     = (L*0.9-2*DL)*RS/(W*0.9-2*DW)
       FR    = R
       MR    = 1
       #IFDEF RES_MISMOD 0
       MISMOD = 0
       #ELSE
        #IFDEF RES_MISMOD 1
       MISMOD = 1
       #ENDIF
       #ENDIF
       ]
}

DMACRO RES_PRO_MIS res_seed res_ter rsh_value dw_value dl_value {
       #IFDEF BACK_ANNOTATION_FLOW 1
       [PROPERTY W,L,MISMOD,FR,MR
       #ENDIF
       #IFDEF BACK_ANNOTATION_FLOW 2
       [PROPERTY W,L,MISMOD,MR
       #ENDIF
       W = PERIM_CO(res_seed,res_ter)/2
       L = AREA(res_seed)/W
       RS    = rsh_value
       DW    = dw_value
       DL    = dl_value
       R     = (L*0.9-2*DL)*RS/(W*0.9-2*DW)
       FR    = R
       MR    = 1
       #IFDEF RES_MISMOD 0
       MISMOD = 0
       #ELSE
        #IFDEF RES_MISMOD 1
       MISMOD = 1
       #ENDIF
       #ENDIF
       ]
}

DMACRO RES_PRO_FLAG res_seed res_ter rsh_value dw_value dl_value {
       #IFDEF BACK_ANNOTATION_FLOW 1
       [PROPERTY W,L,flag_cc,FR,MR
       #ENDIF
       #IFDEF BACK_ANNOTATION_FLOW 2
       [PROPERTY W,L,flag_cc,MR
       #ENDIF
       W = PERIM_CO(res_seed,res_ter)/2
       L = AREA(res_seed)/W
       flag_cc = 0
       RS    = rsh_value
       DW    = dw_value
       DL    = dl_value
       R     = (L*0.9-2*DL)*RS/(W*0.9-2*DW)
       FR    = R
       MR    = 1
       ]
}

DMACRO RES_PRO res_seed res_ter rsh_value dw_value dl_value {
       #IFDEF BACK_ANNOTATION_FLOW 1
       [PROPERTY W,L,FR,MR
       #ENDIF
       #IFDEF BACK_ANNOTATION_FLOW 2
       [PROPERTY W,L,MR
       #ENDIF
       W = PERIM_CO(res_seed,res_ter)/2
       L = AREA(res_seed)/W
       RS    = rsh_value
       DW    = dw_value
       DL    = dl_value
       R     = (L*0.9-2*DL)*RS/(W*0.9-2*DW)
       FR    = R
       MR    = 1
       ]
}

DMACRO RES_PRO_EFUSE res_seed res_ter {
       [PROPERTY W,L,R,MR
       W = PERIM_CO(res_seed,res_ter)/2
       L = AREA(res_seed)/W
       RS=300
       R=(L*0.9*RS)/(W*0.9)
       MR = 1
       ]
}

