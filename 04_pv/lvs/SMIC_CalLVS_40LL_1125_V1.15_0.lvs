//                                                                                                       //
// Device List                                                                                           //
//                                                                                                       //
// NGATE  = AA*GT*SN-NW; PGATE  = AA*GT*SP*NW; CNGATE = AA*GT*SN*NW;                                     //
// CPGATE = AA*GT*SP-NW;                                                                                 //
//                                                                                                       //
// "*" means "AND" and "-" means "NOT"                                                                   //
//                                                                                                       //
// --------------------- ---------------------------- -------------------------                          //
// Device Name           Description                  Device Layer Operation                             //
// --------------------- ---------------------------- -------------------------                          //
// MOSFET                                                                                                //
//                                                                                                       //
// n11ll_ckt     1.1V NMOS         (NGATE-DG-TG-HVT-LVT-ULVT-PSUB-NC-OVERDR-TGV-DNWTR)                   //
// p11ll_ckt     1.1V PMOS         (PGATE-DG-TG-HVT-LVT-ULVT-PSUB-NC-OVERDR-TGV-DNWTR)                   //
// nt11ll_ckt    1.1V Native NMOS  (NGATE-DG-TG*PSUB-HVT-ULVT-LVT-NC-OVERDR-TGV-DNWTR)                   //
// nhvt11ll_ckt  1.1V HVT NMOS     (NGATE-DG-TG*HVT-LVT-ULVT-PSUB-NC-OVERDR-TGV-DNWTR)                   //
// phvt11ll_ckt  1.1V HVT PMOS     (PGATE-DG-TG*HVT-LVT-ULVT-PSUB-NC-OVERDR-TGV-DNWTR)                   //
// nlvt11ll_ckt  1.1V LVT NMOS     (NGATE-DG-TG*LVT-ULVT-HVT-PSUB-NC-OVERDR-TGV-DNWTR)                   //
// plvt11ll_ckt  1.1V LVT PMOS     (PGATE-DG-TG*LVT-ULVT-HVT-PSUB-NC-OVERDR-TGV-DNWTR)                   //
// nulvt11ll_ckt 1.1V ULVT NMOS    (NGATE-DG-TG-LVT*ULVT-HVT-PSUB-NC-OVERDR-TGV-DNWTR)                   //
// pulvt11ll_ckt 1.1V ULVT PMOS    (PGATE-DG-TG-LVT*ULVT-HVT-PSUB-NC-OVERDR-TGV-DNWTR)                   //
// n25ll_ckt     2.5V NMOS         (NGATE-DG*TG-HVT-LVT-ULVT-PSUB-NC-OVERDR-TGV-DNWTR)                   //
// p25ll_ckt     2.5V PMOS         (PGATE-DG*TG-HVT-LVT-ULVT-PSUB-NC-OVERDR-TGV-DNWTR)                   //
// nt25ll_ckt    2.5V Native NMOS  (NGATE-DG*TG*PSUB-HVT-LVT-ULVT-NC-OVERDR-TGV-DNWTR)                   //
// nod33ll_ckt   2.5V od 3.3V NMOS (NGATE-DG*TG*OVERDR-HVT-LVT-ULVT-PSUB-NC-TGV-DNWTR)                   //
// pod33ll_ckt   2.5V od 3.3V PMOS (PGATE-DG*TG*OVERDR-HVT-LVT-ULVT-PSUB-NC-TGV-DNWTR)                   //
// nud18ll_ckt   2.5V ud 1.8V NMOS (NGATE-DG*TG-OVERDR-HVT-LVT-ULVT-PSUB-NC*TGV-DNWTR)                   //
// pud18ll_ckt   2.5V ud 1.8V PMOS (PGATE-DG*TG-OVERDR-HVT-LVT-ULVT-PSUB-NC*TGV-DNWTR)                   //
// ntod33ll_ckt  2.5V od Native NMOS  (NGATE-DG*TG*OVERDR-HVT-LVT-ULVT*PSUB-NC-TGV-DNWTR)                //
// ntud18ll_ckt  2.5V ud Native NMOS  (NGATE-DG*TG-OVERDR-HVT-LVT-ULVT*PSUB-NC*TGV-DNWTR)                //
