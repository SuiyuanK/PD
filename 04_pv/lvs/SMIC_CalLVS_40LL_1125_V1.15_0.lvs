////////////////////////////////////////////////////////////////////////
//*Define Devices                                                     //
////////////////////////////////////////////////////////////////////////
DMACRO MOS_REDUCE device_name {
       LVS REDUCE device_name PARALLEL yes
       [effective L,W
        P = sum( W*L )
        Q = sum( W/L )
        W = sqrt( P*Q )
        L = sqrt ( P/Q )
       ]
}

DMACRO LDMOS_REDUCE device_name {
       LVS REDUCE device_name PARALLEL yes
       [effective LR,WR
        P = sum( WR*LR )
        Q = sum( WR/LR )
        WR = sqrt( P*Q )
        LR = sqrt ( P/Q )
       ]
}

