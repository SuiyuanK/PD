///////////////////////////////End of *Define Inductors* //////////////////////////
ntd1      = ndif AND nwell
ptd1      = pdif AND pwell
dnwd_ptd  = ptd AND dnwd_psub
rwell_ptd = ptd AND rwell
ndiff   = ndif AND pwell
pdiff   = pdif AND nwell

ngate1   = ((((((poly1 AND ndiff) NOT PLDMK) NOT OCCD) NOT OCOVL) NOT VARMOS) NOT NCAP) NOT PCAP
pgate1   = ((((((poly1 AND pdiff) NOT PLDMK) NOT OCCD) NOT OCOVL) NOT VARMOS) NOT NCAP) NOT PCAP
cngate1  = ((poly1 AND ntd1) NOT OCCD) NOT OCOVL
cpgate1  = ((poly1 AND ptd1) NOT OCCD) NOT OCOVL

//TEMPA = AA AND GT 
//TEMP  = AA NOT TEMPA
//ngate = ngate1 touch TEMP==2
//pgate = pgate1 touch TEMP==2
//cngate = cngate1 touch TEMP==2
//cpgate = cpgate1 touch TEMP==2

TEMPA = ndifi AND GT
TEMP_SN = ndifi NOT TEMPA
TEMPB = pdifi AND GT
TEMP_SP = pdifi NOT TEMPB

ngate = ngate1 touch TEMP_SN==2
pgate = pgate1 touch TEMP_SP==2
cngate = cngate1 touch TEMP_SN==2
cpgate = cpgate1 touch TEMP_SP==2

ngate_spec = ngate1 touch (holes ngate1)
pgate_spec = pgate1 touch (holes pgate1)

//poly  = poly1 NOT gate
//poly    = copy poly1

nsd1    = ((ndiff NOT ngate) NOT OCCD) NOT OCOVL
psd1    = ((pdiff NOT pgate) NOT OCCD) NOT OCOVL
//ntd     = (((ntd1  NOT cngate) NOT AADUM) NOT OCCD) NOT OCOVL
//ptd     = (((ptd1  NOT cpgate) NOT AADUM) NOT OCCD) NOT OCOVL
ntd     = ((((ntd1  NOT cngate) NOT OCCD) NOT OCOVL) NOT GT) NOT nld50ll_d
ptd     = (((((ptd1  NOT cpgate) NOT OCCD) NOT OCOVL) NOT MARKS) NOT GT) NOT pld50ll_d


//*DIODE
dio_np  = nsd1 INSIDE DSTR
dio_pn  = psd1 INSIDE DSTR

ND_core = (dio_np NOT DG) NOT TG  
ND_IO1  = (dio_np AND DG) NOT TG
ND_IO2  = (dio_np NOT DG) AND TG

PD_core = (dio_pn NOT DG) NOT TG
PD_IO1  = (dio_pn AND DG) NOT TG
PD_IO2  = (dio_pn NOT DG) AND TG

//ULL
ndio_coreu_elvt_old  = ((((((ND_core NOT PSUB) NOT HVT) NOT LVT) NOT ULVT) AND LV) NOT UHVT) NOT PHL
pdio_coreu_elvt_old  = (((((PD_core NOT HVT) NOT LVT) NOT ULVT) AND LV) NOT UHVT) NOT PHL
ndio_coreu_ull_old  = ((((((ND_core NOT PSUB) NOT HVT) NOT LVT) NOT ULVT) NOT LV) AND UHVT) NOT PHL
pdio_coreu_ull_old  = (((((PD_core NOT HVT) NOT LVT) NOT ULVT) NOT LV) AND UHVT) NOT PHL

ntdio_core_old    = (((ND_core AND PSUB) NOT HVT) NOT LVT) NOT ULVT
ntdio_IO1_old     = (((ND_IO1  AND PSUB) NOT HVT) NOT LVT) NOT ULVT
ntdio_IO2_old     = (((ND_IO2  AND PSUB) NOT HVT) NOT LVT) NOT ULVT

ndio_core_old     = ((((ND_core NOT PSUB) NOT HVT) NOT LVT) NOT DNW) NOT ULVT
ndio_core_ulvt_old= (((ND_core NOT PSUB) NOT HVT) NOT LVT) AND ULVT
ndio_core_hvt_old = (((ND_core NOT PSUB) AND HVT) NOT LVT) NOT ULVT
ndio_core_lvt_old = (((ND_core NOT PSUB) NOT HVT) AND LVT) NOT ULVT
ndio_IO1      = ((((ND_IO1  NOT PSUB) NOT HVT) NOT LVT) NOT DNW) NOT ULVT
ndio_IO2_old      = ((((ND_IO2  NOT PSUB) NOT HVT) NOT LVT) NOT DNW) NOT ULVT

pdio_core_old     = ((PD_core NOT HVT) NOT LVT) NOT ULVT
pdio_core_ulvt_old= ((PD_core NOT HVT) NOT LVT) AND ULVT
pdio_core_hvt_old = ((PD_core AND HVT) NOT LVT) NOT ULVT
pdio_core_lvt_old = ((PD_core NOT HVT) AND LVT) NOT ULVT
pdio_IO1_old      = ((PD_IO1  NOT HVT) NOT LVT) NOT ULVT
pdio_IO2_old      = ((PD_IO2  NOT HVT) NOT LVT) NOT ULVT

dio_nw    = nwell AND DSTR
//dionw   = dio_nw NOT INTERACT dio_pn
dionw_1   = dio_nw NOT INTERACT dio_pn 
dionw_2   = dionw_1 NOT INTERACT dio_np
dionw_old     = dionw_2 NOT INTERACT DNW 

//define n+/rwell   rwell/dnw  dnw/psub    diode
dnd12_core_old    = (((ND_core INTERACT rwell) NOT HVT) NOT LVT) NOT ULVT  
dnd18_core    = (((ND_IO1 INTERACT rwell) NOT HVT) NOT LVT) NOT ULVT  
dnd25_core_old    = (((ND_IO2 INTERACT rwell) NOT HVT) NOT LVT) NOT ULVT  
rwd12_core_old    = (((((rwell AND (DSTR INSIDE DNW)) NOT INTERACT ND_core) NOT INTERACT ND_IO2) NOT HVT) NOT LVT) NOT ULVT
rwd12_core_aux    = (((((rwell INTERACT (DSTR INSIDE DNW)) NOT INTERACT ND_core) NOT INTERACT ND_IO2) NOT HVT) NOT LVT) NOT ULVT
dnwd12_core_old   = (((DNW INSIDE DSTR) NOT HVT) NOT LVT) NOT ULVT

//nsd   = nsd1 NOT dio_np
nsd2    = nsd1 NOT dio_np
psd2    = psd1 NOT dio_pn

//*Parasitic Diode

/*
parasitic_rwell1  = (rwell INTERACT DNWTR) NOT INTERACT ND_core
parasitic_rwell2  = ((rwell INTERACT RFDEV) NOT INTERACT ND_core) NOT INTERACT VARMOS
parasitic_rwell3  = rwell INTERACT (VARMOS NOT INTERACT RFDEV)
parasitic_rwell4  = rwell INTERACT LDBK
parasitic_rwell5  = (rwell INTERACT DSTR) NOT INTERACT rwd12_core
parasitic_rwell   = (((parasitic_rwell1 OR parasitic_rwell2) OR parasitic_rwell3) OR parasitic_rwell4) OR parasitic_rwell5
parasitic_dnw1  = DNW INTERACT DNWTR
parasitic_dnw2  = DNW INTERACT (RFDEV NOT INTERACT VARMOS)
parasitic_dnw3  = DNW INTERACT (VARMOS NOT INTERACT RFDEV)
parasitic_dnw4  = DNW INTERACT LDBK
parasitic_dnw5  = DNW ENCLOSE DSTR
parasitic_dnw   = ((parasitic_dnw2 OR parasitic_dnw3) OR parasitic_dnw4) OR parasitic_dnw5
parasitic_nw1   = nwell NOT INTERACT DSTR
parasitic_nw2   = parasitic_nw1 NOT INTERACT dio_pn
parasitic_nw3   = parasitic_nw2 ENCLOSE pgate
parasitic_nw4   = (nwell INTERACT cngate) INTERACT (VARMOS NOT INTERACT RFDEV)
parasitic_nw5    = ((parasitic_nw3 OR parasitic_nw4) NOT INTERACT DNW) interact dnwd_psub == 1
parasitic_nw6    = (nwell ENCLOSE DSTR) NOT INTERACT dio_nw
parasitic_nw    = parasitic_nw5 OR parasitic_nw6
*/

parasitic_rwell   = (((rwell not interact (VARMOS and RFDEV)) NOT INTERACT DMPNP) NOT INTERACT rwd12_core) not interact RFDN6T
parasitic_dnw  = (((DNW not interact (VARMOS and RFDEV)) NOT INTERACT DMPNP) NOT dnwd12_core) not interact RFDN6T

parasitic_nw1   = nwell NOT (nwell inside DSTR) 
parasitic_nw2   = parasitic_nw1 INTERACT dio_pn
parasitic_nw3   = parasitic_nw1 ENCLOSE pgate
parasitic_nw4   = (nwell INTERACT cngate) INTERACT (VARMOS NOT INTERACT RFDEV)
parasitic_nw    = ((((parasitic_nw2 OR parasitic_nw3) OR parasitic_nw4) NOT INTERACT DNW) not interact RFDN5T) interact dnwd_psub == 1


//*BJT
pnpemit1 = psd2  AND DMPNP
pnpemit  = (pnpemit1 INTERACT SAB) AND BIPOLA

pnpbase = nwell INTERACT pnpemit
collsur = pwell TOUCH pnpbase
pnpcoll    = collsur OR pnpbase
//pnpcoll = STAMP coll BY pwell

PNP_core = (pnpemit NOT DG) NOT TG 
PNP_IO1  = (pnpemit AND DG) NOT TG
PNP_IO2  = (pnpemit NOT DG) AND TG

pnpbase4   = AREA pnpbase >78.9 <79.1
pnpbase25  = AREA pnpbase >149.3 <149.5
pnpbase100 = AREA pnpbase >316.0 <316.2

pnpsbase4   = AREA pnpbase >15.6 <15.8
pnpsbase25  = AREA pnpbase >53.0 <53.2
pnpsbase100 = AREA pnpbase >164.9 <165.1

PNPCOREA4a  = AREA PNP_core >4.8 <5.0
PNPCOREA25a = AREA PNP_core >30.25 <31
PNPCOREA100a= AREA PNP_core >123.2 <124

PNPIO1A4a   = AREA PNP_IO1 >4.8 <5.0
PNPIO1A25a  = AREA PNP_IO1 >30.25 <31
PNPIO1A100a = AREA PNP_IO1 >123.2 <124

PNPIO2A4a   = AREA PNP_IO2 >4.8 <5.0
PNPIO2A25a  = AREA PNP_IO2 >30.25 <31
PNPIO2A100a = AREA PNP_IO2 >123.2 <124

PNPCOREA4_old  = PNPCOREA4a INTERACT pnpbase4
PNPCOREA25_old = PNPCOREA25a INTERACT pnpbase25
PNPCOREA100_old= PNPCOREA100a INTERACT pnpbase100

PNPIO1A4_old   = PNPIO1A4a INTERACT pnpbase4
PNPIO1A25_old  = PNPIO1A25a INTERACT pnpbase25
PNPIO1A100 = PNPIO1A100a INTERACT pnpbase100

PNPIO2A4_old   = PNPIO2A4a INTERACT pnpbase4
PNPIO2A25_old  = PNPIO2A25a INTERACT pnpbase25
PNPIO2A100_old = PNPIO2A100a INTERACT pnpbase100

SPNPCOREA4_old  = PNPCOREA4a INTERACT pnpsbase4
SPNPCOREA25_old = PNPCOREA25a INTERACT pnpsbase25
SPNPCOREA100_old= PNPCOREA100a INTERACT pnpsbase100

SPNPIO1A4_old   = PNPIO1A4a INTERACT pnpsbase4
SPNPIO1A25_old  = PNPIO1A25a INTERACT pnpsbase25
SPNPIO1A100 = PNPIO1A100a INTERACT pnpsbase100

SPNPIO2A4_old   = PNPIO2A4a INTERACT pnpsbase4
SPNPIO2A25_old  = PNPIO2A25a INTERACT pnpsbase25
SPNPIO2A100_old = PNPIO2A100a INTERACT pnpsbase100

dnwnpn      = DNW  AND DMPNP
npnemit1    = nsd2 INTERACT dnwnpn
npnemit     = (npnemit1 INTERACT SAB) AND BIPOLA
nwell1      = nwell INTERACT DNW 
dnwell      = DNW OR nwell1
//dnwell      = STAMP dnw1 BY nwell

NPN_core = (npnemit NOT DG) NOT TG
NPN_IO1  = (npnemit AND DG) NOT TG
NPN_IO2  = (npnemit NOT DG) AND TG

npnbase4   = AREA rwell >78.9 <79.1
npnbase25  = AREA rwell >149.3 <149.5
npnbase100 = AREA rwell >316.0 <316.2

npnsbase4   = AREA rwell >15.6 <15.8
npnsbase25  = AREA rwell >53.0 <53.2
npnsbase100 = AREA rwell >164.9 <165.1

NPNCOREA4a  = AREA npn_core >4.8 <5.0
NPNCOREA25a = AREA npn_core >30.25 <31
NPNCOREA100a= AREA npn_core >123.2 <124

NPNIO1A4a   = AREA NPN_IO1 >4.8 <5.0
NPNIO1A25a  = AREA NPN_IO1 >30.25 <31
NPNIO1A100a = AREA NPN_IO1 >123.2 <124

NPNIO2A4a   = AREA NPN_IO2 >4.8 <5.0
NPNIO2A25a  = AREA NPN_IO2 >30.25 <31
NPNIO2A100a = AREA NPN_IO2 >123.2 <124

NPNCOREA4_old  = NPNCOREA4a INTERACT npnbase4
NPNCOREA25_old = NPNCOREA25a INTERACT npnbase25
NPNCOREA100_old= NPNCOREA100a INTERACT npnbase100

NPNIO1A4   = NPNIO1A4a INTERACT npnbase4
NPNIO1A25_old  = NPNIO1A25a INTERACT npnbase25
NPNIO1A100_old = NPNIO1A100a INTERACT npnbase100

NPNIO2A4_old   = NPNIO2A4a INTERACT npnbase4
NPNIO2A25_old  = NPNIO2A25a INTERACT npnbase25
NPNIO2A100_old = NPNIO2A100a INTERACT npnbase100

SNPNCOREA4_old  = NPNCOREA4a INTERACT npnsbase4
SNPNCOREA25_old = NPNCOREA25a INTERACT npnsbase25
SNPNCOREA100_old= NPNCOREA100a INTERACT npnsbase100

SNPNIO1A4   = NPNIO1A4a INTERACT npnsbase4
SNPNIO1A25_old  = NPNIO1A25a INTERACT npnsbase25
SNPNIO1A100_old = NPNIO1A100a INTERACT npnsbase100

SNPNIO2A4_old   = NPNIO2A4a INTERACT npnsbase4
SNPNIO2A25_old  = NPNIO2A25a INTERACT npnsbase25
SNPNIO2A100_old = NPNIO2A100a INTERACT npnsbase100

nsd3    = nsd2  NOT npnemit
nsd     = ((nsd3 NOT ngate_spec) NOT nld_gate) NOT nld50ll_s

/**Junction Varactor*/

psd3    = psd2  NOT pnpemit

psd     = ((psd3 NOT pgate_spec) NOT pld_gate) NOT pld50ll_s

//*MOSFET

N_core  = (ngate NOT DG) NOT TG
N_IO1   = (ngate AND DG) NOT TG
N_IO2   = (ngate NOT DG) AND TG

P_core  = (pgate NOT DG) NOT TG
P_IO1   = (pgate AND DG) NOT TG
P_IO2   = (pgate NOT DG) AND TG

N_core_spec  = (ngate_spec NOT DG) NOT TG
P_core_spec  = (pgate_spec NOT DG) NOT TG
N_IO2_spec   = (ngate_spec NOT DG) AND TG
P_IO2_spec   = (pgate_spec NOT DG) AND TG

//*MOS gate definition
//ULL
ngate_coreu_avt1    = ((((((((((((N_core NOT LV) NOT UHVT) AND PHL) NOT PSUB) NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) NOT DGV
ngate_coreu_avt2    = ngate_coreu_avt1 NOT RFDEV
pgate_coreu_avt1    = (((((((((((P_core NOT LV) NOT UHVT) AND PHL) NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) NOT DGV

ngate_coreu_elvt1    = ((((((((((((N_core AND LV) NOT UHVT) NOT PHL) NOT PSUB) NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) NOT DGV
ngate_coreu_elvt2    = ngate_coreu_elvt1 NOT RFDEV
ngate_coreu_elvt_old = (ngate_coreu_elvt2 NOT DNWTR) touch nsd == 2
dnwng_coreu_elvt_old = (((ngate_coreu_elvt2 AND DNWTR) AND DNW) NOT RFDEV) touch nsd == 2
pgate_coreu_elvt1    = (((((((((((P_core AND LV) NOT UHVT) NOT PHL) NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) NOT DGV
pgate_coreu_elvt_old = (pgate_coreu_elvt1 touch psd == 2) NOT RFDEV

ngate_coreu_ull1     = ((((((((((((N_core NOT LV) AND UHVT) NOT PHL) NOT PSUB) NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) NOT DGV
ngate_coreu_ull2     = ngate_coreu_ull1 NOT RFDEV
ngate_coreu_ull_old  = (ngate_coreu_ull2 NOT DNWTR) touch nsd == 2
dnwng_coreu_ull_old  = (((ngate_coreu_ull2 AND DNWTR) AND DNW) NOT RFDEV) touch nsd == 2
pgate_coreu_ull1     = ((((((((((P_core NOT LV) AND UHVT) NOT PHL) NOT HVT) NOT LVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) NOT DGV
pgate_coreu_ull_old  = (pgate_coreu_ull1  touch psd == 2 ) NOT RFDEV

//end of ULL


SRAM_DUMMY      = (((D2SRAM OR DNSRAM) OR RFSRAM) OR DPSRAM) OR LRSRAM

ntgate_core1    = (((((((((N_core AND PSUB) NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY)  NOT OVERDR) NOT TGV) NOT DGV 
ntgate_core_old     = ntgate_core1 touch nsd == 2
ntgate_IO1_1    = (((((((((N_IO1  AND PSUB) NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY ) NOT OVERDR) NOT TGV) NOT DGV
ntgate_IO1      = ntgate_IO1_1 touch nsd == 2
ntgate_IO2_1    = (((((((((N_IO2  AND PSUB) NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) NOT DGV
ntgate_IO2_old      = ntgate_IO2_1 touch nsd == 2

ntgate_IO2_over_1 = (((((((((N_IO2 AND PSUB) NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY)  AND OVERDR) NOT TGV) NOT DGV 
ntgate_IO2_over_old   = ntgate_IO2_over_1 touch nsd == 2

ntgate_IO2_under_1 = (((((((((N_IO2 AND PSUB) NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY)  NOT OVERDR) AND TGV) NOT DGV
ntgate_IO2_under_old   = ntgate_IO2_under_1 touch nsd == 2

ngate_core_1    = (((((((((N_core NOT PSUB) NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) NOT DGV
ngate_core2       = ngate_core_1 NOT RFDEV
ngate_core_old       = (ngate_core2 NOT DNWTR) touch nsd == 2
dnwngate12_old        = ((ngate_core2 AND DNWTR) AND DNW) NOT RFDEV

ngate_core_spec1     = (((((((((N_core_spec NOT PSUB) NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) NOT DGV
ngate_core_spec_aux  = ((ngate_core_spec1 OR (holes ngate_core_spec1)) NOT RFDEV) NOT DNWTR
ngate_core_spec_old  = (ngate_core_spec1 NOT RFDEV) NOT DNWTR

ngate_core_hvt1 = (((((((((N_core NOT PSUB) AND HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) NOT DGV
ngate_core_hvt2       = ngate_core_hvt1 NOT RFDEV
ngate_core_hvt_old  = (ngate_core_hvt2 NOT DNWTR) touch nsd == 2
dnwhvtgate12_old    = ((ngate_core_hvt1 AND DNW) AND DNWTR) NOT RFDEV

ngate_core_lvt1 = (((((((((N_core NOT PSUB) NOT HVT) AND LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) NOT DGV
ngate_core_lvt2       = ngate_core_lvt1 NOT RFDEV
ngate_core_lvt_old        = (ngate_core_lvt2 NOT DNWTR) touch nsd == 2
dnwlvtgate12_old          = ((ngate_core_lvt1 AND DNW) AND DNWTR) NOT RFDEV


ngate_core_ulvt1 = (((((((((N_core NOT PSUB) NOT HVT) NOT LVT) AND ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) NOT DGV
ngate_core_ulvt2       = ngate_core_ulvt1 NOT RFDEV
ngate_core_ulvt_old        = (ngate_core_ulvt2 NOT DNWTR) touch nsd == 2
dnwulvtgate12_old          = ((ngate_core_ulvt1 AND DNW) AND DNWTR) NOT RFDEV


ngate_IO1_1    = (((((((((N_IO1  NOT PSUB) NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) NOT DGV
ngate_IO1_2       = ngate_IO1_1 NOT RFDEV
ngate_IO1         = (ngate_IO1_2 NOT DNWTR) touch nsd == 2
dnwngate18        = ((ngate_IO1_1 AND DNW) AND DNWTR) NOT RFDEV

ngate_IO1_under1  = (((((((((N_IO1  NOT PSUB) NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) AND DGV
ngate_IO1_under   = ngate_IO1_under1 touch nsd == 2

ngate_IO2_1      = (((((((((N_IO2  NOT PSUB) NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) NOT DGV

ngate_IO2_2      = ngate_IO2_1 NOT RFDEV
ngate_IO2_old        = (ngate_IO2_2 NOT DNWTR) touch nsd == 2
dnwngate25_old       = ((ngate_IO2_1 AND DNW) AND DNWTR) NOT RFDEV

ngate_IO2_spec1     = (((((((((N_IO2_spec NOT PSUB) NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) NOT DGV
ngate_IO2_spec_aux  = ((ngate_IO2_spec1 OR (holes ngate_IO2_spec1)) NOT RFDEV) NOT DNWTR
ngate_IO2_spec_old  = (ngate_IO2_spec1 NOT RFDEV) NOT DNWTR

pgat10          = ((((((P_core NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT OVERDR) NOT TGV) NOT DGV
pgate_core_hvt1 = (((((((P_core AND HVT) NOT LVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) NOT DGV
pgate_core_hvt_old  = pgate_core_hvt1  touch psd == 2

pgate_core_lvt1 = ((((((((P_core NOT HVT) AND LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) NOT DGV
pgate_core_lvt_old = (pgate_core_lvt1 touch psd == 2) NOT RFDEV

pgate_core_ulvt1 = ((((((((P_core NOT HVT) NOT LVT) AND ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) NOT DGV
pgate_core_ulvt_old = (pgate_core_ulvt1 touch psd == 2) NOT RFDEV


pgate_IO1_1    = ((((((((P_IO1  NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) NOT DGV
pgate_IO1_2    = pgate_IO1_1 NOT RFDEV
pgate_IO1_old      = pgate_IO1_2 touch psd == 2

pgate_IO1_under_1 = ((((((((P_IO1  NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) AND DGV
pgate_IO1_under   = pgate_IO1_under_1 touch psd == 2

pgate_IO2_1    = ((((((((P_IO2  NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) NOT DGV
pgate_IO2_2    = pgate_IO2_1 NOT RFDEV
pgate_IO2_old      = pgate_IO2_2 touch psd == 2

pgate_IO2_spec1     = ((((((((P_IO2_spec NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) NOT TGV) NOT DGV
pgate_IO2_spec_aux  = (pgate_IO2_spec1 OR (holes pgate_IO2_spec1)) NOT RFDEV
pgate_IO2_spec_old  = pgate_IO2_spec1 NOT RFDEV

ngate_IO2_over1 = (((((((((N_IO2  NOT PSUB) NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) AND OVERDR) NOT TGV) NOT DGV
ngate_IO2_over2        = (ngate_IO2_over1 NOT DNWTR) touch nsd == 2
ngate_IO2_over_old         = ngate_IO2_over2 NOT RFDEV
dnwodgate33_old            = ((ngate_IO2_over1 AND DNWTR) AND DNW) NOT RFDEV

pgate_IO2_over1 = ((((((((P_IO2  NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) AND OVERDR) NOT TGV) NOT DGV
pgate_IO2_over2  = pgate_IO2_over1 touch psd == 2  
pgate_IO2_over_old   = pgate_IO2_over2 NOT RFDEV

ngate_IO2_under1 = (((((((((N_IO2  NOT PSUB) NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) AND TGV) NOT DGV 
tmp_ngate_IO2_under1 = (((((((N_IO2  NOT PSUB) NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR 


ngate_IO2_under2 = (ngate_IO2_under1 NOT DNWTR) touch nsd == 2
ngate_IO2_under_old   = ngate_IO2_under2 NOT RFDEV
dnwudgate18_old           = ((ngate_IO2_under1 AND DNW) AND DNWTR) NOT RFDEV

pgate_IO2_under1 = ((((((((P_IO2  NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT INST) NOT SRAM_DUMMY) NOT OVERDR) AND TGV) NOT DGV
pgate_IO2_under2  = pgate_IO2_under1 touch psd == 2
pgate_IO2_under_old   = pgate_IO2_under2 NOT RFDEV


//*SRAM bitcell(3)

SRAM_NGATE       = ((((N_core NOT PSUB) NOT LVT) NOT ULVT) NOT HVT) NOT CL
SRAM_NGATE_0.576 = (((((SRAM_NGATE AND INST) AND DPSRAM) NOT LRSRAM) NOT D2SRAM) NOT DNSRAM) NOT RFSRAM
SRAM_NGATE_0.741 = ((((((SRAM_NGATE AND INST) NOT DPSRAM) NOT LRSRAM) NOT D2SRAM) NOT DNSRAM) AND RFSRAM) AND HPBL
SRAM_NGATE_0.589 = (((((SRAM_NGATE AND INST) NOT DPSRAM) NOT LRSRAM) AND D2SRAM) NOT DNSRAM) NOT RFSRAM
SRAM_NGATE_0.299 = ((((((SRAM_NGATE AND INST) NOT DPSRAM) NOT LRSRAM) NOT D2SRAM) AND DNSRAM) NOT RFSRAM) NOT UHVT
SRAM_NGATE_0.299ULL = ((((((SRAM_NGATE AND INST) NOT DPSRAM) NOT LRSRAM) NOT D2SRAM) AND DNSRAM) NOT RFSRAM) AND UHVT
SRAM_NGATE_0.374 = ((((((SRAM_NGATE AND INST) NOT DPSRAM) AND LRSRAM) NOT D2SRAM) NOT DNSRAM) NOT RFSRAM) AND HPBL

SRAM_PGATE       = (((P_core NOT LVT) NOT ULVT) NOT HVT) NOT CL
SRAM_PGATE_0.576 = (((((SRAM_PGATE AND INST) AND DPSRAM) NOT LRSRAM) NOT D2SRAM) NOT DNSRAM) NOT RFSRAM
SRAM_PGATE_0.741 = ((((((SRAM_PGATE AND INST) NOT DPSRAM) NOT LRSRAM) NOT D2SRAM) NOT DNSRAM) AND RFSRAM) AND HPBL
SRAM_PGATE_0.589 = (((((SRAM_PGATE AND INST) NOT DPSRAM) NOT LRSRAM) AND D2SRAM) NOT DNSRAM) NOT RFSRAM
SRAM_PGATE_0.299 = ((((((SRAM_PGATE AND INST) NOT DPSRAM) NOT LRSRAM) NOT D2SRAM) AND DNSRAM) NOT RFSRAM) NOT UHVT
SRAM_PGATE_0.299ULL = ((((((SRAM_PGATE AND INST) NOT DPSRAM) NOT LRSRAM) NOT D2SRAM) AND DNSRAM) NOT RFSRAM) AND UHVT
SRAM_PGATE_0.374 = ((((((SRAM_PGATE AND INST) NOT DPSRAM) AND LRSRAM) NOT D2SRAM) NOT DNSRAM) NOT RFSRAM) AND HPBL

SRAM_PGATE_all = ((((SRAM_PGATE_0.576 OR SRAM_PGATE_0.741) OR SRAM_PGATE_0.589) OR SRAM_PGATE_0.299) OR SRAM_PGATE_0.374) OR SRAM_PGATE_0.299ULL


//=================================================================
//Define bitcell = 0.299 ULL S2//
//stnpdull(W/L=0.140/0.055,AREA=0.0077)
//stnpdull_s2_gate_0.299_a = AREA SRAM_NGATE_0.299ULL >=0.0077 <0.00771
//stnpdull_s2_gate_0.299_old   = stnpdull_s2_gate_0.299_a TOUCH nsd == 2

//stnpgull(W/L=0.115/0.065,AREA=0.007475)
//stnpgull_s2_gate_0.299_a = AREA SRAM_NGATE_0.299ULL >=0.007475 <0.00748
//stnpgull_s2_gate_0.299_old   = ( stnpgull_s2_gate_0.299_a TOUCH nsd == 2 ) AND SDOP

//stplull(W/L=0.06/0.055,AREA=0.0033)
//stplull_s2_gate_0.299_a = AREA SRAM_PGATE_0.299ULL >=0.0033 <0.0034
//stplull_s2_gate_0.299_old   = stplull_s2_gate_0.299_a TOUCH psd == 2

//=================================================================
//Define bitcell = 0.299 ULL S1//
//stnpdull(W/L=0.142/0.055,AREA=0.00781)
stnpdull_s1_gate_0.299_a = AREA SRAM_NGATE_0.299ULL >=0.00781 <0.00782
stnpdull_s1_gate_0.299_old   = stnpdull_s1_gate_0.299_a TOUCH nsd == 2

//stnpgull(W/L=0.11/0.059,AREA=0.00649)
stnpgull_s1_gate_0.299_a = AREA SRAM_NGATE_0.299ULL >=0.00649 <0.0065
stnpgull_s1_gate_0.299_old   = (stnpgull_s1_gate_0.299_a TOUCH nsd == 2 ) AND SDOP

//stplull(W/L=0.06/0.055,AREA=0.0033)
stplull_s1_gate_0.299_a = AREA SRAM_PGATE_0.299ULL >=0.0033 <0.0034
stplull_s1_gate_0.299_old   = stplull_s1_gate_0.299_a TOUCH psd == 2

//=================================================================
//Define bitcell = 0.576 
//=================================================================
//dplnfetpd(W/L=0.32/0.055,AREA=0.0176) 
dplnfetpd_gate_0.576_a = AREA SRAM_NGATE_0.576 >=0.0176 <0.0177 
dplnfetpd_gate_0.576_old   = dplnfetpd_gate_0.576_a TOUCH nsd == 2

//dplnfetwl(W/L=0.164/0.057,AREA=0.009348)
dplnfetwl_gate_0.576_a = AREA SRAM_NGATE_0.576 >=0.009348 <0.009349
dplnfetwl_gate_0.576_old   = (dplnfetwl_gate_0.576_a TOUCH nsd == 2 ) AND SDOP

//dplpfetpu(W/L=0.06/0.055,AREA=0.0033)
dplpfetpu_gate_0.576_a = AREA SRAM_PGATE_0.576 >=0.0033 <0.0034
dplpfetpu_gate_0.576_old   = dplpfetpu_gate_0.576_a TOUCH psd == 2

//=================================================================
//Define bitcell = 0.741 //
//rflnfetpd(W/L=0.438/0.055,AREA=0.02409)
rflnfetpd_gate_0.741_a = AREA SRAM_NGATE_0.741 >=0.02409 <0.0241
rflnfetpd_gate_0.741_old   = rflnfetpd_gate_0.741_a TOUCH nsd == 2

//rflnfetwl(W/L=0.168/0.063,AREA=0.010584)
rflnfetwl_gate_0.741_1 = AREA SRAM_NGATE_0.741 >=0.010584 <0.010585
SP_NW_rf               = SP ENCLOSE rflpfetpu_gate_0.741
SP_NW_rf_ov            = SIZE SP_NW_rf BY 0.211
rflnfetwla_gate_0.741_1= rflnfetwl_gate_0.741_1 TOUCH SP_NW_rf_ov
rflnfetwla_gate_0.741_old  = (rflnfetwla_gate_0.741_1 TOUCH nsd == 2) AND SDOP
rflnfetwlb_gate_0.741_1= rflnfetwl_gate_0.741_1 NOT rflnfetwla_gate_0.741
rflnfetwlb_gate_0.741_old  = (rflnfetwlb_gate_0.741_1 TOUCH nsd == 2) AND SDOP


//rflpfetpu(W/L=0.08/0.055,AREA=0.0044)
rflpfetpu_gate_0.741_a = AREA SRAM_PGATE_0.741 >=0.0044 <0.0045
rflpfetpu_gate_0.741_old   = rflpfetpu_gate_0.741_a TOUCH psd == 2

//=================================================================
//Define bitcell = 0.589 //
//dpcnfetpd(W/L=0.305/0.055,AREA=0.016775)
dpcnfetpd_gate_0.589_a = AREA SRAM_NGATE_0.589 >=0.016775 <0.016776
dpcnfetpd_gate_0.589_old   = dpcnfetpd_gate_0.589_a TOUCH nsd == 2

//dpcnfetwl(W/L=0.154/0.067,AREA=0.010318)
dpcnfetwl_gate_0.589_1 = AREA SRAM_NGATE_0.589 >=0.010318 <0.010319
SP_NW                  = SP ENCLOSE dpcpfetpu_gate_0.589
SP_NW_ov               = SIZE SP_NW BY 0.14
dpcnfetwla_gate_0.589_1= dpcnfetwl_gate_0.589_1 TOUCH SP_NW_ov
dpcnfetwla_gate_0.589_old  = (dpcnfetwla_gate_0.589_1 TOUCH nsd == 2) AND SDOP
dpcnfetwlb_gate_0.589_1= dpcnfetwl_gate_0.589_1 NOT dpcnfetwla_gate_0.589
dpcnfetwlb_gate_0.589_old  = (dpcnfetwlb_gate_0.589_1 TOUCH nsd == 2) AND SDOP

//dpcpfetpu(W/L=0.06/0.055,AREA=0.0033)
dpcpfetpu_gate_0.589_a = AREA SRAM_PGATE_0.589 >=0.0033 <0.0034
dpcpfetpu_gate_0.589_old   = dpcpfetpu_gate_0.589_a TOUCH psd == 2
//=================================================================

//Define bitcell = 0.299 //
//dslnfetpd(W/L=0.142/0.055,AREA=0.00781)
dslnfetpd_gate_0.299_a = AREA SRAM_NGATE_0.299 >=0.00781 <0.00782
dslnfetpd_gate_0.299_old   = dslnfetpd_gate_0.299_a TOUCH nsd == 2

//dslnfetwl(W/L=0.11/0.059,AREA=0.00649)
dslnfetwl_gate_0.299_a = AREA SRAM_NGATE_0.299 >=0.00649 <0.0065
dslnfetwl_gate_0.299_old   = dslnfetwl_gate_0.299_a TOUCH nsd == 2
//dslnfetwl_gate_0.299_old   = (dslnfetwl_gate_0.299_a TOUCH nsd == 2) AND SDOP

//dslpfetpu(W/L=0.06/0.055,AREA=0.0033)
dslpfetpu_gate_0.299_a = AREA SRAM_PGATE_0.299 >=0.0033 <0.0034
dslpfetpu_gate_0.299_old   = dslpfetpu_gate_0.299_a TOUCH psd == 2
//=================================================================

//Define bitcell = 0.374 //
//lshnfetpd(W/L=0.233/0.055,AREA=0.012815)
lshnfetpd_gate_0.374_a = AREA SRAM_NGATE_0.374 >=0.012815 <0.012816
lshnfetpd_gate_0.374_old   = lshnfetpd_gate_0.374_a TOUCH nsd == 2

//lshnfetwl(W/L=0.183/0.063,AREA=0.011529)
lshnfetwl_gate_0.374_a = AREA SRAM_NGATE_0.374 >=0.011529 <0.011530
lshnfetwl_gate_0.374_old   = (lshnfetwl_gate_0.374_a TOUCH nsd == 2) AND SDOP

//lshpfetpu(W/L=0.07/0.055,AREA=0.00385)
lshpfetpu_gate_0.374_a = AREA SRAM_PGATE_0.374 >=0.00385 <0.00386
lshpfetpu_gate_0.374_old   = lshpfetpu_gate_0.374_a TOUCH psd == 2
//=================================================================


pgate_core_all    = (pgat10 NOT SRAM_DUMMY) NOT SRAM_PGATE_all
pgate_core_1      = pgate_core_all TOUCH psd == 2
pgate_core1       = pgate_core_1 NOT RFDEV
pgate_core_old        = pgate_core1 touch psd == 2

pgate_core_spec1     = ((((((P_core_spec NOT HVT) NOT LVT) NOT ULVT) NOT CL) NOT OVERDR) NOT TGV) NOT DGV 
pgate_core_spec_aux  = (pgate_core_spec1 OR (holes pgate_core_spec1)) NOT RFDEV
pgate_core_spec_old  = pgate_core_spec1 NOT RFDEV

//*MOS Varactor

pvar_core_aux = (((((cngate NOT DG) NOT TG ) INTERACT NCAP) NOT RFDEV) NOT DNW) AND VARMOS
pvar_core_old     = AA ENCLOSE pvar_core_aux
pvar_core_t   = copy pvar_core_aux 
pvar_IO1_aux  = (((((cngate AND DG) NOT TG ) INTERACT NCAP) NOT RFDEV) NOT DNW) AND VARMOS
pvar_IO1      = AA ENCLOSE pvar_IO1_aux
pvar_IO1_t    = copy pvar_IO1_aux
pvar_IO2_aux  = (((((cngate NOT DG) AND TG ) INTERACT NCAP) NOT RFDEV) NOT DNW) AND VARMOS
pvar_IO2_old      = AA ENCLOSE pvar_IO2_aux
pvar_IO2_t    = copy pvar_IO2_aux

pvar_core_aux_dnw = (((((cngate NOT DG) NOT TG ) INTERACT NCAP) NOT RFDEV) AND DNW) AND VARMOS
pvar_core_dnw_old     = AA ENCLOSE pvar_core_aux_dnw
pvar_core_dnw_t   = copy pvar_core_aux_dnw
pvar_IO1_aux_dnw  = (((((cngate AND DG) NOT TG ) INTERACT NCAP) NOT RFDEV) AND DNW) AND VARMOS
pvar_IO1_dnw_old      = AA ENCLOSE pvar_IO1_aux_dnw
pvar_IO1_dnw_t    = copy pvar_IO1_aux_dnw
pvar_IO2_aux_dnw  = (((((cngate NOT DG) AND TG ) INTERACT NCAP) NOT RFDEV) AND DNW) AND VARMOS
pvar_IO2_dnw_old      = AA ENCLOSE pvar_IO2_aux_dnw
pvar_IO2_dnw_t    = copy pvar_IO2_aux_dnw 

nvar_core_aux = (((((cpgate NOT DG) NOT TG ) INTERACT PCAP) NOT RFDEV) NOT DNW) AND VARMOS
nvar_core_old     = AA ENCLOSE nvar_core_aux
nvar_core_t   = copy nvar_core_aux
nvar_IO1_aux  = (((((cpgate AND DG) NOT TG ) INTERACT PCAP) NOT RFDEV) NOT DNW) AND VARMOS
nvar_IO1_old      = AA ENCLOSE nvar_IO1_aux
nvar_IO1_t    = copy nvar_IO1_aux 
nvar_IO2_aux  = (((((cpgate NOT DG) AND TG ) INTERACT PCAP) NOT RFDEV) NOT DNW) AND VARMOS
nvar_IO2_old      = AA ENCLOSE nvar_IO2_aux
nvar_IO2_t    = copy nvar_IO2_aux

nvar_core_aux_dnw = (((((cpgate NOT DG) NOT TG ) INTERACT PCAP) NOT RFDEV) AND DNW) AND VARMOS
nvar_core_dnw_old     = AA ENCLOSE nvar_core_aux_dnw
nvar_core_dnw_t   = copy nvar_core_aux_dnw
nvar_IO1_aux_dnw  = (((((cpgate AND DG) NOT TG ) INTERACT PCAP) NOT RFDEV) AND DNW) AND VARMOS
nvar_IO1_dnw_old      = AA ENCLOSE nvar_IO1_aux_dnw
nvar_IO1_dnw_t    = copy nvar_IO1_aux_dnw
nvar_IO2_aux_dnw  = (((((cpgate NOT DG) AND TG ) INTERACT PCAP) NOT RFDEV) AND DNW) AND VARMOS
nvar_IO2_dnw_old      = AA ENCLOSE nvar_IO2_aux_dnw
nvar_IO2_dnw_t    = copy nvar_IO2_aux_dnw

nwell_ntd = (nwell INTERACT DNW) INTERACT ntd

//*SMIC IO devices(3)
cngate_core1 = (((cngate NOT DG) NOT TG) NOT INTERACT NCAP) NOT SRAM_DUMMY
cngate_core_old  = cngate_core1 touch ntd == 2
cngate_IO1_1 = (((cngate AND DG) NOT TG) NOT INTERACT NCAP) NOT SRAM_DUMMY
cngate_IO1_old   = cngate_IO1_1 touch ntd == 2
cngate_IO2_1 = (((cngate NOT DG) AND TG) NOT INTERACT NCAP) NOT SRAM_DUMMY
cngate_IO2_old   = cngate_IO2_1 touch ntd == 2

/* generate generic gate and rf gate, generic poly and rf poly*/
gate_ldmos = ((AA and GT) and LDBK) INTERACT (nld_gate OR pld_gate)
gate1      = (((ngate OR pgate) OR cngate) OR cpgate) OR gate_ldmos
gate      = gate1 OR ((holes gate1) touch gate1)
gate_core = (gate NOT DG) NOT TG
gate_IO   = (gate NOT DG) AND TG

#IFDEF RC_RUN TRUE
poly    = poly1 NOT gate 
npoly   = poly AND SN
ppoly   = poly NOT SN
#ENDIF

#IFDEF RC_RUN FALSE
poly    = copy poly1
npoly   = poly AND SN
ppoly   = poly NOT SN
#ENDIF

/*Define layers for LOD extraction*/
diff = ndifi OR pdifi
all_sd= nsd OR psd

/*Define layers for WPE extraction*/
ngate_wpe = ngate NOT INST //to speed up running
pgate_wpe = pgate NOT INST //to speed up running

/* Divide contact into polycont and dfcont */
polycont = CT AND poly
npolycont = polycont AND SN
ppolycont = polycont NOT npolycont //Ethan
//ppolycont = polycont AND SP
dfcont   = CT NOT polycont
ndfcont   = dfcont AND SN
pdfcont   = dfcont NOT SN

ntd_nwell_subcont = (ntd AND nwell) interact CT
ptd_pwell_subcont = (ptd AND pwell) interact CT
ptd_rwell_subcont = (ptd AND rwell) interact CT
ptd_dnwd_psub_subcont=(ptd AND dnwd_psub) interact CT
ntd_dnwell_subcont   = (ntd AND dnwell) interact CT

//*Define layer for ERC check
rnwell  = nwell TOUCH nwr
bnwell  = nwell INTERACT DMPNP
ntap1   = ntd   NOT rnwell
ntap2   = ntap1 NOT bnwell

//*Define layer for dnw mos laddr/waddr calculation
ndifd1     = ndiff AND DNW
ndifd      = EXTENTS ndifd1
ndifd3     = ndifd NOT gt2
gt2        = GT AND ndifd

daa1       = (AA INTERACT GT) AND DNW
daa        = EXTENTS daa1
daa3       = daa1 NOT gt2

dnwngate12_body    = gt2 enclose dnwngate12
dnwngate18_body    = gt2 enclose dnwngate18
dnwngate25_body    = gt2 enclose dnwngate25
dnwhvtgate12_body  = gt2 enclose dnwhvtgate12
dnwlvtgate12_body  = gt2 enclose dnwlvtgate12
dnwodgate33_body   = gt2 enclose dnwodgate33
dnwudgate18_body   = gt2 enclose dnwudgate18

dnwwdedge  = ndifd TOUCH EDGE gt2 
dnwwdedge_daa = daa TOUCH EDGE gt2

//dnwwaddrec =  ENC dnwwdedge rwell <1000 opposite region
//dnwwaddrec2 = ENC dnwwdedge DNW <1000 opposite region
//dnwwaddrec3 = ENC dnwwdedge_daa DNW <1000 opposite region


//Define poly for MOM third terminal with out n or p guard ring

//Define LDMOS
ndifi_sti1             = SIZE ndifi BY 0.075 overunder
ndifi_sti              = ndifi_sti1 INTERACT GT
nld50ll_gate           = (((((poly1 AND ndifi_sti) AND LDBK) INTERACT nwell) AND TG) NOT OVERDR) NOT nwell
nld50ll_gate_od        = (((((poly1 AND ndifi_sti) AND LDBK) INTERACT nwell) AND TG) AND OVERDR) NOT nwell
nld50ll_gate_body_old      = (NFDMK INTERACT nld50ll_gate) NOT RFDEV
nld50ll_gate_od_body_old   = (NFDMK INTERACT nld50ll_gate_od) NOT RFDEV
nld_gate    = nld50ll_gate OR nld50ll_gate_od
nld50ll_s   = (((ndifi_sti NOT nld_gate) NOT INTERACT nwell) AND LDBK) NOT RFDEV
nld50ll_s_od   = copy nld50ll_s

pdifi_sti1            = SIZE pdifi BY 0.075 overunder
pdifi_sti             = pdifi_sti1 INTERACT GT
pld50ll_gate          = ((((((poly1 AND pdifi_sti) AND LDBK) INTERACT pwell) AND TG) NOT OVERDR) AND DNW) NOT pwell
pld50ll_gate_od       = ((((((poly1 AND pdifi_sti) AND LDBK) INTERACT pwell) AND TG) AND OVERDR) AND DNW) NOT pwell
pld50ll_gate_body_old     = (NFDMK INTERACT pld50ll_gate) NOT RFDEV
pld50ll_gate_od_body_old  = (NFDMK INTERACT pld50ll_gate_od) NOT RFDEV
pld_gate    = pld50ll_gate OR pld50ll_gate_od
pld50ll_s   = (((pdifi_sti NOT pld_gate) NOT INTERACT pwell) AND LDBK) NOT RFDEV
pld50ll_s_od   = copy pld50ll_s

nld50ll_d   = (((ndifi_sti NOT nld_gate) INTERACT nwell) AND LDBK) NOT RFDEV
nld50ll_ad  = nwell ENCLOSE nld50ll_d
pld50ll_d   = (((pdifi_sti NOT pld_gate) INTERACT pwell) AND LDBK) NOT RFDEV
pld50ll_ad  = rwell ENCLOSE pld50ll_d

#IFDEF RC_RUN TRUE
//new define
nld50ll_s:prop = dfm property nld50ll_s nld50ll_gate_body OVERLAP ABUT ALSO MULTI
    [ ct = count(nld50ll_gate_body)]
    [ ar = (count(nld50ll_gate_body)==2) ?  (area(nld50ll_s)/2) : area(nld50ll_s) ]
    [ pm = (count(nld50ll_gate_body)==2) ?  (perim(nld50ll_s)/2) : perim(nld50ll_s) ]
nld50ll_gate_body:prop = dfm property nld50ll_gate_body nld50ll_s:prop OVERLAP ABUT ALSO MULTI
    [ ar = sum(property(nld50ll_s:prop,"ar")) ]
    [ pm = sum(property(nld50ll_s:prop,"pm")) ]
nld50ll_s_od:prop = dfm property nld50ll_s nld50ll_gate_od_body OVERLAP ABUT ALSO MULTI
    [ ct = count(nld50ll_gate_od_body)]
    [ ar = (count(nld50ll_gate_od_body)==2) ?  (area(nld50ll_s)/2) : area(nld50ll_s) ]
    [ pm = (count(nld50ll_gate_od_body)==2) ?  (perim(nld50ll_s)/2) : perim(nld50ll_s) ]
nld50ll_gate_od_body:prop = dfm property nld50ll_gate_od_body nld50ll_s_od:prop OVERLAP ABUT ALSO MULTI
    [ ar = sum(property(nld50ll_s_od:prop,"ar")) ]
    [ pm = sum(property(nld50ll_s_od:prop,"pm")) ]
//end

//new define
pld50ll_s:prop = dfm property pld50ll_s pld50ll_gate_body OVERLAP ABUT ALSO MULTI
    [ ct = count(pld50ll_gate_body)]
    [ ar = (count(pld50ll_gate_body)==2) ?  (area(pld50ll_s)/2) : area(pld50ll_s) ]
    [ pm = (count(pld50ll_gate_body)==2) ?  (perim(pld50ll_s)/2) : perim(pld50ll_s) ]
pld50ll_gate_body:prop = dfm property pld50ll_gate_body pld50ll_s:prop OVERLAP ABUT ALSO MULTI
    [ ar = sum(property(pld50ll_s:prop,"ar")) ]
    [ pm = sum(property(pld50ll_s:prop,"pm")) ]

pld50ll_s_od:prop = dfm property pld50ll_s pld50ll_gate_od_body OVERLAP ABUT ALSO MULTI
    [ ct = count(pld50ll_gate_od_body)]
    [ ar = (count(pld50ll_gate_od_body)==2) ?  (area(pld50ll_s)/2) : area(pld50ll_s) ]
    [ pm = (count(pld50ll_gate_od_body)==2) ?  (perim(pld50ll_s)/2) : perim(pld50ll_s) ]
pld50ll_gate_od_body:prop = dfm property pld50ll_gate_od_body pld50ll_s_od:prop OVERLAP ABUT ALSO MULTI
    [ ar = sum(property(pld50ll_s_od:prop,"ar")) ]
    [ pm = sum(property(pld50ll_s_od:prop,"pm")) ]
//end
#ENDIF

//Define Retangle CT for SRAM special connection
SRAM_MARK= (((DPSRAM OR LRSRAM) OR D2SRAM) OR DNSRAM) OR RFSRAM
CTREC = (RECTANGLE CT ==0.06 BY ==0.16) AND SRAM_MARK
CTREC_POLY = CTREC AND poly
CTREC_SD   = CTREC AND (nsd or psd)

CONNECT npoly CTREC BY CTREC_POLY  
CONNECT ppoly CTREC BY CTREC_POLY 
CONNECT nsd CTREC  BY CTREC_SD
CONNECT psd CTREC  BY CTREC_SD

//=================
// dfm properties
//=================
variable MAX_DIS_GT_TO_GT       2
variable MAX_DIS_GATE_TO_ACTIVE 30
variable MAX_DIS_GATE_TO_CT     2
variable MAX_DIS_SCT_TO_DCT     10

act_sd1          = nsd2 OR psd2
act_sd          = act_sd1 NOT ((holes gate1) touch gate1)
orient_gate     = COIN EDGE gate act_sd
gate_to_poly    = DFM SPACE orient_gate GT <= MAX_DIS_GT_TO_GT   BY EXT
gate_to_ct      = DFM SPACE gate dfcont    <= MAX_DIS_GATE_TO_CT BY EXT by layer dfcont


//== AA to AA ==
active_enc = dfm space orient_gate AA < MAX_DIS_GATE_TO_ACTIVE by enc by layer AA
active_ext = dfm space orient_gate AA < MAX_DIS_GATE_TO_ACTIVE by ext count == 1 by layer AA measure all
orientsd_aaprop = dfm property orient_gate active_enc active_ext overlap abut also multi
[ active_space = RANGE_XXY(
                     SORT_MERGE_XXY(
                       CONCAT(VECTOR(ECMIN(active_enc),ECMAX(active_enc),EW(active_enc)),
                              VECTOR(ECMIN(orient_gate),ECMAX(orient_gate),MAX_DIS_GATE_TO_ACTIVE)),
                       CONCAT(VECTOR(ECMIN(active_ext),ECMAX(active_ext),EW(active_ext)),
                              VECTOR(ECMIN(orient_gate),ECMAX(orient_gate),MAX_DIS_GATE_TO_ACTIVE))),
                     VECTOR(ECMIN(orient_gate),ECMAX(orient_gate)))
]

//-- Get dfm props of the first/second/third smallest poly to gate distance ------------------
g2p_prop    = DFM PROPERTY orient_gate gate_to_poly OVERLAP ABUT ALSO MULTI SPLIT
   [ G2P    = SELECT_MERGE_XXY(1,CONCAT(VECTOR (ECMIN(gate_to_poly),ECMAX(gate_to_poly),EW(gate_to_poly)),VECTOR(ECMIN(orient_gate),ECMAX(orient_gate),MAX_DIS_GT_TO_GT)),
                               2,CONCAT(VECTOR (ECMIN(gate_to_poly),ECMAX(gate_to_poly),EW(gate_to_poly)),VECTOR(ECMIN(orient_gate),ECMAX(orient_gate),MAX_DIS_GT_TO_GT)),
                               3,CONCAT(VECTOR (ECMIN(gate_to_poly),ECMAX(gate_to_poly),EW(gate_to_poly)),VECTOR(ECMIN(orient_gate),ECMAX(orient_gate),MAX_DIS_GT_TO_GT)))
   ]

//-- ct dfm -------------------------------
act_sd_num  = DFM PROPERTY act_sd dfcont  OVERLAP ABUT ALSO MULTI [num = count(dfcont)]
g2ct_prop   = DFM PROPERTY orient_gate gate_to_ct OVERLAP ABUT ALSO MULTI
    [ G2CT    = SELECT_MERGE_XXY(1,CONCAT(VECTOR (ECMIN(gate_to_ct),ECMAX(gate_to_ct),EW(gate_to_ct)), VECTOR(ECMIN(orient_gate),ECMAX(orient_gate),MAX_DIS_GATE_TO_CT)))]


gate_props    = DFM PROPERTY gate g2p_prop orient_gate g2ct_prop orientsd_aaprop act_sd_num OVERLAP ABUT ALSO MULTI
//gate_props    = DFM PROPERTY gate g2p_prop orient_gate orientsd_aaprop act_sd_num OVERLAP ABUT ALSO MULTI
   [ - = COUNT(orientsd_aaprop) ] == 2
   [ G2G      = SORT_MERGE_XXY(VECTOR (ECMIN(orient_gate),ECMAX(orient_gate), MAX_DIS_GT_TO_GT )) ]
   [ G2P_S    = VPROPERTY(g2p_prop, "G2P",1) ]
   [ G2P_D    = VPROPERTY(g2p_prop, "G2P",2) ]
   [ G2G      = VPROPERTY(g2p_prop, "G2G")]
   [ G2AA_S   = VPROPERTY(orientsd_aaprop,"active_space",1)]
   [ G2AA_D   = VPROPERTY(orientsd_aaprop,"active_space",2)]
   [ G2CT_S   = VPROPERTY(g2ct_prop, "G2CT",1) ]
   [ G2CT_D   = VPROPERTY(g2ct_prop, "G2CT",2) ]
   [ CT_NUM_S = PROPERTY(act_sd_num,"num",1)]
   [ CT_NUM_D = PROPERTY(act_sd_num,"num",2)]


