///////////////////////////////////////////////////////////////
//BJT definition
DMACRO BJT_PRO reg_layer {
      #IFDEF RC_RUN FALSE
        [ PROPERTY "AREA"
        "AREA" = AREA(reg_layer) ]
      #ENDIF
      #IFDEF RC_RUN TRUE
      #IFDEF BACK_ANNOTATION_FLOW 1
        [ PROPERTY mismod,m,FA
          #IFDEF BJT_MISMOD 0   
           mismod = 0
           m = 1
           FA = AREA(reg_layer)
          #ENDIF
          #IFDEF BJT_MISMOD 1
           mismod = 1
           m = 1
           FA = AREA(reg_layer)
          #ENDIF
           ]
      #ENDIF
      #IFDEF BACK_ANNOTATION_FLOW 2
        [ PROPERTY mismod,m
          #IFDEF BJT_MISMOD 0   
           mismod = 0
           m = 1
          #ENDIF
          #IFDEF BJT_MISMOD 1
           mismod = 1
           m = 1
          #ENDIF
           ]
      #ENDIF
      #ENDIF
}

DMACRO BJT_REDUCE device_name {
       LVS REDUCE device_name PARALLEL yes
      #IFDEF RC_RUN FALSE
       [effective "AREA"
       "AREA" = sum ( "AREA" )
       ]
      #ENDIF
      #IFDEF RC_RUN TRUE
      #ENDIF
}

