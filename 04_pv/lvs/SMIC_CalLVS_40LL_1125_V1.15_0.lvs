///////////////////////////////////////////////////////////////
//*Define MOS  Varactor 
DMACRO VAR_PARALLEL_REDUCE device_name {
       LVS REDUCE device_name PARALLEL yes
       [effective LR,WR
         P = sum ( WR * LR )
         Q = sum ( WR / LR )
         LR = sqrt( P / Q )
         WR = sqrt( P * Q )
       ]
}

DMACRO VARDNW_PARALLEL_REDUCE device_name{
       LVS REDUCE device_name PARALLEL yes
       [TOLERANCE LR 0 WR 0 LADDR 0 WADDR 0
       effective LR,WR,NF,LADDR,WADDR
       //[TOLERANCE LR 0 WR 0 
       // effective LR,WR,NF
         LR = sum ( LR*NF )/sum ( NF )
         WR = sum ( WR*NF )/sum ( NF )
         NF = sum ( NF )
         //LADDR = sum ( LADDR )
         //WADDR = sum ( WADDR )
         LADDR = sum (LADDR*1) / sum (NF )
         WADDR = sum (WADDR*1)/ sum (NF)
       ]
}

DMACRO VAR_PRO layer1 layer2 {
       [ PROPERTY LR,WR,MISMOD,MR,NF
         NF = COUNT(layer1)
         WR = PERIM_CO(layer1,layer2)/(2*NF)
         LR = AREA(layer1)/(WR*NF)
         MR = 1
         #IFDEF VAR_MISMOD 0
          MISMOD = 0
         #ENDIF
         #IFDEF VAR_MISMOD 1
          MISMOD = 1
         #ENDIF
          ]
}


