/*MESH MOM definition*/
DMACRO MOM_MESH_PRO_4T_33  mom_finger mom_metal mom_aux tm_num bm_num mom_col mom_row{
        #IFDEF BACK_ANNOTATION_FLOW 1
        [PROPERTY L,NN,TM,BM,MISMOD,flag_width,mm,col,row
        #ENDIF
        #IFDEF BACK_ANNOTATION_FLOW 2
        [PROPERTY L,NN,TM,BM,MISMOD,flag_width,mm
        #ENDIF
        mm = count(mom_aux)/2 
        NN = count(mom_finger)/(2*MM)
        A = (AREA(mom_finger)/(2*MM))/NN
        W1= perim_in(mom_finger,mom_metal)
        W = (W1/NN)/(2*MM)
        L = A/W+9.0E-08
        TM = tm_num
        BM = bm_num
        flag_width = 0
        col=count(mom_col)
        row=count(mom_row)

        #IFDEF MOM_MISMOD 0
        MISMOD = 0
        #ENDIF
        #IFDEF MOM_MISMOD 1
        MISMOD = 1
        #ENDIF
        ]
}

